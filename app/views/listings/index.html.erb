<div class="min-h-screen bg-[#F2E8D8]">
  <div class="max-w-[1280px] mx-auto px-4 md:px-8 py-8">
    <div class="mb-8">
      <h1 class="font-poppins text-3xl font-semibold text-[#0C1E3B] mb-2">Rechercher une annonce</h1>
      <p class="text-[#1A1A1A]">Filtrez parmi nos annonces pour trouver le véhicule qui vous correspond.</p>
    </div>
    
    <!-- Search Form -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 mb-6">
      <!-- Filter Sidebar -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-xl shadow-md p-6 sticky top-24">
        <%= form_with url: listings_path, method: :get, data: { controller: "search-form" } do |f| %>
            <h3 class="font-poppins font-semibold text-lg text-[#0C1E3B] mb-4">Filtres</h3>
            
            <!-- Type de véhicule -->
            <div class="filter-group mb-6" data-controller="accordion">
              <button type="button" class="filter-header w-full flex justify-between items-center pb-2 border-b border-[#D9D9D9]"
                      data-action="accordion#toggle">
                <h4 class="font-medium text-[#0C1E3B]">Type de véhicule</h4>
                <i class="bi bi-chevron-down text-[#B18B43] transition-transform duration-300"
                   data-accordion-target="icon"></i>
              </button>
              <div class="filter-content pt-3 space-y-3" data-accordion-target="content">
                <div class="form-group">
                <%= f.select :category_id, 
                  @categories.map { |c| [c.name, c.id] },
                  { include_blank: "Toutes les catégories" },
                    { class: "w-full p-2 border border-[#D9D9D9] rounded-lg bg-white", 
                      data: { action: "change->search-form#loadSubcategories" }} %>
              </div>
                <div class="form-group">
                <%= f.select :subcategory, 
                  @subcategories.map(&:name),
                  { include_blank: "Tous les types" },
                    { class: "w-full p-2 border border-[#D9D9D9] rounded-lg bg-white", 
                      disabled: @subcategories.empty?, 
                      data: { search_form_target: "subcategorySelect" }} %>
            </div>
              </div>
            </div>
            
            <!-- Marque / Modèle -->
            <div class="filter-group mb-6" data-controller="accordion">
              <button type="button" class="filter-header w-full flex justify-between items-center pb-2 border-b border-[#D9D9D9]"
                      data-action="accordion#toggle">
                <h4 class="font-medium text-[#0C1E3B]">Marque / Modèle</h4>
                <i class="bi bi-chevron-down text-[#B18B43] transition-transform duration-300"
                   data-accordion-target="icon"></i>
              </button>
              <div class="filter-content pt-3 space-y-3" data-accordion-target="content">
                <div class="form-group">
                  <div class="relative">
                    <i class="bi bi-car-front absolute left-3 top-2.5 text-[#B18B43]"></i>
                    <%= f.text_field :make, class: "w-full p-2 pl-10 border border-[#D9D9D9] rounded-lg bg-white", 
                                     placeholder: "Marque (BMW, Peugeot...)" %>
                  </div>
                </div>
                <div class="form-group">
                  <div class="relative">
                    <i class="bi bi-tag absolute left-3 top-2.5 text-[#B18B43]"></i>
                    <%= f.text_field :model, class: "w-full p-2 pl-10 border border-[#D9D9D9] rounded-lg bg-white", 
                                      placeholder: "Modèle (Série 3, 308...)" %>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Prix / Kilométrage / Année -->
            <div class="filter-group mb-6" data-controller="accordion">
              <button type="button" class="filter-header w-full flex justify-between items-center pb-2 border-b border-[#D9D9D9]"
                      data-action="accordion#toggle">
                <h4 class="font-medium text-[#0C1E3B]">Prix / Kilométrage / Année</h4>
                <i class="bi bi-chevron-down text-[#B18B43] transition-transform duration-300"
                   data-accordion-target="icon"></i>
              </button>
              <div class="filter-content pt-3 space-y-4" data-accordion-target="content">
                <!-- Prix -->
                <div class="form-group">
                  <label class="block text-sm text-[#1A1A1A] mb-1">Prix (€)</label>
                  <div class="flex gap-2">
                    <div class="w-1/2">
                      <%= f.number_field :price_min, class: "w-full p-2 border border-[#D9D9D9] rounded-lg bg-white", 
                                         placeholder: "Min" %>
                  </div>
                    <div class="w-1/2">
                      <%= f.number_field :price_max, class: "w-full p-2 border border-[#D9D9D9] rounded-lg bg-white", 
                                         placeholder: "Max" %>
                </div>
                  </div>
                </div>
                
                <!-- Kilométrage -->
                <div class="form-group">
                  <label class="block text-sm text-[#1A1A1A] mb-1">Kilométrage</label>
                  <div class="flex gap-2">
                    <div class="w-1/2">
                      <%= f.number_field :km_min, class: "w-full p-2 border border-[#D9D9D9] rounded-lg bg-white", 
                                         placeholder: "Min" %>
              </div>
                    <div class="w-1/2">
                      <%= f.number_field :km_max, class: "w-full p-2 border border-[#D9D9D9] rounded-lg bg-white", 
                                         placeholder: "Max" %>
            </div>
                  </div>
                </div>
                
                <!-- Année -->
                <div class="form-group">
                  <label class="block text-sm text-[#1A1A1A] mb-1">Année</label>
                  <div class="flex gap-2">
                    <div class="w-1/2">
                      <%= f.number_field :year_min, class: "w-full p-2 border border-[#D9D9D9] rounded-lg bg-white", 
                                         placeholder: "Min", min: 1900, max: Time.current.year %>
                    </div>
                    <div class="w-1/2">
                      <%= f.number_field :year_max, class: "w-full p-2 border border-[#D9D9D9] rounded-lg bg-white", 
                                         placeholder: "Max", min: 1900, max: Time.current.year %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Carburant / Transmission -->
            <div class="filter-group mb-6" data-controller="accordion">
              <button type="button" class="filter-header w-full flex justify-between items-center pb-2 border-b border-[#D9D9D9]"
                      data-action="accordion#toggle">
                <h4 class="font-medium text-[#0C1E3B]">Carburant / Transmission</h4>
                <i class="bi bi-chevron-down text-[#B18B43] transition-transform duration-300"
                   data-accordion-target="icon"></i>
              </button>
              <div class="filter-content pt-3 space-y-3" data-accordion-target="content">
                <!-- Carburant -->
                <div class="form-group">
                  <label class="block text-sm text-[#1A1A1A] mb-1">Carburant</label>
                  <div class="grid grid-cols-2 gap-2">
                    <% ['Essence', 'Diesel', 'Hybride', 'Électrique', 'GPL', 'Autre'].each do |fuel| %>
                      <div class="flex items-center">
                        <%= f.check_box :fuel_type, { multiple: true, class: "mr-2 accent-[#B18B43]", id: "fuel_#{fuel.parameterize}" }, fuel, nil %>
                        <label for="fuel_<%= fuel.parameterize %>" class="text-sm">
                          <i class="bi <%= fuel_type_icon(fuel) %> mr-1 text-[#B18B43]"></i> <%= fuel %>
                        </label>
                      </div>
                    <% end %>
                  </div>
                </div>
                
                <!-- Transmission -->
                <div class="form-group mt-3">
                  <label class="block text-sm text-[#1A1A1A] mb-1">Transmission</label>
                  <div class="grid grid-cols-1 gap-2">
                    <% ['Manuelle', 'Automatique', 'Semi-automatique'].each do |transmission| %>
                      <div class="flex items-center">
                        <%= f.check_box :transmission, { multiple: true, class: "mr-2 accent-[#B18B43]", id: "transmission_#{transmission.parameterize}" }, transmission, nil %>
                        <label for="transmission_<%= transmission.parameterize %>" class="text-sm">
                          <i class="bi <%= transmission_icon(transmission) %> mr-1 text-[#B18B43]"></i> <%= transmission %>
                        </label>
                  </div>
                    <% end %>
                </div>
              </div>
            </div>
          </div>
          
            <!-- Équipements -->
            <div class="filter-group mb-6" data-controller="accordion">
              <button type="button" class="filter-header w-full flex justify-between items-center pb-2 border-b border-[#D9D9D9]"
                      data-action="accordion#toggle">
                <h4 class="font-medium text-[#0C1E3B]">Équipements</h4>
                <i class="bi bi-chevron-down text-[#B18B43] transition-transform duration-300"
                   data-accordion-target="icon"></i>
              </button>
              <div class="filter-content pt-3" data-accordion-target="content">
                <% @equipment_categories.each do |(category, equipment_list)| %>
                  <div class="mb-4" data-controller="accordion">
                    <button type="button" class="w-full flex justify-between items-center text-sm pb-1 border-b border-[#D9D9D9] opacity-80"
                            data-action="accordion#toggle">
                      <span class="font-medium"><%= category %></span>
                      <i class="bi bi-chevron-down text-[#B18B43] text-xs transition-transform duration-300"
                         data-accordion-target="icon"></i>
                      </button>
                    <div class="pt-2 pl-1 grid grid-cols-1 gap-1 hidden" data-accordion-target="content">
                          <% equipment_list.each do |equipment| %>
                        <div class="flex items-center">
                          <%= f.check_box :equipment, { multiple: true, class: "mr-2 accent-[#B18B43]", id: "equipment_#{equipment.parameterize}" }, equipment, nil %>
                          <label for="equipment_<%= equipment.parameterize %>" class="text-sm flex items-center">
                            <i class="bi <%= equipment_icon(equipment) %> mr-1 text-[#B18B43]"></i>
                            <%= equipment %>
                          </label>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
            
            <!-- Spécificités -->
            <div class="filter-group mb-6" data-controller="accordion">
              <button type="button" class="filter-header w-full flex justify-between items-center pb-2 border-b border-[#D9D9D9]"
                      data-action="accordion#toggle">
                <h4 class="font-medium text-[#0C1E3B]">Spécificités</h4>
                <i class="bi bi-chevron-down text-[#B18B43] transition-transform duration-300"
                   data-accordion-target="icon"></i>
              </button>
              <div class="filter-content pt-3 space-y-3" data-accordion-target="content">
                <!-- Specific filters will be loaded dynamically based on vehicle type -->
                <div data-search-form-target="specificFilters" class="space-y-4">
                  <!-- Specific filters will be inserted here -->
          </div>
          </div>
            </div>
            
            <div class="flex gap-3 justify-between mt-8">
              <%= link_to "Réinitialiser", listings_path, class: "btn btn-ghost text-[#0C1E3B] border-[#D9D9D9]" %>
              <%= f.submit "Appliquer les filtres", class: "btn bg-[#B18B43] hover:bg-[#A0782D] text-white border-none" %>
          </div>
        <% end %>
      </div>
    </div>
      
      <!-- Listings Results -->
      <div class="lg:col-span-3">
        <!-- Results Header & Sorting -->
        <div class="bg-white rounded-xl shadow-md p-4 mb-6">
          <div class="flex flex-col sm:flex-row justify-between items-center">
            <div>
              <div class="flex items-center">
                <h2 class="font-poppins text-lg font-semibold text-[#0C1E3B] mr-2">Résultats</h2>
                <span class="badge bg-[#B18B43] text-white border-none"><%= @listings.count %> annonces</span>
              </div>
              <p class="text-sm text-[#1A1A1A] opacity-75">
                <%= search_summary(params) %>
              </p>
  </div>

            <div class="mt-3 sm:mt-0">
              <div class="dropdown dropdown-end">
                <label tabindex="0" class="btn btn-sm bg-white hover:bg-[#F2E8D8] text-[#0C1E3B] border-[#D9D9D9]">
                  <i class="bi bi-sort-down mr-2"></i> 
                  <%= sort_label(params[:sort]) || "Trier par" %>
                </label>
                <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
                  <li><%= link_to "Plus récentes", listings_path(request.query_parameters.merge(sort: "date_desc")) %></li>
                  <li><%= link_to "Plus anciennes", listings_path(request.query_parameters.merge(sort: "date_asc")) %></li>
                  <li><%= link_to "Prix croissant", listings_path(request.query_parameters.merge(sort: "price_asc")) %></li>
                  <li><%= link_to "Prix décroissant", listings_path(request.query_parameters.merge(sort: "price_desc")) %></li>
                  <li><%= link_to "Kilométrage croissant", listings_path(request.query_parameters.merge(sort: "km_asc")) %></li>
                  <li><%= link_to "Année: plus récentes", listings_path(request.query_parameters.merge(sort: "year_desc")) %></li>
                  <li><%= link_to "Année: plus anciennes", listings_path(request.query_parameters.merge(sort: "year_asc")) %></li>
      </ul>
              </div>
            </div>
    </div>
  </div>
  
        <!-- Listing Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% @listings.each do |listing| %>
            <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
              <!-- Image container with badge -->
              <div class="relative h-48">
                <% if listing.main_photo&.file.present? %>
                  <%= image_tag listing.main_photo.file, class: "w-full h-full object-cover" %>
                <% else %>
                  <div class="w-full h-full flex items-center justify-center bg-[#D9D9D9]">
                    <i class="bi bi-image text-[#0C1E3B] text-4xl"></i>
                      </div>
                    <% end %>
                
                <!-- Status Badge -->
                <% if recently_created?(listing) %>
                  <div class="absolute top-3 left-3">
                    <span class="bg-[#B18B43] text-white text-xs font-medium px-2.5 py-1 rounded-lg">NOUVEAU</span>
                  </div>
                <% end %>
                
                <!-- Certification Badge -->
                <% if listing.certified? %>
                  <div class="absolute top-3 right-3">
                    <span class="bg-blue-600 text-white text-xs font-medium px-2.5 py-1 rounded-lg flex items-center">
                      <i class="bi bi-patch-check-fill mr-1"></i> CERTIFIÉ
                    </span>
                  </div>
                <% end %>
              </div>
              
              <!-- Content -->
              <div class="p-4">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="font-poppins font-medium text-[#0C1E3B] truncate"><%= listing.title %></h3>
                  <p class="font-semibold text-[#B18B43]">
                    <%= number_to_currency(listing.vehicle.price, precision: 0, unit: "€", delimiter: " ") %>
                  </p>
                      </div>
                      
                <p class="text-sm text-[#1A1A1A] line-clamp-2 mb-3"><%= listing.vehicle.make %> <%= listing.vehicle.model %></p>
                
                <!-- Specs -->
                <div class="grid grid-cols-2 gap-2 mb-4">
                  <div class="flex items-center text-xs text-[#1A1A1A]">
                    <i class="bi bi-calendar3 text-[#B18B43] mr-1"></i>
                    <%= listing.vehicle.year %>
                      </div>
                  <div class="flex items-center text-xs text-[#1A1A1A]">
                    <i class="bi bi-speedometer2 text-[#B18B43] mr-1"></i>
                    <%= number_with_delimiter(listing.vehicle.mileage) %> km
                        </div>
                  <div class="flex items-center text-xs text-[#1A1A1A]">
                    <i class="bi bi-fuel-pump text-[#B18B43] mr-1"></i>
                    <%= listing.vehicle.fuel_type %>
                      </div>
                  <div class="flex items-center text-xs text-[#1A1A1A]">
                    <i class="bi bi-gear-wide-connected text-[#B18B43] mr-1"></i>
                    <%= listing.vehicle.transmission %>
                  </div>
                </div>
                
                <!-- Button -->
                <%= link_to "Voir l'annonce", listing_path(listing), class: "btn btn-sm w-full bg-[#F2E8D8] hover:bg-[#D9D9D9] border-none text-[#0C1E3B]" %>
              </div>
            </div>
          <% end %>
        </div>
        
        <!-- Pagination -->
        <% if @listings.respond_to?(:total_pages) %>
          <div class="mt-8 flex justify-center">
            <%= paginate @listings %>
          </div>
        <% end %>
      </div>
    </div>
    </div>
</div>

<% content_for :head do %>
<script>
    document.addEventListener('DOMContentLoaded', function() {
      // Accordion functionality
      const accordions = document.querySelectorAll('[data-controller="accordion"]');
      
      accordions.forEach(accordion => {
        const toggle = accordion.querySelector('[data-action="accordion#toggle"]');
        const content = accordion.querySelector('[data-accordion-target="content"]');
        const icon = accordion.querySelector('[data-accordion-target="icon"]');
        
        if (toggle && content) {
          toggle.addEventListener('click', () => {
            content.classList.toggle('hidden');
            if (icon) {
              icon.classList.toggle('rotate-180');
            }
          });
        }
      });
      
      // Show main accordions by default (not nested ones)
      document.querySelectorAll('.filter-group > .filter-content').forEach(content => {
        content.classList.remove('hidden');
      });
  });
</script>
<% end %>
