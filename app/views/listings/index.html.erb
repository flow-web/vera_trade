<div class="container pt-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="m-0"><span class="badge bg-primary"><%= @listings.count %></span> annonces trouvées</h5>
    <div class="dropdown">
      <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-sort-down"></i> Trier
      </button>
      <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuButton">
        <li><a class="dropdown-item" href="#">Prix: croissant</a></li>
        <li><a class="dropdown-item" href="#">Prix: décroissant</a></li>
        <li><a class="dropdown-item" href="#">Date: plus récentes</a></li>
        <li><a class="dropdown-item" href="#">Date: plus anciennes</a></li>
        <li><a class="dropdown-item" href="#">Kilométrage: croissant</a></li>
        <li><a class="dropdown-item" href="#">Date d'immatriculation: récentes</a></li>
        <li><a class="dropdown-item" href="#">Date d'immatriculation: anciennes</a></li>
        <li><a class="dropdown-item" href="#">Consommation: économique</a></li>
      </ul>
    </div>
  </div>
  
  <% if @listings.any? %>
    <div class="listings-container bg-white border rounded p-0">
      <% @listings.each_with_index do |listing, index| %>
        <%= link_to listing, class: "text-decoration-none" do %>
          <div class="listing-card <%= index > 0 ? 'border-top' : '' %> p-3">
            <div class="row g-0">
              <!-- Image section - côté gauche -->
              <div class="col-4 col-md-3">
                <% if listing.photos.attached? %>
                  <div class="listing-image position-relative rounded bg-light" style="height: 150px; display: flex; align-items: center; justify-content: center;">
                    <%= image_tag listing.photos.first, style: "max-height: 100%; max-width: 100%; object-fit: contain;" %>
                    <% if listing.vehicle.non_smoker.present? && listing.vehicle.non_smoker %>
                      <div class="position-absolute bottom-0 end-0 m-1">
                        <span class="badge bg-success rounded-pill">
                          <i class="bi bi-slash-circle"></i>
                        </span>
                      </div>
                    <% end %>
                  </div>
                <% else %>
                  <div class="listing-image bg-light d-flex justify-content-center align-items-center rounded" style="height: 150px;">
                    <i class="bi bi-camera fs-4 text-muted"></i>
                  </div>
                <% end %>
              </div>
              
              <!-- Information section - côté droit -->
              <div class="col-8 col-md-9">
                <div class="ps-3">
                  <div class="row">
                    <div class="col-md-8">
                      <h5 class="listing-title text-dark fw-bold mb-1 text-truncate"><%= listing.title %></h5>
                      <div class="listing-category text-dark mb-2">
                        <%= listing.vehicle.make %> <%= listing.vehicle.model %> (<%= listing.vehicle.year %>)
                        <% if listing.vehicle.finition.present? %>
                          - <%= listing.vehicle.finition %>
                        <% end %>
                      </div>
                      
                      <!-- Caractéristiques du véhicule - badges -->
                      <div class="listing-details d-flex flex-wrap gap-2 mb-2">
                        <% if listing.vehicle.kilometers.present? %>
                          <span class="badge bg-light text-dark"><i class="bi bi-speedometer2 me-1"></i><%= number_with_delimiter(listing.vehicle.kilometers) %> km</span>
                        <% end %>
                        <% if listing.vehicle.fuel_type.present? %>
                          <span class="badge bg-light text-dark"><i class="bi bi-fuel-pump me-1"></i><%= listing.vehicle.fuel_type %></span>
                        <% end %>
                        <% if listing.vehicle.transmission.present? %>
                          <span class="badge bg-light text-dark"><i class="bi bi-gear me-1"></i><%= listing.vehicle.transmission %></span>
                        <% end %>
                        <% if listing.vehicle.doors.present? %>
                          <span class="badge bg-light text-dark"><i class="bi bi-door-closed me-1"></i><%= listing.vehicle.doors %> portes</span>
                        <% end %>
                        <% if listing.vehicle.exterior_color.present? %>
                          <span class="badge bg-light text-dark"><i class="bi bi-palette me-1"></i><%= listing.vehicle.exterior_color %></span>
                        <% end %>
                        <% if listing.vehicle.interior_material.present? %>
                          <span class="badge bg-light text-dark"><i class="bi bi-chair me-1"></i><%= listing.vehicle.interior_material %></span>
                        <% end %>
                      </div>

                      <!-- Seconde ligne de badges -->
                      <div class="listing-details d-flex flex-wrap gap-2 mb-2">
                        <% if listing.vehicle.previous_owners.present? %>
                          <span class="badge bg-light text-dark"><i class="bi bi-people me-1"></i><%= listing.vehicle.previous_owners %> prop.</span>
                        <% end %>
                        <% if listing.vehicle.last_service_date.present? %>
                          <span class="badge bg-light text-dark"><i class="bi bi-tools me-1"></i>Entretien: <%= listing.vehicle.last_service_date.strftime("%m/%Y") %></span>
                        <% end %>
                        <% if listing.vehicle.ct_expiry_date.present? %>
                          <span class="badge bg-light text-dark"><i class="bi bi-check-circle me-1"></i>CT: <%= listing.vehicle.ct_expiry_date.strftime("%m/%Y") %></span>
                        <% end %>
                        <% if listing.vehicle.has_service_history.present? && listing.vehicle.has_service_history %>
                          <span class="badge bg-light text-dark"><i class="bi bi-journal-check me-1"></i>Carnet</span>
                        <% end %>
                      </div>
                      
                      <!-- Description en format desktop -->
                      <div class="d-none d-md-block text-dark mt-2">
                        <div class="text-truncate-2" style="max-height: 40px; overflow: hidden;">
                          <%= listing.description %>
                        </div>
                      </div>
                    </div>
                    
                    <div class="col-md-4 d-flex flex-column align-items-end justify-content-between">
                      <!-- Prix -->
                      <div>
                        <div class="listing-price text-primary fw-bold fs-4">
                          <%= number_to_currency(listing.vehicle.price, unit: "€", precision: 0) %>
                        </div>
                      </div>
                      
                      <!-- Localisation et date -->
                      <div class="d-flex flex-column align-items-end mt-auto">
                        <% if listing.vehicle.location.present? %>
                          <div class="text-muted small mb-1">
                            <i class="bi bi-geo-alt"></i> <%= listing.vehicle.location %>
                          </div>
                        <% end %>
                        <div class="text-muted small">
                          <i class="bi bi-clock"></i> <%= time_ago_in_words(listing.created_at) %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info">
      Aucune annonce n'est disponible pour le moment.
    </div>
  <% end %>
</div>

<style>
  .listing-card {
    transition: background-color 0.2s;
  }
  
  .listing-card:hover {
    background-color: #f8f9fa;
  }
  
  .text-truncate-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .dropdown-toggle::after {
    display: none;
  }
  
  .badge {
    padding: 0.4em 0.6em;
    font-weight: normal;
  }
</style>
