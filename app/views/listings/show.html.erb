<div class="container mx-auto px-4 py-8 max-w-5xl">
  <!-- Breadcrumb -->
  <div class="text-sm breadcrumbs mb-6">
    <ul>
      <li><%= link_to "Annonces", listings_path, class: "link link-hover" %></li>
      <li class="font-medium"><%= @listing.title %></li>
    </ul>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Main Content -->
    <div class="col-span-2">
      <div class="container mt-5">
        <div class="row">
          <div class="col-md-8 mb-4">
            <h1 class="h2 mb-3"><%= @listing.title %></h1>
            
            <% if @public_media.any? %>
              <!-- Galerie de médias -->
              <div class="mb-8">
                <div class="carousel w-full rounded-lg overflow-hidden mb-4" id="mediaCarousel">
                  <% @public_media.each_with_index do |media_item, index| %>
                    <div id="slide-<%= index %>" class="carousel-item relative w-full <%= index == 0 ? 'active' : 'hidden' %>">
                      <% if media_item.content_type == 'image' %>
                        <%= image_tag url_for(media_item.media), class: "w-full h-96 object-contain bg-base-200" %>
                      <% elsif media_item.content_type == 'video' %>
                        <video class="w-full h-96 bg-base-200" controls>
                          <source src="<%= url_for(media_item.media) %>" type="<%= media_item.media.content_type %>">
                          Votre navigateur ne supporte pas la lecture vidéo.
                        </video>
                      <% end %>
                      
                      <div class="absolute left-0 right-0 bottom-0 bg-black bg-opacity-50 p-2 text-white">
                        <div class="flex justify-between items-center">
                          <span class="text-xs"><%= media_item.title %></span>
                          <span class="badge badge-primary"><%= media_item.context.presence || 'Sans contexte' %></span>
                        </div>
                      </div>
                      
                      <div class="absolute flex justify-between transform -translate-y-1/2 left-5 right-5 top-1/2">
                        <a href="#slide-<%= (index - 1) % @public_media.count %>" class="btn btn-circle">❮</a> 
                        <a href="#slide-<%= (index + 1) % @public_media.count %>" class="btn btn-circle">❯</a>
                      </div>
                    </div>
                  <% end %>
                </div>
                
                <!-- Thumbnails -->
                <div class="grid grid-cols-4 md:grid-cols-6 gap-2">
                  <% @public_media.each_with_index do |media_item, index| %>
                    <div class="carousel-thumbnail cursor-pointer" data-target="slide-<%= index %>">
                      <% if media_item.content_type == 'image' %>
                        <%= image_tag url_for(media_item.media), class: "w-full h-20 object-cover rounded-md" %>
                      <% elsif media_item.content_type == 'video' %>
                        <div class="w-full h-20 flex items-center justify-center bg-base-200 rounded-md relative">
                          <i class="bi bi-film text-3xl text-primary"></i>
                          <div class="absolute bottom-1 right-1">
                            <div class="badge badge-xs badge-primary">Vidéo</div>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% else %>
              <div class="card mb-4">
                <div class="card-body text-center py-5">
                  <i class="bi bi-camera fs-1 text-muted"></i>
                  <p class="text-muted mt-2">Aucune photo disponible</p>
                </div>
              </div>
            <% end %>
            
            <h2 class="text-xl text-neutral-content mb-6">
              <%= @listing.vehicle.make %> <%= @listing.vehicle.model %> (<%= @listing.vehicle.year %>)
            </h2>

            <!-- Vehicle Details Card -->
            <div class="card bg-base-100 shadow-sm mb-8">
              <div class="card-body">
                <!-- Description Section -->
                <div class="mb-6">
                  <h3 class="text-lg font-medium mb-2">Description</h3>
                  <div class="prose max-w-none">
                    <% combined_description = @listing.description.to_s %>
                    <% if @listing.vehicle.description.present? %>
                      <% combined_description += "\n\n" + @listing.vehicle.description if @listing.description.present? %>
                      <% combined_description = @listing.vehicle.description if combined_description.blank? %>
                    <% end %>
                    <%= simple_format(combined_description) %>
                  </div>
                </div>
                
                <!-- Vehicle Characteristics Section -->
                <div>
                  <h3 class="text-lg font-medium mb-2">Caractéristiques du véhicule</h3>
                  
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                    <div>
                      <div class="flex flex-col space-y-2">
                        <div class="flex justify-between">
                          <span class="font-medium">Marque:</span>
                          <span><%= @listing.vehicle.make %></span>
                        </div>
                        <div class="flex justify-between">
                          <span class="font-medium">Modèle:</span>
                          <span><%= @listing.vehicle.model %></span>
                        </div>
                        <div class="flex justify-between">
                          <span class="font-medium">Année:</span>
                          <span><%= @listing.vehicle.year %></span>
                        </div>
                        <% if @listing.vehicle.finition.present? %>
                          <div class="flex justify-between">
                            <span class="font-medium">Finition/Version:</span>
                            <span><%= @listing.vehicle.finition %></span>
                          </div>
                        <% end %>
                        <% if @listing.vehicle.doors.present? %>
                          <div class="flex justify-between">
                            <span class="font-medium">Nombre de portes:</span>
                            <span><%= @listing.vehicle.doors %> portes</span>
                          </div>
                        <% end %>
                        <% if @listing.vehicle.exterior_color.present? %>
                          <div class="flex justify-between">
                            <span class="font-medium">Couleur extérieure:</span>
                            <span><%= @listing.vehicle.exterior_color %></span>
                          </div>
                        <% end %>
                        <% if @listing.vehicle.interior_material.present? || @listing.vehicle.interior_color.present? %>
                          <div class="flex justify-between">
                            <span class="font-medium">Intérieur:</span>
                            <span>
                              <% if @listing.vehicle.interior_material.present? %>
                                <%= @listing.vehicle.interior_material %>
                              <% end %>
                              <% if @listing.vehicle.interior_color.present? %>
                                <%= @listing.vehicle.interior_material.present? ? " - " : "" %><%= @listing.vehicle.interior_color %>
                              <% end %>
                            </span>
                          </div>
                        <% end %>
                      </div>
                    </div>
                    <div>
                      <div class="flex flex-col space-y-2">
                        <% if @listing.vehicle.kilometers.present? %>
                          <div class="flex justify-between">
                            <span class="font-medium">Kilométrage:</span>
                            <span><%= number_with_delimiter(@listing.vehicle.kilometers) %> km</span>
                          </div>
                        <% end %>
                        <% if @listing.vehicle.fuel_type.present? %>
                          <div class="flex justify-between">
                            <span class="font-medium">Carburant:</span>
                            <span><%= @listing.vehicle.fuel_type %></span>
                          </div>
                        <% end %>
                        <% if @listing.vehicle.transmission.present? %>
                          <div class="flex justify-between">
                            <span class="font-medium">Transmission:</span>
                            <span><%= @listing.vehicle.transmission %></span>
                          </div>
                        <% end %>
                        <% if @listing.vehicle.previous_owners.present? %>
                          <div class="flex justify-between">
                            <span class="font-medium">Propriétaires précédents:</span>
                            <span><%= @listing.vehicle.previous_owners %></span>
                          </div>
                        <% end %>
                        <% if @listing.vehicle.non_smoker.present? %>
                          <div class="flex justify-between">
                            <span class="font-medium">Non-fumeur:</span>
                            <span><%= @listing.vehicle.non_smoker ? "Oui" : "Non" %></span>
                          </div>
                        <% end %>
                        <% if @listing.vehicle.location.present? %>
                          <div class="flex justify-between">
                            <span class="font-medium">Lieu de visualisation:</span>
                            <span><%= @listing.vehicle.location %></span>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                  
                  <!-- Historique entretien -->
                  <% if @listing.vehicle.last_service_date.present? || @listing.vehicle.next_ct_date.present? || @listing.vehicle.ct_expiry_date.present? || @listing.vehicle.has_service_history.present? %>
                    <div class="mt-6">
                      <h4 class="text-md font-medium mb-2">Historique et entretien</h4>
                      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="flex flex-col space-y-2">
                          <% if @listing.vehicle.last_service_date.present? %>
                            <div class="flex justify-between">
                              <span class="font-medium">Dernière révision:</span>
                              <span><%= @listing.vehicle.last_service_date.strftime("%d/%m/%Y") %></span>
                            </div>
                          <% end %>
                          <% if @listing.vehicle.has_service_history.present? %>
                            <div class="flex justify-between">
                              <span class="font-medium">Carnet d'entretien:</span>
                              <span><%= @listing.vehicle.has_service_history ? "Disponible" : "Non disponible" %></span>
                            </div>
                          <% end %>
                        </div>
                        <div class="flex flex-col space-y-2">
                          <% if @listing.vehicle.next_ct_date.present? %>
                            <div class="flex justify-between">
                              <span class="font-medium">Prochain contrôle technique:</span>
                              <span><%= @listing.vehicle.next_ct_date.strftime("%d/%m/%Y") %></span>
                            </div>
                          <% end %>
                          <% if @listing.vehicle.ct_expiry_date.present? %>
                            <div class="flex justify-between">
                              <span class="font-medium">Validité du CT:</span>
                              <span><%= @listing.vehicle.ct_expiry_date.strftime("%d/%m/%Y") %></span>
                            </div>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                  
                  <!-- Équipements -->
                  <% if @listing.vehicle.safety_features.present? || @listing.vehicle.comfort_features.present? || @listing.vehicle.multimedia_features.present? || @listing.vehicle.exterior_features.present? || @listing.vehicle.other_features.present? %>
                    <div class="mt-6">
                      <h4 class="text-md font-medium mb-2">Équipements et options</h4>
                      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <% if @listing.vehicle.safety_features.present? %>
                          <div>
                            <div class="font-medium mb-1">Sécurité</div>
                            <div class="prose max-w-none">
                              <%= simple_format(@listing.vehicle.safety_features) %>
                            </div>
                          </div>
                        <% end %>
                        
                        <% if @listing.vehicle.comfort_features.present? %>
                          <div>
                            <div class="font-medium mb-1">Confort</div>
                            <div class="prose max-w-none">
                              <%= simple_format(@listing.vehicle.comfort_features) %>
                            </div>
                          </div>
                        <% end %>
                        
                        <% if @listing.vehicle.multimedia_features.present? %>
                          <div>
                            <div class="font-medium mb-1">Multimédia</div>
                            <div class="prose max-w-none">
                              <%= simple_format(@listing.vehicle.multimedia_features) %>
                            </div>
                          </div>
                        <% end %>
                        
                        <% if @listing.vehicle.exterior_features.present? %>
                          <div>
                            <div class="font-medium mb-1">Extérieur</div>
                            <div class="prose max-w-none">
                              <%= simple_format(@listing.vehicle.exterior_features) %>
                            </div>
                          </div>
                        <% end %>
                        
                        <% if @listing.vehicle.other_features.present? %>
                          <div>
                            <div class="font-medium mb-1">Autres</div>
                            <div class="prose max-w-none">
                              <%= simple_format(@listing.vehicle.other_features) %>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                  
                  <!-- État et frais à prévoir -->
                  <% if @listing.vehicle.body_condition.present? || @listing.vehicle.interior_condition.present? || @listing.vehicle.tire_condition.present? || @listing.vehicle.recent_works.present? || @listing.vehicle.issues.present? || @listing.vehicle.expected_costs.present? %>
                    <div class="mt-6">
                      <h4 class="text-md font-medium mb-2">État du véhicule et entretien</h4>
                      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <% if @listing.vehicle.body_condition.present? %>
                          <div>
                            <div class="font-medium mb-1">État de la carrosserie</div>
                            <div class="prose max-w-none">
                              <%= simple_format(@listing.vehicle.body_condition) %>
                            </div>
                          </div>
                        <% end %>
                        
                        <% if @listing.vehicle.interior_condition.present? %>
                          <div>
                            <div class="font-medium mb-1">État de l'intérieur</div>
                            <div class="prose max-w-none">
                              <%= simple_format(@listing.vehicle.interior_condition) %>
                            </div>
                          </div>
                        <% end %>
                        
                        <% if @listing.vehicle.tire_condition.present? %>
                          <div>
                            <div class="font-medium mb-1">État des pneus</div>
                            <div class="prose max-w-none">
                              <%= simple_format(@listing.vehicle.tire_condition) %>
                            </div>
                          </div>
                        <% end %>
                        
                        <% if @listing.vehicle.recent_works.present? %>
                          <div>
                            <div class="font-medium mb-1">Travaux récents effectués</div>
                            <div class="prose max-w-none">
                              <%= simple_format(@listing.vehicle.recent_works) %>
                            </div>
                          </div>
                        <% end %>
                        
                        <% if @listing.vehicle.issues.present? %>
                          <div>
                            <div class="font-medium mb-1">Points à signaler</div>
                            <div class="prose max-w-none">
                              <%= simple_format(@listing.vehicle.issues) %>
                            </div>
                          </div>
                        <% end %>
                        
                        <% if @listing.vehicle.expected_costs.present? %>
                          <div>
                            <div class="font-medium mb-1">Frais à prévoir</div>
                            <div class="prose max-w-none">
                              <%= simple_format(@listing.vehicle.expected_costs) %>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>

            <!-- Équipements Section -->
            <% 
            safety_features = @listing.vehicle.safety_features.present? ? @listing.vehicle.safety_features.split("\n").reject(&:blank?) : []
            comfort_features = @listing.vehicle.comfort_features.present? ? @listing.vehicle.comfort_features.split("\n").reject(&:blank?) : []
            multimedia_features = @listing.vehicle.multimedia_features.present? ? @listing.vehicle.multimedia_features.split("\n").reject(&:blank?) : []
            exterior_features = @listing.vehicle.exterior_features.present? ? @listing.vehicle.exterior_features.split("\n").reject(&:blank?) : []
            other_features = @listing.vehicle.other_features.present? ? @listing.vehicle.other_features.split("\n").reject(&:blank?) : []
            
            has_any_features = safety_features.any? || comfort_features.any? || multimedia_features.any? || exterior_features.any? || other_features.any?
            %>
            
            <% if has_any_features %>
              <div class="mt-8">
                <h3 class="text-lg font-medium mb-4">Équipements et options</h3>
                
                <div class="tabs tabs-boxed mb-4">
                  <% if safety_features.any? %>
                    <a class="tab tab-active" data-target="safety-tab">Sécurité</a>
                  <% end %>
                  <% if comfort_features.any? %>
                    <a class="tab <%= 'tab-active' if !safety_features.any? %>" data-target="comfort-tab">Confort</a>
                  <% end %>
                  <% if multimedia_features.any? %>
                    <a class="tab <%= 'tab-active' if !safety_features.any? && !comfort_features.any? %>" data-target="multimedia-tab">Multimédia</a>
                  <% end %>
                  <% if exterior_features.any? %>
                    <a class="tab <%= 'tab-active' if !safety_features.any? && !comfort_features.any? && !multimedia_features.any? %>" data-target="exterior-tab">Extérieur</a>
                  <% end %>
                  <% if other_features.any? %>
                    <a class="tab <%= 'tab-active' if !safety_features.any? && !comfort_features.any? && !multimedia_features.any? && !exterior_features.any? %>" data-target="other-tab">Autre</a>
                  <% end %>
                </div>
                
                <div class="features-content px-2">
                  <% if safety_features.any? %>
                    <div id="safety-tab" class="tab-content">
                      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                        <% safety_features.each do |feature| %>
                          <div class="flex items-center">
                            <span class="text-primary mr-2"><i class="bi bi-check-circle-fill"></i></span>
                            <span><%= feature %></span>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                  
                  <% if comfort_features.any? %>
                    <div id="comfort-tab" class="tab-content <%= 'hidden' if safety_features.any? %>">
                      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                        <% comfort_features.each do |feature| %>
                          <div class="flex items-center">
                            <span class="text-primary mr-2"><i class="bi bi-check-circle-fill"></i></span>
                            <span><%= feature %></span>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                  
                  <% if multimedia_features.any? %>
                    <div id="multimedia-tab" class="tab-content <%= 'hidden' if safety_features.any? || comfort_features.any? %>">
                      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                        <% multimedia_features.each do |feature| %>
                          <div class="flex items-center">
                            <span class="text-primary mr-2"><i class="bi bi-check-circle-fill"></i></span>
                            <span><%= feature %></span>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                  
                  <% if exterior_features.any? %>
                    <div id="exterior-tab" class="tab-content <%= 'hidden' if safety_features.any? || comfort_features.any? || multimedia_features.any? %>">
                      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                        <% exterior_features.each do |feature| %>
                          <div class="flex items-center">
                            <span class="text-primary mr-2"><i class="bi bi-check-circle-fill"></i></span>
                            <span><%= feature %></span>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                  
                  <% if other_features.any? %>
                    <div id="other-tab" class="tab-content <%= 'hidden' if safety_features.any? || comfort_features.any? || multimedia_features.any? || exterior_features.any? %>">
                      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                        <% other_features.each do |feature| %>
                          <div class="flex items-center">
                            <span class="text-primary mr-2"><i class="bi bi-check-circle-fill"></i></span>
                            <span><%= feature %></span>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
            
            <!-- Caractéristiques spécifiques selon le type de véhicule -->
            <% if @listing.vehicle.category.present? %>
              <% 
              # Récupérer les champs spécifiques remplis en fonction de la catégorie
              specific_fields = []
              
              case @listing.vehicle.category.name
              when "Voiture"
                # Déjà affichés dans les caractéristiques standards
              when "Moto"
                specific_fields << ["Cylindrée", "#{@listing.vehicle.cylinder_capacity} cm³"] if @listing.vehicle.cylinder_capacity.present?
                specific_fields << ["Type de moteur", @listing.vehicle.engine_type] if @listing.vehicle.engine_type.present?
                specific_fields << ["Refroidissement", @listing.vehicle.cooling_type] if @listing.vehicle.cooling_type.present?
                specific_fields << ["Démarrage", @listing.vehicle.starter_type] if @listing.vehicle.starter_type.present?
                specific_fields << ["Permis requis", @listing.vehicle.license_type] if @listing.vehicle.license_type.present?
              when "Bateau"
                specific_fields << ["Longueur", "#{@listing.vehicle.length} m"] if @listing.vehicle.length.present?
                specific_fields << ["Largeur", "#{@listing.vehicle.width} m"] if @listing.vehicle.width.present?
                specific_fields << ["Tirant d'eau", "#{@listing.vehicle.draft} m"] if @listing.vehicle.draft.present?
                specific_fields << ["Matériau de coque", @listing.vehicle.hull_material] if @listing.vehicle.hull_material.present?
                specific_fields << ["Nombre de cabines", @listing.vehicle.number_of_cabins] if @listing.vehicle.number_of_cabins.present?
                specific_fields << ["Nombre de couchettes", @listing.vehicle.number_of_berths] if @listing.vehicle.number_of_berths.present?
                specific_fields << ["Heures moteur", @listing.vehicle.engine_hours] if @listing.vehicle.engine_hours.present?
              when "Quad"
                specific_fields << ["Cylindrée", "#{@listing.vehicle.cylinder_capacity} cm³"] if @listing.vehicle.cylinder_capacity.present?
                specific_fields << ["Type de moteur", @listing.vehicle.engine_type] if @listing.vehicle.engine_type.present?
                specific_fields << ["Refroidissement", @listing.vehicle.cooling_type] if @listing.vehicle.cooling_type.present?
                specific_fields << ["Transmission", @listing.vehicle.transmission_type] if @listing.vehicle.transmission_type.present?
                specific_fields << ["Entraînement", @listing.vehicle.drive_type] if @listing.vehicle.drive_type.present?
                specific_fields << ["Démarrage", @listing.vehicle.starter_type] if @listing.vehicle.starter_type.present?
              when "Avion"
                specific_fields << ["Nombre de places", @listing.vehicle.number_of_seats] if @listing.vehicle.number_of_seats.present?
                specific_fields << ["Heures de vol", @listing.vehicle.flight_hours] if @listing.vehicle.flight_hours.present?
                specific_fields << ["Heures moteur", @listing.vehicle.engine_hours] if @listing.vehicle.engine_hours.present?
                specific_fields << ["Nombre de moteurs", @listing.vehicle.number_of_engines] if @listing.vehicle.number_of_engines.present?
                specific_fields << ["Plafond", "#{@listing.vehicle.ceiling} pieds"] if @listing.vehicle.ceiling.present?
                specific_fields << ["Autonomie", "#{@listing.vehicle.range} km"] if @listing.vehicle.range.present?
              when "Véhicule de chantier"
                specific_fields << ["Heures de fonctionnement", @listing.vehicle.operating_hours] if @listing.vehicle.operating_hours.present?
                specific_fields << ["Capacité de levage", "#{@listing.vehicle.lifting_capacity} tonnes"] if @listing.vehicle.lifting_capacity.present?
                specific_fields << ["Portée maximale", "#{@listing.vehicle.maximum_reach} m"] if @listing.vehicle.maximum_reach.present?
                specific_fields << ["Capacité du godet", "#{@listing.vehicle.bucket_capacity} m³"] if @listing.vehicle.bucket_capacity.present?
                specific_fields << ["Équipements additionnels", @listing.vehicle.additional_equipment] if @listing.vehicle.additional_equipment.present?
              when "Camion"
                specific_fields << ["Capacité de charge", "#{@listing.vehicle.loading_capacity} tonnes"] if @listing.vehicle.loading_capacity.present?
                specific_fields << ["Capacité de remorquage", "#{@listing.vehicle.towing_capacity} tonnes"] if @listing.vehicle.towing_capacity.present?
                specific_fields << ["Nombre d'essieux", @listing.vehicle.axles] if @listing.vehicle.axles.present?
                specific_fields << ["Cabine couchette", @listing.vehicle.sleeping_cab ? "Oui" : "Non"] if @listing.vehicle.sleeping_cab.present?
                specific_fields << ["Norme d'émission", @listing.vehicle.emission_standard] if @listing.vehicle.emission_standard.present?
              end
              %>
              
              <% if specific_fields.any? %>
                <div class="mt-8">
                  <h3 class="text-lg font-medium mb-4">Caractéristiques spécifiques - <%= @listing.vehicle.category.name %></h3>
                  
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <% specific_fields.each do |label, value| %>
                      <div class="flex justify-between">
                        <span class="font-medium"><%= label %>:</span>
                        <span><%= value %></span>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Sidebar with Price and Contact Info -->
    <div class="col-span-1">
      <div class="card bg-base-100 shadow-sm sticky top-4">
        <div class="card-body">
          <h3 class="card-title text-2xl text-primary mb-4">
            <%= number_to_currency(@listing.vehicle.price, unit: "€", precision: 0) %>
          </h3>
          
          <div class="flex items-center gap-2 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span>Vendu par: <%= @listing.user.email %></span>
          </div>
          
          <div class="flex items-center gap-2 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span>Publiée le: <%= @listing.created_at.strftime("%d/%m/%Y") %></span>
          </div>
          
          <div class="divider"></div>
          
          <% if user_signed_in? %>
            <% if current_user == @listing.user %>
              <div class="space-y-2">
                <%= link_to "Modifier l'annonce", edit_listing_path(@listing), class: "btn btn-outline btn-primary w-full" %>
                <%= button_to "Supprimer l'annonce", @listing, method: :delete, class: "btn btn-outline btn-error w-full", form: { data: { turbo_confirm: "Êtes-vous sûr de vouloir supprimer cette annonce?" } } %>
              </div>
            <% else %>
              <a href="mailto:<%= @listing.user.email %>" class="btn btn-primary w-full">Contacter le vendeur</a>
            <% end %>
          <% else %>
            <div class="alert alert-info shadow-sm">
              <div>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span><%= link_to "Connectez-vous", new_user_session_path, class: "link link-hover font-medium" %> pour contacter le vendeur.</span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('turbo:load', function() {
    initializeTabs();
    initializeMediaGallery();
  });
  
  document.addEventListener('DOMContentLoaded', function() {
    initializeTabs();
    initializeMediaGallery();
  });
  
  function initializeTabs() {
    const tabs = document.querySelectorAll('.tabs-boxed .tab');
    
    if (tabs.length) {
      tabs.forEach(tab => {
        tab.addEventListener('click', function() {
          // Désactiver tous les onglets
          tabs.forEach(t => t.classList.remove('tab-active'));
          
          // Activer l'onglet cliqué
          this.classList.add('tab-active');
          
          // Masquer tous les contenus d'onglets
          const tabContents = document.querySelectorAll('.tab-content');
          tabContents.forEach(content => {
            content.classList.add('hidden');
          });
          
          // Afficher le contenu d'onglet correspondant
          const target = this.getAttribute('data-target');
          const targetContent = document.getElementById(target);
          if (targetContent) {
            targetContent.classList.remove('hidden');
          }
        });
      });
    }
    
    // Initialiser le carrousel des photos
    if (document.getElementById('listingCarousel')) {
      const thumbnails = document.querySelectorAll('[data-bs-slide-to]');
      thumbnails.forEach(thumbnail => {
        thumbnail.addEventListener('click', function(e) {
          e.preventDefault();
          const index = this.getAttribute('data-bs-slide-to');
          const carousel = document.getElementById('listingCarousel');
          
          // Masquer tous les éléments du carrousel
          const carouselItems = carousel.querySelectorAll('.carousel-item');
          carouselItems.forEach(item => {
            item.classList.remove('active');
          });
          
          // Afficher l'élément correspondant à l'index
          if (carouselItems[index]) {
            carouselItems[index].classList.add('active');
          }
        });
      });
      
      // Gérer les boutons précédent/suivant
      const prevButton = document.querySelector('.carousel-control-prev');
      const nextButton = document.querySelector('.carousel-control-next');
      
      if (prevButton && nextButton) {
        prevButton.addEventListener('click', function() {
          navigateCarousel(-1);
        });
        
        nextButton.addEventListener('click', function() {
          navigateCarousel(1);
        });
      }
      
      function navigateCarousel(direction) {
        const carouselItems = document.querySelectorAll('#listingCarousel .carousel-item');
        let activeIndex = -1;
        
        carouselItems.forEach((item, index) => {
          if (item.classList.contains('active')) {
            activeIndex = index;
          }
        });
        
        if (activeIndex !== -1) {
          carouselItems[activeIndex].classList.remove('active');
          
          let newIndex = activeIndex + direction;
          if (newIndex < 0) newIndex = carouselItems.length - 1;
          if (newIndex >= carouselItems.length) newIndex = 0;
          
          carouselItems[newIndex].classList.add('active');
        }
      }
    }
  }
  
  function initializeMediaGallery() {
    const thumbnails = document.querySelectorAll('.carousel-thumbnail');
    
    thumbnails.forEach(thumb => {
      thumb.addEventListener('click', function() {
        const targetId = this.dataset.target;
        
        // Hide all carousel items
        document.querySelectorAll('.carousel-item').forEach(item => {
          item.classList.add('hidden');
          item.classList.remove('active');
        });
        
        // Show the target item
        const target = document.getElementById(targetId);
        if (target) {
          target.classList.remove('hidden');
          target.classList.add('active');
        }
      });
    });
  }
</script>
