<% content_for(:title) { "#{@listing.title} — Vera Trade" } %>
<% content_for(:description) { "#{@vehicle&.make} #{@vehicle&.model} #{@vehicle&.year} — #{number_to_currency(@vehicle&.price, unit: '€', format: '%n %u', delimiter: ' ', precision: 0)} — #{@vehicle&.location}" } %>

<div class="container mx-auto px-4 py-8 max-w-6xl">
  <!-- Breadcrumb -->
  <div class="text-sm breadcrumbs mb-6">
    <ul>
      <li><%= link_to "Annonces", listings_path %></li>
      <li><%= @vehicle&.make %></li>
      <li class="opacity-60"><%= @listing.title.truncate(40) %></li>
    </ul>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Colonne principale -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Photos -->
      <div class="rounded-xl overflow-hidden bg-base-300">
        <% if @listing.photos.attached? %>
          <div class="aspect-video">
            <%= image_tag @listing.photos.first, class: "w-full h-full object-cover", alt: @listing.title, id: "main-photo" %>
          </div>
          <% if @listing.photos.count > 1 %>
            <div class="flex gap-2 p-3 overflow-x-auto">
              <% @listing.photos.each_with_index do |photo, i| %>
                <%= image_tag photo, class: "w-20 h-14 object-cover rounded cursor-pointer hover:opacity-80 transition-opacity #{'ring-2 ring-primary' if i == 0}", alt: "Photo #{i + 1}" %>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="aspect-video flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20 opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          </div>
        <% end %>
      </div>

      <!-- Titre + prix mobile -->
      <div class="lg:hidden">
        <h1 class="text-2xl font-bold mb-2"><%= @listing.title %></h1>
        <p class="text-3xl font-bold text-primary"><%= number_to_currency(@vehicle&.price, unit: "€", format: "%n %u", delimiter: " ", precision: 0) %></p>
      </div>

      <!-- Specs principales -->
      <div class="card bg-base-100 shadow">
        <div class="card-body p-5">
          <h2 class="card-title text-base mb-4">Caractéristiques</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <% specs = [
              ["Marque", @vehicle&.make],
              ["Modèle", @vehicle&.model],
              ["Année", @vehicle&.year],
              ["Kilométrage", @vehicle&.kilometers ? "#{number_with_delimiter(@vehicle.kilometers)} km" : nil],
              ["Carburant", @vehicle&.fuel_type],
              ["Transmission", @vehicle&.transmission],
              ["Finition", @vehicle&.finition],
              ["Portes", @vehicle&.doors],
              ["Couleur ext.", @vehicle&.exterior_color],
              ["Intérieur", @vehicle&.interior_material],
              ["Couleur int.", @vehicle&.interior_color],
              ["Propriétaires", @vehicle&.previous_owners],
              ["Puissance fiscale", @vehicle&.fiscal_power ? "#{@vehicle.fiscal_power} CV" : nil],
              ["CO2", @vehicle&.co2_emissions ? "#{@vehicle.co2_emissions} g/km" : nil],
              ["Consommation", @vehicle&.average_consumption ? "#{@vehicle.average_consumption} L/100km" : nil],
              ["Localisation", @vehicle&.location],
            ] %>
            <% specs.each do |label, value| %>
              <% next unless value.present? %>
              <div>
                <p class="text-xs opacity-50 uppercase tracking-wide"><%= label %></p>
                <p class="font-medium text-sm"><%= value %></p>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- État du véhicule -->
      <% conditions = [
        ["Carrosserie", @vehicle&.body_condition],
        ["Intérieur", @vehicle&.interior_condition],
        ["Pneus", @vehicle&.tire_condition],
        ["Travaux récents", @vehicle&.recent_works],
        ["Points à prévoir", @vehicle&.issues],
        ["Coûts estimés", @vehicle&.expected_costs],
      ].select { |_, v| v.present? } %>
      <% if conditions.any? %>
        <div class="card bg-base-100 shadow">
          <div class="card-body p-5">
            <h2 class="card-title text-base mb-4">État du véhicule</h2>
            <div class="space-y-3">
              <% conditions.each do |label, value| %>
                <div>
                  <p class="text-xs opacity-50 uppercase tracking-wide mb-1"><%= label %></p>
                  <p class="text-sm"><%= value %></p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Équipements -->
      <% features = [
        ["Sécurité", @vehicle&.safety_features],
        ["Confort", @vehicle&.comfort_features],
        ["Multimédia", @vehicle&.multimedia_features],
        ["Extérieur", @vehicle&.exterior_features],
        ["Autres", @vehicle&.other_features],
      ].select { |_, v| v.present? } %>
      <% if features.any? %>
        <div class="card bg-base-100 shadow">
          <div class="card-body p-5">
            <h2 class="card-title text-base mb-4">Équipements</h2>
            <% features.each do |label, value| %>
              <div class="mb-3">
                <p class="text-xs opacity-50 uppercase tracking-wide mb-1"><%= label %></p>
                <div class="flex flex-wrap gap-1.5">
                  <% value.split(",").map(&:strip).each do |item| %>
                    <span class="badge badge-sm badge-ghost"><%= item %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Description -->
      <% if @listing.description.present? %>
        <div class="card bg-base-100 shadow">
          <div class="card-body p-5">
            <h2 class="card-title text-base mb-3">Description</h2>
            <p class="text-sm leading-relaxed opacity-80"><%= simple_format(@listing.description) %></p>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Prix + actions (desktop) -->
      <div class="card bg-base-100 shadow sticky top-20">
        <div class="card-body p-5">
          <h1 class="text-xl font-bold mb-1 hidden lg:block"><%= @listing.title %></h1>
          <p class="text-3xl font-bold text-primary mb-4"><%= number_to_currency(@vehicle&.price, unit: "€", format: "%n %u", delimiter: " ", precision: 0) %></p>

          <div class="flex flex-wrap gap-2 mb-4">
            <% if @vehicle&.year %><span class="badge"><%= @vehicle.year %></span><% end %>
            <% if @vehicle&.kilometers %><span class="badge"><%= number_with_delimiter(@vehicle.kilometers) %> km</span><% end %>
            <% if @vehicle&.fuel_type.present? %><span class="badge"><%= @vehicle.fuel_type %></span><% end %>
          </div>

          <!-- Actions -->
          <div class="space-y-2">
            <% if user_signed_in? && @listing.user != current_user %>
              <%= link_to conversation_path(@listing.user), class: "btn btn-primary w-full" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                Contacter le vendeur
              <% end %>

              <% if @is_favorited %>
                <%= button_to listing_favorite_path(@listing), method: :delete, class: "btn btn-outline btn-error w-full" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" /></svg>
                  Retirer des favoris
                <% end %>
              <% else %>
                <%= button_to listing_favorite_path(@listing), class: "btn btn-outline w-full" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
                  Ajouter aux favoris
                <% end %>
              <% end %>
            <% elsif !user_signed_in? %>
              <%= link_to new_user_session_path, class: "btn btn-primary w-full" do %>
                Connectez-vous pour contacter
              <% end %>
            <% else %>
              <%= link_to edit_listing_path(@listing), class: "btn btn-outline w-full" do %>
                Modifier mon annonce
              <% end %>
            <% end %>
          </div>

          <!-- Stats -->
          <div class="divider my-3"></div>
          <div class="flex justify-between text-xs opacity-50">
            <span><%= @listing.views_count %> vues</span>
            <span>Publiée <%= time_ago_in_words(@listing.created_at) %></span>
          </div>
        </div>
      </div>

      <!-- Vendeur -->
      <div class="card bg-base-100 shadow">
        <div class="card-body p-5">
          <h3 class="text-sm font-bold mb-3">Vendeur</h3>
          <div class="flex items-center gap-3">
            <div class="avatar placeholder">
              <div class="bg-primary/20 text-primary rounded-full w-10">
                <span class="font-bold"><%= @seller.display_name.first.upcase %></span>
              </div>
            </div>
            <div>
              <p class="font-medium text-sm"><%= @seller.display_name %></p>
              <p class="text-xs opacity-50">Membre depuis <%= @seller.created_at.strftime("%B %Y") %></p>
            </div>
          </div>
          <% if @seller.listings.where(status: "active").count > 1 %>
            <p class="text-xs opacity-50 mt-2"><%= @seller.listings.where(status: "active").count %> annonces en ligne</p>
          <% end %>
        </div>
      </div>

      <!-- Infos légales -->
      <div class="card bg-base-100 shadow">
        <div class="card-body p-5">
          <h3 class="text-sm font-bold mb-3">Informations</h3>
          <div class="space-y-2 text-xs opacity-60">
            <% if @vehicle&.vin.present? %><p>VIN : <%= @vehicle.vin %></p><% end %>
            <% if @vehicle&.license_plate.present? %><p>Immatriculation : <%= @vehicle.license_plate %></p><% end %>
            <% if @vehicle&.has_service_history %><p>Carnet d'entretien disponible</p><% end %>
            <% if @vehicle&.non_smoker %><p>Véhicule non-fumeur</p><% end %>
            <% if @vehicle&.ct_expiry_date %><p>CT valide jusqu'au <%= @vehicle.ct_expiry_date.strftime("%d/%m/%Y") %></p><% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Autres annonces du vendeur -->
  <% if @other_listings.any? %>
    <div class="mt-12">
      <h2 class="text-xl font-bold mb-6">Autres annonces de <%= @seller.display_name %></h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <% @other_listings.each do |listing| %>
          <% v = listing.vehicle %>
          <%= link_to listing, class: "card bg-base-100 shadow card-lift cursor-pointer group overflow-hidden" do %>
            <figure class="h-40 overflow-hidden">
              <% if listing.photos.attached? %>
                <%= image_tag listing.photos.first, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", alt: listing.title %>
              <% else %>
                <div class="w-full h-full bg-base-300 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                </div>
              <% end %>
            </figure>
            <div class="card-body p-4">
              <h3 class="text-sm font-bold line-clamp-1"><%= listing.title %></h3>
              <p class="text-primary font-bold"><%= number_to_currency(v&.price, unit: "€", format: "%n %u", delimiter: " ", precision: 0) %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
