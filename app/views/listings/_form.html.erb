<script>
document.addEventListener('DOMContentLoaded', function() {
  // Gestion des onglets
  const tabs = document.querySelectorAll('.tab');
  const sections = document.querySelectorAll('.section-content');
  
  // Afficher la première section par défaut
  document.getElementById('infos-section').classList.remove('hidden');
  
  // Gérer les clics sur les onglets
  tabs.forEach(tab => {
    tab.addEventListener('click', function() {
      // Mettre à jour les onglets
      tabs.forEach(t => t.classList.remove('tab-active'));
      this.classList.add('tab-active');
      
      // Mettre à jour les sections
      const targetId = this.getAttribute('data-target');
      sections.forEach(section => {
        if (section.id === targetId) {
          section.classList.remove('hidden');
        } else {
          section.classList.add('hidden');
        }
      });
    });
  });

  // Gestion des cases à cocher avec animation
  document.querySelectorAll('input[type="checkbox"][data-feature]').forEach(checkbox => {
    checkbox.addEventListener('change', function() {
      const featureType = this.getAttribute('data-feature');
      const featureValue = this.value;
      let textareaId;
      
      switch(featureType) {
        case 'safety':
          textareaId = 'vehicle_safety_features';
          break;
        case 'comfort':
          textareaId = 'vehicle_comfort_features';
          break;
        case 'multimedia':
          textareaId = 'vehicle_multimedia_features';
          break;
        case 'exterior':
          textareaId = 'vehicle_exterior_features';
          break;
        case 'other':
          textareaId = 'vehicle_other_features';
          break;
      }
      
      const textarea = document.getElementById(textareaId);
      if (textarea) {
        let features = textarea.value ? textarea.value.split('\n').filter(f => f.trim() !== '') : [];
        
        if (this.checked) {
          if (!features.includes(featureValue)) {
            features.push(featureValue);
            this.closest('.label').classList.add('bg-primary', 'bg-opacity-10');
            setTimeout(() => {
              this.closest('.label').classList.remove('bg-primary', 'bg-opacity-10');
            }, 500);
          }
        } else {
          features = features.filter(f => f !== featureValue);
          this.closest('.label').classList.add('bg-error', 'bg-opacity-10');
          setTimeout(() => {
            this.closest('.label').classList.remove('bg-error', 'bg-opacity-10');
          }, 500);
        }
        
        textarea.value = features.join('\n');
      }
    });
  });

  // Gestion des aperçus de fichiers
  function handleFileSelect(event, previewId) {
    const files = event.target.files;
    const preview = document.getElementById(previewId);
    if (!preview) return;
    
    preview.innerHTML = '';

    for (let i = 0; i < files.length; i++) {
      const file = files[i];
      const reader = new FileReader();

      reader.onload = function(e) {
        const div = document.createElement('div');
        div.className = 'relative group';
        
        if (file.type.startsWith('image/')) {
          const img = document.createElement('img');
          img.src = e.target.result;
          img.className = 'w-full h-32 object-cover rounded-lg';
          div.appendChild(img);
        } else if (file.type.startsWith('video/')) {
          const video = document.createElement('video');
          video.src = e.target.result;
          video.className = 'w-full h-32 object-cover rounded-lg';
          video.controls = true;
          div.appendChild(video);
        } else {
          const icon = document.createElement('div');
          icon.className = 'w-full h-32 flex items-center justify-center bg-base-300 rounded-lg';
          icon.innerHTML = `
            <svg class="w-12 h-12 text-neutral-content" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
            </svg>
          `;
          div.appendChild(icon);
        }

        const overlay = document.createElement('div');
        overlay.className = 'absolute inset-0 bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 transition-opacity duration-200 rounded-lg flex items-center justify-center text-white';
        overlay.innerHTML = `
          <div class="text-center">
            <div class="badge badge-accent">${file.name.split('.').pop()}</div>
            <p class="text-xs mt-1">${(file.size / 1024).toFixed(0)} KB</p>
          </div>
        `;
        
        div.appendChild(overlay);
        preview.appendChild(div);
      };

      reader.readAsDataURL(file);
    }
  }

  // Ajouter les écouteurs d'événements pour les aperçus de fichiers
  document.querySelectorAll('input[type="file"]').forEach(input => {
    input.addEventListener('change', function(e) {
      const previewId = this.closest('.form-control').querySelector('div[id$="-preview"]')?.id;
      if (previewId) {
        handleFileSelect(e, previewId);
      }
    });
  });

  // Fonction pour naviguer vers la section suivante
  window.navigateToNextSection = function() {
    const sections = Array.from(document.querySelectorAll('.section-content'));
    const currentSection = sections.find(section => !section.classList.contains('hidden'));
    const currentIndex = sections.indexOf(currentSection);
    
    if (currentIndex < sections.length - 1) {
      // Passer à la section suivante
      const nextSection = sections[currentIndex + 1];
      const nextTab = document.querySelector(`[data-target="${nextSection.id}"]`);
      
      // Mettre à jour les onglets
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('tab-active'));
      nextTab.classList.add('tab-active');
      
      // Mettre à jour les sections
      sections.forEach(section => {
        if (section.id === nextSection.id) {
          section.classList.remove('hidden');
        } else {
          section.classList.add('hidden');
        }
      });
    } else {
      // Si c'est la dernière section, soumettre le formulaire
      document.querySelector('form').submit();
    }
  };
});

function addMediaFolder() {
  const template = document.getElementById('media-folder-template');
  const container = document.getElementById('media-folders');
  const clone = template.content.cloneNode(true);
  container.insertBefore(clone, template);
}
</script>

