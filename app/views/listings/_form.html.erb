<%= form_with(model: listing, local: true, class: "space-y-6") do |f| %>
  <% if listing.errors.any? %>
    <div class="alert alert-error">
      <h2><%= pluralize(listing.errors.count, "erreur") %> ont empêché l'enregistrement de cette annonce :</h2>
      <ul>
        <% listing.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Onglets pour les différentes sections du formulaire -->
  <div class="tabs tabs-boxed mb-6 bg-base-200">
    <a class="tab tab-active" data-target="infos-section">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      Informations
    </a>
    <a class="tab" data-target="vehicle-section">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
      </svg>
      Véhicule
    </a>
    <a class="tab" data-target="vehicle-details-section">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
      </svg>
      Détails
    </a>
    <a class="tab" data-target="vehicle-features-section">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
      Équipements
    </a>
    <a class="tab" data-target="vehicle-condition-section">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      État
    </a>
    <a class="tab" data-target="media-section">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
      </svg>
      Médias
    </a>
  </div>

  <!-- Section Informations de l'annonce -->
  <div id="infos-section" class="section-content">
    <h2 class="text-xl font-semibold mb-4 flex items-center">
      <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
      </svg>
      Informations de l'annonce
    </h2>
    
    <div class="form-control w-full mb-4">
      <%= f.label :title, class: "label flex items-center" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
        </svg>
        Titre de l'annonce
      <% end %>
      <%= f.text_field :title, class: "input input-bordered w-full", placeholder: "Ex: BMW Série 3 320d M Sport 2019" %>
    </div>

    <div class="form-control w-full">
      <%= f.label :description, class: "label flex items-center" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
        </svg>
        Description
      <% end %>
      <%= f.text_area :description, class: "textarea textarea-bordered h-24", placeholder: "Décrivez votre véhicule en détail..." %>
    </div>
  </div>

  <!-- Section Détails du véhicule -->
  <div id="vehicle-section" class="section-content hidden">
    <h2 class="text-xl font-semibold mb-4 flex items-center">
      <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"></path>
      </svg>
      Détails du véhicule
    </h2>
    
    <%= fields_for :vehicle do |v| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div class="form-control w-full">
          <%= v.label :license_plate, class: "label flex items-center" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
            Immatriculation
          <% end %>
          <%= v.text_field :license_plate, 
              class: "input input-bordered w-full", 
              placeholder: "Ex: AA-123-AA",
              data: { 
                controller: "vehicle-info",
                action: "input->vehicle-info#validateLicensePlate blur->vehicle-info#fetchInfo",
                vehicle_info_target: "licensePlate"
              } %>
          <div class="text-sm text-error hidden" data-vehicle-info-target="licensePlateError"></div>
        </div>
        
        <div class="form-control w-full">
          <%= v.label :vin, class: "label flex items-center" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
            Numéro de série (VIN)
          <% end %>
          <%= v.text_field :vin, 
              class: "input input-bordered w-full", 
              placeholder: "Ex: WVWZZZ1KZAW123456",
              data: { 
                controller: "vehicle-info",
                action: "input->vehicle-info#validateVin blur->vehicle-info#fetchInfo",
                vehicle_info_target: "vin"
              } %>
          <div class="text-sm text-error hidden" data-vehicle-info-target="vinError"></div>
        </div>
      </div>

