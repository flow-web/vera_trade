  // Fonctions pour la gestion des médias
  function initializeMediaUploads() {
    const mainMediaInput = document.getElementById('main-media-input');
    const mainMediaQueue = document.getElementById('main-media-queue');
    const newMediaForm = document.getElementById('new-media-form');
    const mediaFileInput = document.getElementById('media-file-input');
    const uploadedMediaContainer = document.getElementById('uploaded-media-container');
    const uploadedMediaList = document.getElementById('uploaded-media-list');
    
    if (!mainMediaInput || !mainMediaQueue) return;
    
    // Fonction pour prévisualiser les fichiers sélectionnés
    mainMediaInput.addEventListener('change', function() {
      mainMediaQueue.innerHTML = '';
      
      if (this.files && this.files.length > 0) {
        if (this.files.length > 10) {
          alert('Vous ne pouvez pas sélectionner plus de 10 fichiers.');
          this.value = '';
          return;
        }
        
        [...this.files].forEach(file => {
          const fileDiv = document.createElement('div');
          fileDiv.className = 'relative group bg-base-200 p-2 rounded-lg';
          
          const fileContent = document.createElement('div');
          fileContent.className = 'flex flex-col';
          
          // Prévisualisation du fichier (image ou icône)
          const preview = document.createElement('div');
          preview.className = 'h-32 flex items-center justify-center mb-2';
          
          if (file.type.startsWith('image/')) {
            const img = document.createElement('img');
            img.className = 'max-h-full max-w-full object-contain';
            
            const reader = new FileReader();
            reader.onload = function(e) {
              img.src = e.target.result;
            };
            reader.readAsDataURL(file);
            
            preview.appendChild(img);
          } else if (file.type.startsWith('video/')) {
            const videoIcon = document.createElement('div');
            videoIcon.className = 'text-primary text-4xl flex flex-col items-center';
            videoIcon.innerHTML = '<i class="bi bi-film"></i><span class="text-xs mt-1">Vidéo</span>';
            preview.appendChild(videoIcon);
          } else if (file.type === 'application/pdf') {
            const pdfIcon = document.createElement('div');
            pdfIcon.className = 'text-error text-4xl flex flex-col items-center';
            pdfIcon.innerHTML = '<i class="bi bi-file-earmark-pdf"></i><span class="text-xs mt-1">PDF</span>';
            preview.appendChild(pdfIcon);
          } else {
            const fileIcon = document.createElement('div');
            fileIcon.className = 'text-neutral text-4xl flex flex-col items-center';
            fileIcon.innerHTML = '<i class="bi bi-file-earmark"></i><span class="text-xs mt-1">Fichier</span>';
            preview.appendChild(fileIcon);
          }
          
          fileContent.appendChild(preview);
          
          // Informations du fichier
          const fileInfo = document.createElement('div');
          fileInfo.className = 'text-xs';
          fileInfo.innerHTML = `
            <p class="truncate font-medium">${file.name}</p>
            <p class="text-neutral-content">${(file.size / 1024 / 1024).toFixed(2)} MB</p>
          `;
          fileContent.appendChild(fileInfo);
          
          // Formulaire pour ajouter du contexte
          const contextForm = document.createElement('div');
          contextForm.className = 'mt-2';
          
          const contextSelect = document.createElement('select');
          contextSelect.className = 'select select-bordered select-sm w-full max-w-xs';
          contextSelect.innerHTML = `
            <option value="">Sélectionner un contexte</option>
            ${MediaItem.CONTEXTS.map(context => `<option value="${context}">${context}</option>`).join('')}
          `;
          contextForm.appendChild(contextSelect);
          
          fileContent.appendChild(contextForm);
          
          // Bouton d'upload
          const uploadButton = document.createElement('button');
          uploadButton.className = 'btn btn-primary btn-sm w-full mt-2';
          uploadButton.textContent = 'Uploader';
          uploadButton.addEventListener('click', function() {
            const context = contextSelect.value;
            uploadFile(file, context);
          });
          
          fileContent.appendChild(uploadButton);
          
          fileDiv.appendChild(fileContent);
          mainMediaQueue.appendChild(fileDiv);
        });
      }
    });
    
    // Fonction pour uploader un fichier
    function uploadFile(file, context) {
      const formData = new FormData();
      formData.append('media_item[media]', file);
      formData.append('media_item[title]', file.name.split('.')[0]);
      formData.append('media_item[context]', context || '');
      formData.append('media_item[private]', 'false');
      
      // Afficher une barre de progression
      const progressBar = document.createElement('progress');
      progressBar.className = 'progress progress-primary w-full';
      progressBar.max = 100;
      progressBar.value = 0;
      
      const fileDiv = event.target.closest('.relative');
      fileDiv.appendChild(progressBar);
      
      fetch('/listings/<%= @listing.id %>/media_items', {
        method: 'POST',
        body: formData,
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Afficher le média uploadé
          displayUploadedMedia(data.media_item);
          
          // Supprimer le fichier de la queue
          fileDiv.remove();
          
          // Montrer la section des médias uploadés si elle était cachée
          uploadedMediaList.classList.remove('hidden');
        } else {
          alert('Erreur lors de l\'upload: ' + data.errors.join(', '));
          progressBar.classList.add('progress-error');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Erreur lors de l\'upload');
        progressBar.classList.add('progress-error');
      });
    }
    
    // Fonction pour afficher un média uploadé
    function displayUploadedMedia(mediaItem) {
      const mediaDiv = document.createElement('div');
      mediaDiv.className = 'relative group';
      mediaDiv.dataset.mediaId = mediaItem.id;
      
      let mediaContent;
      
      if (mediaItem.content_type === 'image') {
        mediaContent = `
          <img src="${mediaItem.media.url}" class="w-full h-32 object-cover rounded-lg" alt="${mediaItem.title}">
          <div class="absolute inset-0 bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 transition-opacity duration-200 rounded-lg flex items-center justify-center text-white">
            <div class="text-center">
              <div class="badge badge-primary">${mediaItem.context || 'Sans contexte'}</div>
              <p class="text-xs mt-1">${mediaItem.title}</p>
            </div>
          </div>
        `;
      } else if (mediaItem.content_type === 'video') {
        mediaContent = `
          <div class="w-full h-32 bg-base-200 rounded-lg flex items-center justify-center relative">
            <i class="bi bi-film text-4xl text-primary"></i>
            <div class="absolute bottom-1 right-1">
              <div class="badge badge-primary">${mediaItem.context || 'Sans contexte'}</div>
            </div>
          </div>
        `;
      } else {
        mediaContent = `
          <div class="w-full h-32 bg-base-200 rounded-lg flex items-center justify-center relative">
            <i class="bi bi-file-earmark text-4xl text-neutral"></i>
            <div class="absolute bottom-1 right-1">
              <div class="badge badge-primary">${mediaItem.context || 'Sans contexte'}</div>
            </div>
          </div>
        `;
      }
      
      mediaDiv.innerHTML = mediaContent;
      
      // Bouton de suppression
      const deleteButton = document.createElement('button');
      deleteButton.className = 'btn btn-error btn-xs absolute top-1 right-1 opacity-0 group-hover:opacity-100';
      deleteButton.innerHTML = '<i class="bi bi-trash"></i>';
      deleteButton.addEventListener('click', function() {
        if (confirm('Êtes-vous sûr de vouloir supprimer ce média ?')) {
          deleteMedia(mediaItem.id);
        }
      });
      
      mediaDiv.appendChild(deleteButton);
      uploadedMediaContainer.appendChild(mediaDiv);
    }
    
    // Fonction pour supprimer un média
    function deleteMedia(mediaId) {
      fetch(`/media_items/${mediaId}`, {
        method: 'DELETE',
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'Content-Type': 'application/json'
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Supprimer le média de l'affichage
          const mediaDiv = document.querySelector(`[data-media-id="${mediaId}"]`);
          if (mediaDiv) {
            mediaDiv.remove();
          }
          
          // Cacher la section si elle est vide
          if (uploadedMediaContainer.children.length === 0) {
            uploadedMediaList.classList.add('hidden');
          }
        } else {
          alert('Erreur lors de la suppression');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Erreur lors de la suppression');
      });
    }
  }
  
  function initializeFolderCreation() {
    const folderCards = document.querySelectorAll('[data-folder-type]');
    const folderCreationForm = document.getElementById('folder-creation-form');
    const folderTypeLabel = document.getElementById('folder-type-label');
    const folderIcon = document.getElementById('folder-icon');
    const cancelFolderBtn = document.getElementById('cancel-folder-btn');
    const folderMediaInput = document.getElementById('folder-media-input');
    const folderMediaPreview = document.getElementById('folder-media-preview');
    const newFolderForm = document.getElementById('new-folder-form');
    const createdFoldersContainer = document.getElementById('created-folders-container');
    const createdFoldersList = document.getElementById('created-folders-list');
    
    if (!folderCards.length || !folderCreationForm) return;
    
    // Événement de clic sur un type de dossier
    folderCards.forEach(card => {
      card.addEventListener('click', function() {
        const folderType = this.dataset.folderType;
        folderTypeLabel.textContent = folderType;
        
        // Mettre à jour l'icône
        let iconClass = 'bi-folder';
        switch (folderType) {
          case "Carnet d'entretien":
            iconClass = 'bi-journal-check';
            break;
          case "Factures & achats":
            iconClass = 'bi-receipt';
            break;
          case "Restaurations / Réparations":
            iconClass = 'bi-tools';
            break;
          case "Certificats & documents":
            iconClass = 'bi-file-earmark-text';
            break;
          case "Contrôle technique":
            iconClass = 'bi-clipboard-check';
            break;
          case "Carte grise":
            iconClass = 'bi-card-text';
            break;
        }
        
        folderIcon.innerHTML = `<i class="bi ${iconClass} text-lg"></i>`;
        
        // Préremplir le nom du dossier
        document.getElementById('media_folder_name').value = folderType;
        
        // Afficher le formulaire
        folderCreationForm.classList.remove('hidden');
        
        // Vider les aperçus
        folderMediaPreview.innerHTML = '';
        folderMediaPreview.classList.add('hidden');
        folderMediaInput.value = '';
      });
    });
    
    // Événement d'annulation
    if (cancelFolderBtn) {
      cancelFolderBtn.addEventListener('click', function() {
        folderCreationForm.classList.add('hidden');
      });
    }
    
    // Gestion de la prévisualisation des fichiers du dossier
    if (folderMediaInput) {
      folderMediaInput.addEventListener('change', function() {
        folderMediaPreview.innerHTML = '';
        
        if (this.files && this.files.length > 0) {
          folderMediaPreview.classList.remove('hidden');
          
          [...this.files].forEach(file => {
            const fileDiv = document.createElement('div');
            fileDiv.className = 'bg-base-200 p-2 rounded-lg';
            
            let fileContent;
            
            if (file.type.startsWith('image/')) {
              fileContent = document.createElement('img');
              fileContent.className = 'w-full h-20 object-cover rounded-lg mb-1';
              
              const reader = new FileReader();
              reader.onload = function(e) {
                fileContent.src = e.target.result;
              };
              reader.readAsDataURL(file);
            } else if (file.type.startsWith('video/')) {
              fileContent = document.createElement('div');
              fileContent.className = 'w-full h-20 bg-base-200 rounded-lg flex items-center justify-center mb-1';
              fileContent.innerHTML = '<i class="bi bi-film text-3xl text-primary"></i>';
            } else if (file.type === 'application/pdf') {
              fileContent = document.createElement('div');
              fileContent.className = 'w-full h-20 bg-base-200 rounded-lg flex items-center justify-center mb-1';
              fileContent.innerHTML = '<i class="bi bi-file-earmark-pdf text-3xl text-error"></i>';
            } else {
              fileContent = document.createElement('div');
              fileContent.className = 'w-full h-20 bg-base-200 rounded-lg flex items-center justify-center mb-1';
              fileContent.innerHTML = '<i class="bi bi-file-earmark text-3xl text-neutral"></i>';
            }
            
            fileDiv.appendChild(fileContent);
            
            const fileInfo = document.createElement('div');
            fileInfo.className = 'text-xs';
            fileInfo.innerHTML = `
              <p class="truncate">${file.name}</p>
              <p class="text-neutral-content">${(file.size / 1024 / 1024).toFixed(2)} MB</p>
            `;
            
            fileDiv.appendChild(fileInfo);
            folderMediaPreview.appendChild(fileDiv);
          });
        } else {
          folderMediaPreview.classList.add('hidden');
        }
      });
    }
    
    // Soumission du formulaire de création de dossier
    if (newFolderForm) {
      newFolderForm.addEventListener('submit', function(event) {
        event.preventDefault();
        
        const formData = new FormData(newFolderForm);
        
        // Ajouter les fichiers sélectionnés
        if (folderMediaInput.files.length > 0) {
          [...folderMediaInput.files].forEach((file, index) => {
            formData.append(`media_folder[media_items_attributes][${index}][media]`, file);
            formData.append(`media_folder[media_items_attributes][${index}][title]`, file.name.split('.')[0]);
            formData.append(`media_folder[media_items_attributes][${index}][context]`, 'Document');
            formData.append(`media_folder[media_items_attributes][${index}][private]`, 'true');
          });
        }
        
        fetch(newFolderForm.action, {
          method: 'POST',
          body: formData,
          headers: {
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
          }
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            // Afficher le dossier créé
            displayCreatedFolder(data.media_folder);
            
            // Masquer le formulaire
            folderCreationForm.classList.add('hidden');
            
            // Réinitialiser le formulaire
            newFolderForm.reset();
            folderMediaPreview.innerHTML = '';
            folderMediaPreview.classList.add('hidden');
            
            // Montrer la section des dossiers créés si elle était cachée
            createdFoldersList.classList.remove('hidden');
          } else {
            alert('Erreur lors de la création du dossier: ' + data.errors.join(', '));
          }
        })
        .catch(error => {
          console.error('Error:', error);
          alert('Erreur lors de la création du dossier');
        });
      });
    }
    
    // Fonction pour afficher un dossier créé
    function displayCreatedFolder(folder) {
      const folderDiv = document.createElement('div');
      folderDiv.className = 'card bg-base-200 p-4 mb-2';
      folderDiv.dataset.folderId = folder.id;
      
      // Déterminer l'icône
      let iconClass = 'bi-folder';
      switch (folder.name) {
        case "Carnet d'entretien":
          iconClass = 'bi-journal-check';
          break;
        case "Factures & achats":
          iconClass = 'bi-receipt';
          break;
        case "Restaurations / Réparations":
          iconClass = 'bi-tools';
          break;
        case "Certificats & documents":
          iconClass = 'bi-file-earmark-text';
          break;
        case "Contrôle technique":
          iconClass = 'bi-clipboard-check';
          break;
        case "Carte grise":
          iconClass = 'bi-card-text';
          break;
      }
      
      folderDiv.innerHTML = `
        <div class="flex justify-between items-center">
          <div class="flex items-center">
            <span class="text-primary mr-2"><i class="bi ${iconClass} text-lg"></i></span>
            <div>
              <h5 class="font-medium">${folder.name}</h5>
              <p class="text-xs text-neutral-content">${folder.description || 'Aucune description'}</p>
            </div>
          </div>
          <button class="btn btn-error btn-xs delete-folder-btn"><i class="bi bi-trash"></i></button>
        </div>
      `;
      
      // Ajouter l'événement de suppression
      folderDiv.querySelector('.delete-folder-btn').addEventListener('click', function() {
        if (confirm('Êtes-vous sûr de vouloir supprimer ce dossier et tous ses contenus ?')) {
          deleteFolder(folder.id);
        }
      });
      
      createdFoldersContainer.appendChild(folderDiv);
    }
    
    // Fonction pour supprimer un dossier
    function deleteFolder(folderId) {
      fetch(`/media_folders/${folderId}`, {
        method: 'DELETE',
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'Content-Type': 'application/json'
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Supprimer le dossier de l'affichage
          const folderDiv = document.querySelector(`[data-folder-id="${folderId}"]`);
          if (folderDiv) {
            folderDiv.remove();
          }
          
          // Cacher la section si elle est vide
          if (createdFoldersContainer.children.length === 0) {
            createdFoldersList.classList.add('hidden');
          }
        } else {
          alert('Erreur lors de la suppression du dossier');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Erreur lors de la suppression du dossier');
      });
    }
  }
</script>

<% content_for :head do %>
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Gestion des onglets et sections
  const tabs = document.querySelectorAll('.tab');
  const sections = document.querySelectorAll('.section-content');
  const progressBar = document.querySelector('.progress-bar');
  
  // Add step data attributes to tabs if they don't have them
  tabs.forEach((tab, index) => {
    if (!tab.hasAttribute('data-step')) {
      tab.setAttribute('data-step', index + 1);
    }
  });
  
  // Fonction pour mettre à jour la barre de progression
  function updateProgressBar(step) {
    const progress = (step / tabs.length) * 100;
    progressBar.style.width = `${progress}%`;
  }
  
  // Handle tab clicks
  tabs.forEach(tab => {
    tab.addEventListener('click', function() {
      const targetId = this.getAttribute('data-target');
      const step = parseInt(this.getAttribute('data-step'));
      
      // Masquer toutes les sections et désactiver tous les onglets
      sections.forEach(section => section.classList.add('hidden'));
      tabs.forEach(t => t.classList.remove('tab-active'));
      
      // Afficher la section cible et activer l'onglet
      document.getElementById(targetId).classList.remove('hidden');
      this.classList.add('tab-active');
      
      // Mettre à jour la barre de progression
      updateProgressBar(step);
    });
  });
  
  // Initialize progress bar
  const activeTab = document.querySelector('.tab.tab-active');
  if (activeTab) {
    const step = parseInt(activeTab.getAttribute('data-step')) || 1;
    updateProgressBar(step);
  }
  
  // Add next/previous buttons to sections
  sections.forEach((section, index) => {
    if (!section.querySelector('.section-navigation')) {
      const sectionId = section.getAttribute('id');
      const nav = document.createElement('div');
      nav.className = 'section-navigation flex justify-between mt-6';
      
      // Prev button (except for first section)
      if (index > 0) {
        const prevTab = tabs[index - 1];
        const prevTarget = prevTab.getAttribute('data-target');
        const prevBtn = document.createElement('button');
        prevBtn.type = 'button';
        prevBtn.className = 'btn btn-outline';
        prevBtn.innerHTML = '<i class="bi bi-arrow-left mr-2"></i> Retour';
        prevBtn.addEventListener('click', function() {
          document.querySelector(`.tab[data-target="${prevTarget}"]`).click();
        });
        nav.appendChild(prevBtn);
      } else {
        // Empty div for spacing
        const spacer = document.createElement('div');
        nav.appendChild(spacer);
      }
      
      // Next button (except for last section)
      if (index < sections.length - 1) {
        const nextTab = tabs[index + 1];
        const nextTarget = nextTab.getAttribute('data-target');
        const nextBtn = document.createElement('button');
        nextBtn.type = 'button';
        nextBtn.className = 'btn bg-[#B18B43] hover:bg-[#A0782D] text-white border-none';
        nextBtn.innerHTML = 'Continuer <i class="bi bi-arrow-right ml-2"></i>';
        nextBtn.addEventListener('click', function() {
          document.querySelector(`.tab[data-target="${nextTarget}"]`).click();
        });
        nav.appendChild(nextBtn);
      } else {
        // Submit button for last section
        const submitBtn = document.createElement('button');
        submitBtn.type = 'submit';
        submitBtn.className = 'btn bg-[#B18B43] hover:bg-[#A0782D] text-white border-none';
        submitBtn.textContent = 'Publier l\'annonce';
        nav.appendChild(submitBtn);
      }
      
      section.appendChild(nav);
    }
  });
});
</script>
<% end %>
