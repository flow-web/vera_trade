<div class="max-w-4xl mx-auto p-6">
  <div class="bg-base-100 shadow-lg rounded-lg overflow-hidden">
    <div class="bg-primary text-primary-content p-6">
      <h1 class="text-2xl font-bold">Publier une annonce de véhicule</h1>
      <p class="text-sm opacity-90 mt-1">Renseignez les informations de votre véhicule pour créer votre annonce</p>
    </div>

    <%= form_with(model: @listing, local: true, html: { multipart: true, class: "p-6" }) do |form| %>
      <% if @listing.errors.any? || @vehicle.errors.any? %>
        <div class="alert alert-error mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <div>
            <% if @listing.errors.any? %>
              <h4 class="font-bold"><%= pluralize(@listing.errors.count, "erreur") %> concernant l'annonce:</h4>
              <ul class="mt-1 list-disc list-inside">
                <% @listing.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            <% end %>
            
            <% if @vehicle.errors.any? %>
              <h4 class="font-bold mt-2"><%= pluralize(@vehicle.errors.count, "erreur") %> concernant le véhicule:</h4>
              <ul class="mt-1 list-disc list-inside">
                <% @vehicle.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Barre de progression -->
      <div class="w-full bg-gray-200 rounded-full h-2.5 mb-6">
        <div class="bg-[#B18B43] h-2.5 rounded-full progress-bar" style="width: 20%"></div>
      </div>

      <!-- Onglets pour les différentes sections du formulaire -->
      <div class="tabs tabs-boxed mb-6">
        <a class="tab tab-active" data-target="vehicle-section" data-step="1"><span class="badge bg-[#B18B43] text-white mr-2">1</span> Détails véhicule</a>
        <a class="tab" data-target="vehicle-features-section" data-step="2"><span class="badge bg-[#B18B43] text-white mr-2">2</span> Équipements</a>
        <a class="tab" data-target="vehicle-condition-section" data-step="3"><span class="badge bg-[#B18B43] text-white mr-2">3</span> État</a>
        <a class="tab" data-target="photos-section" data-step="4"><span class="badge bg-[#B18B43] text-white mr-2">4</span> Dossier multimédia</a>
        <a class="tab" data-target="infos-section" data-step="5"><span class="badge bg-[#B18B43] text-white mr-2">5</span> Informations générales</a>
      </div>

      <!-- Section 1: Détails du véhicule -->
      <div id="vehicle-section" class="section-content">
        <div class="border border-[#D9D9D9] rounded-lg p-5 mb-6">
          <h2 class="text-xl font-semibold mb-4 text-[#0C1E3B] flex items-center">
            <span class="inline-flex justify-center items-center w-8 h-8 bg-[#B18B43] text-white rounded-full mr-3">1</span>
            Détails du véhicule
          </h2>
          
          <%= fields_for :vehicle do |v| %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div class="form-control w-full">
                <%= v.label :category_id, "Catégorie de véhicule", class: "label" %>
                <%= v.select :category_id, 
                  Category.main_categories.order(:name).map { |c| [c.name, c.id] },
                  { include_blank: "Sélectionnez une catégorie" },
                  { class: "select select-bordered w-full", id: "vehicle_category_id" } 
                %>
              </div>
              
              <div class="form-control w-full">
                <%= v.label :subcategory, "Type de véhicule", class: "label" %>
                <%= v.select :subcategory, 
                  [],
                  { include_blank: "Sélectionnez d'abord une catégorie" },
                  { class: "select select-bordered w-full", id: "vehicle_subcategory", disabled: true } 
                %>
              </div>
            </div>
            
            <div id="custom-type-container" class="form-control w-full mb-4 hidden">
              <%= v.label :custom_type, "Précisez le type de véhicule", class: "label" %>
              <%= v.text_field :custom_type, class: "input input-bordered w-full", placeholder: "Ex: Véhicule spécifique" %>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div class="form-control w-full relative">
                <%= v.label :make, "Marque de votre véhicule", class: "label" %>
                <%= v.text_field :make, class: "input input-bordered w-full", placeholder: "Commencez à taper le nom d'une marque...", autocomplete: "off", id: "vehicle_make", list: "car-brands-list" %>
                <datalist id="car-brands-list">
                  <!-- Les marques automobiles vont ici, générées automatiquement par JavaScript -->
                </datalist>
              </div>
              
              <div class="form-control w-full">
                <%= v.label :model, "Modèle", class: "label" %>
                <%= v.text_field :model, class: "input input-bordered w-full", placeholder: "Ex: Serie 3" %>
              </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div class="form-control w-full">
                <%= v.label :year, "Année", class: "label" %>
                <%= v.number_field :year, class: "input input-bordered w-full", min: 1900, max: Time.current.year, placeholder: "Ex: 2020" %>
              </div>
              
              <div class="form-control w-full">
                <%= v.label :price, "Prix (€)", class: "label" %>
                <%= v.number_field :price, class: "input input-bordered w-full", min: 0, step: 100, placeholder: "Ex: 15000" %>
              </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div class="form-control w-full">
                <%= v.label :kilometers, "Kilométrage", class: "label" %>
                <%= v.number_field :kilometers, class: "input input-bordered w-full", min: 0, placeholder: "Ex: 50000" %>
              </div>
              
              <div class="form-control w-full" id="fuel-type-container">
                <%= v.label :fuel_type, "Type de carburant", class: "label" %>
                <%= v.select :fuel_type, 
                  ['Essence', 'Diesel', 'Hybride', 'Électrique', 'GPL', 'Autre'],
                  { include_blank: "Sélectionnez un type de carburant" },
                  { class: "select select-bordered w-full" } 
                %>
              </div>
            </div>
            
            <div class="form-control w-full mb-4" id="transmission-container">
              <%= v.label :transmission, "Transmission", class: "label" %>
              <%= v.select :transmission, 
                ['Manuelle', 'Automatique', 'Semi-automatique'],
                { include_blank: "Sélectionnez un type de transmission" },
                { class: "select select-bordered w-full" } 
              %>
            </div>
            
            <!-- Conteneur pour les champs spécifiques à chaque catégorie de véhicule -->
            <div id="specific-fields-container" class="mb-4">
              <!-- Les champs spécifiques seront chargés dynamiquement ici -->
            </div>
            
            <div class="form-control w-full mb-4">
              <%= v.label :description, "Détails supplémentaires du véhicule", class: "label" %>
              <%= v.text_area :description, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Options, équipements, etc." %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Section Détails du véhicule supplémentaires -->
      <div id="vehicle-details-section" class="section-content hidden">
        <h2 class="text-xl font-semibold mb-4">Détails supplémentaires du véhicule</h2>
        
        <%= fields_for :vehicle do |v| %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div class="form-control w-full">
              <%= v.label :finition, "Finition/Version", class: "label" %>
              <%= v.text_field :finition, class: "input input-bordered w-full", placeholder: "Ex: Pack Luxe, S LINE, INNOVA..." %>
            </div>
            
            <div class="form-control w-full">
              <%= v.label :doors, "Nombre de portes", class: "label" %>
              <%= v.select :doors, 
                [3, 5],
                { include_blank: "Sélectionnez un nombre de portes" },
                { class: "select select-bordered w-full" } 
              %>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div class="form-control w-full">
              <%= v.label :exterior_color, "Couleur extérieure", class: "label" %>
              <%= v.text_field :exterior_color, class: "input input-bordered w-full", placeholder: "Ex: Noir, Blanc, Rouge..." %>
            </div>
            
            <div class="form-control w-full">
              <%= v.label :interior_material, "Matière intérieure", class: "label" %>
              <%= v.select :interior_material, 
                ['Tissu', 'Cuir', 'Alcantara', 'Simili cuir', 'Mixte', 'Autre'],
                { include_blank: "Sélectionnez la matière intérieure" },
                { class: "select select-bordered w-full" } 
              %>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div class="form-control w-full">
              <%= v.label :interior_color, "Couleur intérieure", class: "label" %>
              <%= v.text_field :interior_color, class: "input input-bordered w-full", placeholder: "Ex: Noir, Beige..." %>
            </div>
            
            <div class="form-control w-full">
              <%= v.label :previous_owners, "Propriétaires précédents", class: "label" %>
              <%= v.number_field :previous_owners, class: "input input-bordered w-full", min: 0, placeholder: "Ex: 1" %>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div class="form-control w-full">
              <%= v.label :location, "Lieu de visualisation", class: "label" %>
              <%= v.text_field :location, class: "input input-bordered w-full", placeholder: "Ex: Paris, Lyon..." %>
            </div>
            
            <div class="form-control w-full">
              <%= v.label :non_smoker, "Véhicule non-fumeur", class: "label" %>
              <div class="flex items-center space-x-4 pt-2 pl-2">
                <label class="cursor-pointer flex items-center">
                  <%= v.radio_button :non_smoker, true, class: "radio radio-primary" %>
                  <span class="ml-2">Oui</span>
                </label>
                <label class="cursor-pointer flex items-center">
                  <%= v.radio_button :non_smoker, false, class: "radio radio-primary" %>
                  <span class="ml-2">Non</span>
                </label>
              </div>
            </div>
          </div>
          
          <div class="divider my-4">Historique et entretien</div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div class="form-control w-full">
              <%= v.label :last_service_date, "Date de la dernière révision", class: "label" %>
              <%= v.date_field :last_service_date, class: "input input-bordered w-full" %>
            </div>
            
            <div class="form-control w-full">
              <%= v.label :has_service_history, "Carnet d'entretien disponible", class: "label" %>
              <div class="flex items-center space-x-4 pt-2 pl-2">
                <label class="cursor-pointer flex items-center">
                  <%= v.radio_button :has_service_history, true, class: "radio radio-primary" %>
                  <span class="ml-2">Oui</span>
                </label>
                <label class="cursor-pointer flex items-center">
                  <%= v.radio_button :has_service_history, false, class: "radio radio-primary" %>
                  <span class="ml-2">Non</span>
                </label>
              </div>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div class="form-control w-full">
              <%= v.label :next_ct_date, "Date du prochain contrôle technique", class: "label" %>
              <%= v.date_field :next_ct_date, class: "input input-bordered w-full" %>
            </div>
            
            <div class="form-control w-full">
              <%= v.label :ct_expiry_date, "Date d'expiration du contrôle technique", class: "label" %>
              <%= v.date_field :ct_expiry_date, class: "input input-bordered w-full" %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Section Équipements du véhicule -->
      <div id="vehicle-features-section" class="section-content hidden">
        <h2 class="text-xl font-semibold mb-4">Équipements et options du véhicule</h2>
        
        <%= fields_for :vehicle do |v| %>
          <div class="form-control w-full mb-4">
            <%= v.label :safety_features, "Équipements de sécurité", class: "label" %>
            <div class="card bg-base-200 p-3 mb-2">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                <% ["ABS", "ESP (Contrôle de stabilité)", "Airbags frontaux", "Airbags latéraux", "Airbags rideaux", "Alarme", "Verrouillage centralisé", "Fixations ISOFIX", "Détecteur de fatigue", "Système d'appel d'urgence"].each do |feature| %>
                  <div class="form-control">
                    <label class="label cursor-pointer justify-start">
                      <input type="checkbox" class="checkbox checkbox-primary checkbox-sm mr-2" data-feature="safety" value="<%= feature %>">
                      <span class="label-text"><%= feature %></span>
                    </label>
                  </div>
                <% end %>
              </div>
            </div>
            <%= v.text_area :safety_features, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Autres équipements de sécurité..." %>
          </div>
          
          <div class="form-control w-full mb-4">
            <%= v.label :comfort_features, "Équipements de confort", class: "label" %>
            <div class="card bg-base-200 p-3 mb-2">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                <% ["Climatisation manuelle", "Climatisation automatique", "Climatisation bi-zone", "Sellerie cuir", "Sellerie tissu", "Sièges chauffants", "Sièges électriques", "Sièges à mémoire", "Régulateur de vitesse", "Limiteur de vitesse", "Direction assistée", "Vitres électriques avant", "Vitres électriques arrière", "Rétroviseurs électriques", "Rétroviseurs rabattables électriquement", "Toit ouvrant", "Toit panoramique", "Détecteur de pluie", "Allumage automatique des phares", "Aide au stationnement avant", "Aide au stationnement arrière", "Caméra de recul"].each do |feature| %>
                  <div class="form-control">
                    <label class="label cursor-pointer justify-start">
                      <input type="checkbox" class="checkbox checkbox-primary checkbox-sm mr-2" data-feature="comfort" value="<%= feature %>">
                      <span class="label-text"><%= feature %></span>
                    </label>
                  </div>
                <% end %>
              </div>
            </div>
            <%= v.text_area :comfort_features, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Autres équipements de confort..." %>
          </div>
          
          <div class="form-control w-full mb-4">
            <%= v.label :multimedia_features, "Équipements multimédia", class: "label" %>
            <div class="card bg-base-200 p-3 mb-2">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                <% ["Système audio", "Navigation GPS", "Lecteur CD/DVD", "Prise auxiliaire", "Prise USB", "Bluetooth", "Écran tactile", "Apple CarPlay", "Android Auto", "Commandes au volant", "Système audio premium"].each do |feature| %>
                  <div class="form-control">
                    <label class="label cursor-pointer justify-start">
                      <input type="checkbox" class="checkbox checkbox-primary checkbox-sm mr-2" data-feature="multimedia" value="<%= feature %>">
                      <span class="label-text"><%= feature %></span>
                    </label>
                  </div>
                <% end %>
              </div>
            </div>
            <%= v.text_area :multimedia_features, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Autres équipements multimédia..." %>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div class="form-control w-full">
              <%= v.label :exterior_features, "Équipements extérieurs", class: "label" %>
              <div class="card bg-base-200 p-3 mb-2">
                <div class="grid grid-cols-1 gap-2">
                  <% ["Jantes alliage", "Phares xénon", "Phares LED", "Feux antibrouillard", "Attelage de remorque", "Barres de toit", "Toit ouvrant", "Vitres teintées"].each do |feature| %>
                    <div class="form-control">
                      <label class="label cursor-pointer justify-start">
                        <input type="checkbox" class="checkbox checkbox-primary checkbox-sm mr-2" data-feature="exterior" value="<%= feature %>">
                        <span class="label-text"><%= feature %></span>
                      </label>
                    </div>
                  <% end %>
                </div>
              </div>
              <%= v.text_area :exterior_features, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Autres équipements extérieurs..." %>
            </div>
            
            <div class="form-control w-full">
              <%= v.label :other_features, "Autres équipements", class: "label" %>
              <div class="card bg-base-200 p-3 mb-2">
                <div class="grid grid-cols-1 gap-2">
                  <% ["Volant multifonctions", "Ordinateur de bord", "Tapis de sol d'origine", "Cache-bagages", "Prise 12V", "Système Stop & Start", "Suspension sport", "Mode de conduite"].each do |feature| %>
                    <div class="form-control">
                      <label class="label cursor-pointer justify-start">
                        <input type="checkbox" class="checkbox checkbox-primary checkbox-sm mr-2" data-feature="other" value="<%= feature %>">
                        <span class="label-text"><%= feature %></span>
                      </label>
                    </div>
                  <% end %>
                </div>
              </div>
              <%= v.text_area :other_features, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Autres équipements..." %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Section État du véhicule -->
      <div id="vehicle-condition-section" class="section-content hidden">
        <h2 class="text-xl font-semibold mb-4">État du véhicule et entretien</h2>
        
        <%= fields_for :vehicle do |v| %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div class="form-control w-full">
              <%= v.label :body_condition, "État de la carrosserie", class: "label" %>
              <%= v.text_area :body_condition, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Décrivez l'état de la carrosserie, rayures, bosses, etc." %>
            </div>
            
            <div class="form-control w-full">
              <%= v.label :interior_condition, "État de l'intérieur", class: "label" %>
              <%= v.text_area :interior_condition, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Décrivez l'état de l'intérieur, usure des sièges, du volant, etc." %>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div class="form-control w-full">
              <%= v.label :tire_condition, "État des pneus", class: "label" %>
              <%= v.text_area :tire_condition, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Décrivez l'état des pneus, usure, marque, etc." %>
            </div>
            
            <div class="form-control w-full">
              <%= v.label :recent_works, "Travaux récents effectués", class: "label" %>
              <%= v.text_area :recent_works, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Décrivez les travaux récents effectués: distribution, vidange, freins, etc." %>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div class="form-control w-full">
              <%= v.label :issues, "Points à signaler", class: "label" %>
              <%= v.text_area :issues, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Décrivez les éventuels problèmes mécaniques, électroniques, etc." %>
            </div>
            
            <div class="form-control w-full">
              <%= v.label :expected_costs, "Frais à prévoir", class: "label" %>
              <%= v.text_area :expected_costs, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Décrivez les frais à prévoir prochainement" %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Section Photos du véhicule -->
      <div id="photos-section" class="section-content hidden">
        <h2 class="text-xl font-semibold mb-4">Photos, vidéos et documents</h2>
        
        <div class="alert alert-info mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <div>
            <h4 class="font-medium">Informations importantes</h4>
            <ul class="mt-1 text-sm">
              <li>• Vous pouvez ajouter jusqu'à 10 photos/vidéos principales</li>
              <li>• Pour chaque média, vous pouvez choisir un contexte</li>
              <li>• La première photo sera l'image principale visible dans les résultats de recherche</li>
              <li>• Les vidéos doivent être au format MP4, MOV ou WebM (max 100 Mo)</li>
              <li>• Vous pouvez aussi créer des dossiers privés pour vos documents (factures, entretien, etc.)</li>
            </ul>
          </div>
        </div>
        
        <!-- Onglets Photos/Dossiers -->
        <div class="tabs tabs-boxed mb-6">
          <a class="tab tab-active" data-target="main-photos-tab">Photos et vidéos principales</a>
          <a class="tab" data-target="private-folders-tab">Dossiers privés</a>
        </div>
        
        <!-- Contenu onglet Photos principales -->
        <div id="main-photos-tab" class="tab-content">
          <div class="card bg-base-100 p-6 mb-6">
            <h3 class="font-medium mb-4">Photos et vidéos principales (max. 10)</h3>
            
            <!-- Zone d'upload de fichiers -->
            <div class="mb-6" id="main-media-uploader">
              <div class="flex items-center justify-center w-full" data-controller="direct-upload">
                <label class="flex flex-col w-full h-32 border-2 border-dashed rounded-md border-neutral-content hover:bg-base-200 hover:border-primary cursor-pointer">
                  <div class="flex flex-col items-center justify-center pt-7">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-neutral-content group-hover:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <p class="pt-1 text-sm tracking-wider text-neutral-content group-hover:text-primary">
                      Glissez-déposez des photos ou vidéos ou cliquez pour sélectionner
                    </p>
                  </div>
                  <input type="file" id="main-media-input" class="opacity-0" multiple accept="image/png, image/jpeg, image/jpg, video/mp4, video/quicktime, video/webm" data-direct-upload-target="input" />
                </label>
                <progress class="progress progress-primary w-full hidden mt-2" value="0" max="100" data-direct-upload-target="progress"></progress>
              </div>
              <p class="mt-2 text-xs text-neutral-content">Formats acceptés: JPG, JPEG, PNG, MP4, MOV, WebM</p>
            </div>
            
            <!-- Aperçu des fichiers sélectionnés -->
            <div id="main-media-preview" class="mb-4">
              <h4 class="font-medium mb-2">Fichiers en attente d'upload</h4>
              <div id="main-media-queue" class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <!-- Les fichiers sélectionnés seront affichés ici -->
              </div>
            </div>
            
            <!-- Formulaire d'ajout de média -->
            <% if @listing.persisted? %>
              <%= form_with model: MediaItem.new, url: listing_media_items_path(@listing), local: false, class: "hidden", id: "new-media-form" do |f| %>
                <%= f.hidden_field :title %>
                <%= f.hidden_field :context %>
                <%= f.hidden_field :private, value: false %>
                <%= f.file_field :media, class: "hidden", id: "media-file-input" %>
              <% end %>
            <% else %>
              <div id="new-media-form" class="hidden">
                <!-- Ce formulaire sera initialisé après la création de l'annonce -->
                <input type="hidden" id="media-file-input" class="hidden">
              </div>
            <% end %>
            
            <!-- Liste des médias déjà uploadés -->
            <div id="uploaded-media-list" class="mt-4 hidden">
              <h4 class="font-medium mb-2">Médias uploadés</h4>
              <div id="uploaded-media-container" class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <!-- Les médias uploadés seront affichés ici -->
              </div>
            </div>
          </div>
        </div>
        
        <!-- Contenu onglet Dossiers privés -->
        <div id="private-folders-tab" class="tab-content hidden">
          <div class="card bg-base-100 p-6 mb-6">
            <h3 class="font-medium mb-4">Dossiers privés pour documents et médias</h3>
            
            <div class="alert alert-warning mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
              <div>
                <h4 class="font-medium">Important: Contenu privé</h4>
                <p class="text-sm">Les dossiers créés ici sont privés et ne seront visibles que par vous. Vous pourrez choisir de les partager individuellement avec des acheteurs potentiels via la messagerie.</p>
              </div>
            </div>
            
            <!-- Liste des types de dossiers -->
            <div class="mb-6">
              <h4 class="font-medium mb-2">Créer un nouveau dossier</h4>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <% MediaFolder::FOLDER_TYPES.each do |folder_type| %>
                  <div class="card bg-base-200 p-4 cursor-pointer hover:bg-base-300" data-folder-type="<%= folder_type %>">
                    <div class="flex items-center">
                      <span class="text-primary mr-2">
                        <% case folder_type %>
                        <% when "Carnet d'entretien" %>
                          <i class="bi bi-journal-check text-lg"></i>
                        <% when "Factures & achats" %>
                          <i class="bi bi-receipt text-lg"></i>
                        <% when "Restaurations / Réparations" %>
                          <i class="bi bi-tools text-lg"></i>
                        <% when "Certificats & documents" %>
                          <i class="bi bi-file-earmark-text text-lg"></i>
                        <% when "Contrôle technique" %>
                          <i class="bi bi-clipboard-check text-lg"></i>
                        <% when "Carte grise" %>
                          <i class="bi bi-card-text text-lg"></i>
                        <% else %>
                          <i class="bi bi-folder text-lg"></i>
                        <% end %>
                      </span>
                      <span class="font-medium"><%= folder_type %></span>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
            
            <!-- Formulaire de création de dossier (apparaît lors du clic) -->
            <div id="folder-creation-form" class="hidden">
              <% if @listing.persisted? %>
                <%= form_with model: MediaFolder.new, url: listing_media_folders_path(@listing), local: false, id: "new-folder-form" do |f| %>
                  <div class="card bg-base-100 border border-primary p-4 mb-4">
                    <h4 class="font-medium flex items-center mb-4">
                      <span id="folder-icon" class="text-primary mr-2"><i class="bi bi-folder text-lg"></i></span>
                      <span>Nouveau dossier: <span id="folder-type-label"></span></span>
                    </h4>
                    
                    <div class="form-control w-full mb-4">
                      <%= f.label :name, "Nom du dossier", class: "label" %>
                      <%= f.text_field :name, class: "input input-bordered w-full", placeholder: "Ex: Entretien complet 2023" %>
                    </div>
                    
                    <div class="form-control w-full mb-4">
                      <%= f.label :description, "Description (optionnelle)", class: "label" %>
                      <%= f.text_area :description, rows: 2, class: "textarea textarea-bordered w-full", placeholder: "Décrivez brièvement le contenu de ce dossier" %>
                    </div>
                    
                    <%= f.hidden_field :private, value: true %>
                    
                    <div class="form-control w-full mb-4">
                      <label class="label">
                        <span class="label-text">Ajouter des fichiers (photos, vidéos, PDF)</span>
                      </label>
                      <input type="file" id="folder-media-input" multiple accept="image/png, image/jpeg, image/jpg, video/mp4, video/quicktime, video/webm, application/pdf" class="file-input file-input-bordered w-full" />
                    </div>
                    
                    <div id="folder-media-preview" class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-4 hidden">
                      <!-- Les fichiers du dossier sélectionnés seront affichés ici -->
                    </div>
                    
                    <div class="flex justify-end gap-2">
                      <button type="button" id="cancel-folder-btn" class="btn btn-ghost">Annuler</button>
                      <%= f.submit "Créer le dossier", class: "btn btn-primary" %>
                    </div>
                  </div>
                <% end %>
              <% else %>
                <div id="new-folder-form" class="card bg-base-100 border border-primary p-4 mb-4">
                  <h4 class="font-medium flex items-center mb-4">
                    <span id="folder-icon" class="text-primary mr-2"><i class="bi bi-folder text-lg"></i></span>
                    <span>Nouveau dossier: <span id="folder-type-label"></span></span>
                  </h4>
                  
                  <div class="form-control w-full mb-4">
                    <label class="label">Nom du dossier</label>
                    <input type="text" class="input input-bordered w-full" placeholder="Ex: Entretien complet 2023" disabled>
                  </div>
                  
                  <div class="form-control w-full mb-4">
                    <label class="label">Description (optionnelle)</label>
                    <textarea rows="2" class="textarea textarea-bordered w-full" placeholder="Décrivez brièvement le contenu de ce dossier" disabled></textarea>
                  </div>
                  
                  <div class="form-control w-full mb-4">
                    <label class="label">
                      <span class="label-text">Ajouter des fichiers (photos, vidéos, PDF)</span>
                    </label>
                    <input type="file" id="folder-media-input" multiple accept="image/png, image/jpeg, image/jpg, video/mp4, video/quicktime, video/webm, application/pdf" class="file-input file-input-bordered w-full" disabled />
                  </div>
                  
                  <div class="alert alert-info">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span>Vous pourrez créer des dossiers après avoir enregistré l'annonce.</span>
                  </div>
                  
                  <div class="flex justify-end gap-2">
                    <button type="button" id="cancel-folder-btn" class="btn btn-ghost">Annuler</button>
                    <button type="button" class="btn btn-primary" disabled>Créer le dossier</button>
                  </div>
                </div>
              <% end %>
            </div>
            
            <!-- Liste des dossiers créés -->
            <div id="created-folders-list" class="mt-4 hidden">
              <h4 class="font-medium mb-2">Dossiers créés</h4>
              <div id="created-folders-container">
                <!-- Les dossiers créés seront affichés ici -->
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="divider my-6"></div>

      <div class="flex justify-end gap-2">
        <%= link_to "Annuler", listings_path, class: "btn btn-ghost" %>
        <button type="button" id="prev-btn" class="btn btn-outline btn-primary hidden">Précédent</button>
        <button type="button" id="next-btn" class="btn btn-primary">Suivant</button>
        <%= form.submit "Publier l'annonce", id: "submit-btn", class: "btn btn-primary hidden" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener('turbo:load', function() {
    initializeForm();
    initializeCarBrandsAutocomplete();
    initializeMediaUploads();
    initializeFolderCreation();
    initializeTabs();
  });
  
  document.addEventListener('DOMContentLoaded', function() {
    initializeForm();
    initializeCarBrandsAutocomplete();
    initializeMediaUploads();
    initializeFolderCreation();
    initializeTabs();
  });
  
  // Fonction pour initialiser les onglets
  function initializeTabs() {
    const tabs = document.querySelectorAll('.tabs .tab');
    const tabContents = document.querySelectorAll('.tab-content');
    
    if (!tabs.length || !tabContents.length) return;
    
    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        // Retirer la classe active de tous les onglets
        tabs.forEach(t => t.classList.remove('tab-active'));
        
        // Ajouter la classe active à l'onglet cliqué
        this.classList.add('tab-active');
        
        // Cacher tous les contenus d'onglets
        tabContents.forEach(content => content.classList.add('hidden'));
        
        // Afficher le contenu correspondant à l'onglet
        const targetId = this.dataset.target;
        if (targetId) {
          const targetContent = document.getElementById(targetId);
          if (targetContent) {
            targetContent.classList.remove('hidden');
          }
        }
      });
    });
  }
  
  function initializeForm() {
    // Gestion des onglets
    const tabs = document.querySelectorAll('.tab');
    const sections = document.querySelectorAll('.section-content');
    const nextBtn = document.getElementById('next-btn');
    const prevBtn = document.getElementById('prev-btn');
    const submitBtn = document.getElementById('submit-btn');
    let currentSectionIndex = 0;
    
    if (!tabs.length || !sections.length) return;
    
    // Fonction pour afficher une section
    function showSection(index) {
      sections.forEach(section => section.classList.add('hidden'));
      sections[index].classList.remove('hidden');
      
      tabs.forEach(tab => tab.classList.remove('tab-active'));
      tabs[index].classList.add('tab-active');
      
      currentSectionIndex = index;
      
      // Afficher/masquer les boutons selon la section
      if (prevBtn) prevBtn.classList.toggle('hidden', index === 0);
      if (nextBtn) nextBtn.classList.toggle('hidden', index === sections.length - 1);
      if (submitBtn) submitBtn.classList.toggle('hidden', index !== sections.length - 1);
    }
    
    // Cliquer sur un onglet
    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => showSection(index));
    });
    
    // Bouton suivant
    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        if (currentSectionIndex < sections.length - 1) {
          showSection(currentSectionIndex + 1);
        }
      });
    }
    
    // Bouton précédent
    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        if (currentSectionIndex > 0) {
          showSection(currentSectionIndex - 1);
        }
      });
    }
    
    // Aperçu des photos
    const input = document.querySelector('input[type="file"]');
    const preview = document.getElementById('photos-preview');
    
    if (input && preview) {
      input.addEventListener('change', function() {
        preview.innerHTML = '';
        
        if (this.files && this.files.length > 0) {
          [...this.files].forEach(file => {
            if (!file.type.match('image.*')) return;
            
            const reader = new FileReader();
            reader.onload = function(e) {
              const div = document.createElement('div');
              div.className = 'relative group';
              
              const img = document.createElement('img');
              img.src = e.target.result;
              img.className = 'w-full h-32 object-cover rounded-lg';
              img.alt = 'Aperçu photo';
              
              const overlay = document.createElement('div');
              overlay.className = 'absolute inset-0 bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 transition-opacity duration-200 rounded-lg flex items-center justify-center text-white';
              overlay.innerHTML = `
                <div class="text-center">
                  <div class="badge badge-accent">${file.name.split('.').pop()}</div>
                  <p class="text-xs mt-1">${(file.size / 1024).toFixed(0)} KB</p>
                </div>
              `;
              
              div.appendChild(img);
              div.appendChild(overlay);
              preview.appendChild(div);
            };
            
            reader.readAsDataURL(file);
          });
        }
      });
    }

    // Gestion des cases à cocher pour les équipements
    document.querySelectorAll('input[type="checkbox"][data-feature]').forEach(checkbox => {
      checkbox.addEventListener('change', function() {
        const featureType = this.getAttribute('data-feature');
        const featureValue = this.value;
        let textareaId;
        
        switch(featureType) {
          case 'safety':
            textareaId = 'vehicle_safety_features';
            break;
          case 'comfort':
            textareaId = 'vehicle_comfort_features';
            break;
          case 'multimedia':
            textareaId = 'vehicle_multimedia_features';
            break;
          case 'exterior':
            textareaId = 'vehicle_exterior_features';
            break;
          case 'other':
            textareaId = 'vehicle_other_features';
            break;
        }
        
        const textarea = document.getElementById(textareaId);
        if (textarea) {
          let features = textarea.value ? textarea.value.split('\n').filter(f => f.trim() !== '') : [];
          
          if (this.checked) {
            if (!features.includes(featureValue)) {
              features.push(featureValue);
            }
          } else {
            features = features.filter(f => f !== featureValue);
          }
          
          textarea.value = features.join('\n');
        }
      });
    });
    
    // Gestion des catégories et sous-catégories
    const categorySelect = document.getElementById('vehicle_category_id');
    const subcategorySelect = document.getElementById('vehicle_subcategory');
    const customTypeContainer = document.getElementById('custom-type-container');
    const specificFieldsContainer = document.getElementById('specific-fields-container');
    const fuelTypeContainer = document.getElementById('fuel-type-container');
    const transmissionContainer = document.getElementById('transmission-container');
    
    // Fonction pour charger les sous-catégories en fonction de la catégorie sélectionnée
    function loadSubcategories(categoryId) {
      if (!categoryId) {
        subcategorySelect.disabled = true;
        subcategorySelect.innerHTML = '<option value="">Sélectionnez d\'abord une catégorie</option>';
        return;
      }
      
      fetch(`/vehicles/subcategories/${categoryId}`)
        .then(response => response.json())
        .then(data => {
          // Vider et réactiver le select des sous-catégories
          subcategorySelect.innerHTML = '<option value="">Sélectionnez un type de véhicule</option>';
          
          // Ajouter les options pour les sous-catégories
          if (data && data.length > 0) {
            data.forEach(subcategory => {
              const option = document.createElement('option');
              option.value = subcategory.name;
              option.textContent = subcategory.name;
              subcategorySelect.appendChild(option);
            });
            
            // Ajouter l'option "Autre"
            const otherOption = document.createElement('option');
            otherOption.value = "Autre";
            otherOption.textContent = "Autre";
            subcategorySelect.appendChild(otherOption);
            
            subcategorySelect.disabled = false;
          } else {
            subcategorySelect.disabled = true;
          }
        })
        .catch(error => {
          console.error('Erreur lors du chargement des sous-catégories:', error);
        });
    }
    
    // Fonction pour charger les champs spécifiques en fonction de la catégorie
    function loadSpecificFields(category) {
      if (!category) {
        specificFieldsContainer.innerHTML = '';
        return;
      }
      
      fetch(`/vehicles/specific_fields?category=${category}`)
        .then(response => response.json())
        .then(data => {
          specificFieldsContainer.innerHTML = '';
          
          // Masquer/afficher les champs standard en fonction de la catégorie
          const commonFields = {
            'fuel_type': fuelTypeContainer,
            'transmission': transmissionContainer
          };
          
          // Par défaut, tous les champs communs sont cachés
          Object.values(commonFields).forEach(field => {
            if (field) field.classList.add('hidden');
          });
          
          // Afficher les champs communs pertinents pour cette catégorie
          if (data.fields && data.fields.includes('fuel_type') && commonFields['fuel_type']) {
            commonFields['fuel_type'].classList.remove('hidden');
          }
          
          if (data.fields && data.fields.includes('transmission') && commonFields['transmission']) {
            commonFields['transmission'].classList.remove('hidden');
          }
          
          // Créer les champs spécifiques à la catégorie
          if (data.fields && data.fields.length > 0) {
            // Création du titre de section
            const titleDiv = document.createElement('div');
            titleDiv.className = "divider my-4";
            titleDiv.textContent = `Informations spécifiques - ${category}`;
            specificFieldsContainer.appendChild(titleDiv);
            
            // Création d'un conteneur pour les champs
            const fieldsGrid = document.createElement('div');
            fieldsGrid.className = "grid grid-cols-1 md:grid-cols-2 gap-4";
            specificFieldsContainer.appendChild(fieldsGrid);
            
            // Ajout des champs spécifiques
            data.fields.forEach(field => {
              // Éviter de dupliquer les champs qui sont déjà gérés comme communs
              if (['fuel_type', 'transmission'].includes(field)) {
                return;
              }
              
              const fieldDiv = document.createElement('div');
              fieldDiv.className = "form-control w-full";
              
              // Configuration du champ en fonction de son type
              switch(field) {
                case 'cylinder_capacity':
                  fieldDiv.innerHTML = `
                    <label for="vehicle_cylinder_capacity" class="label">Cylindrée (cm³)</label>
                    <input type="number" name="vehicle[cylinder_capacity]" id="vehicle_cylinder_capacity" class="input input-bordered w-full" placeholder="Ex: 1000" min="0">
                  `;
                  break;
                case 'engine_type':
                  fieldDiv.innerHTML = `
                    <label for="vehicle_engine_type" class="label">Type de moteur</label>
                    <select name="vehicle[engine_type]" id="vehicle_engine_type" class="select select-bordered w-full">
                      <option value="">Sélectionnez un type</option>
                      <option value="4 temps">4 temps</option>
                      <option value="2 temps">2 temps</option>
                      <option value="Electrique">Électrique</option>
                      <option value="Hybride">Hybride</option>
                      <option value="Autre">Autre</option>
                    </select>
                  `;
                  break;
                case 'cooling_type':
                  fieldDiv.innerHTML = `
                    <label for="vehicle_cooling_type" class="label">Type de refroidissement</label>
                    <select name="vehicle[cooling_type]" id="vehicle_cooling_type" class="select select-bordered w-full">
                      <option value="">Sélectionnez un type</option>
                      <option value="Air">Air</option>
                      <option value="Liquide">Liquide</option>
                      <option value="Mixte">Mixte</option>
                    </select>
                  `;
                  break;
                case 'starter_type':
                  fieldDiv.innerHTML = `
                    <label for="vehicle_starter_type" class="label">Type de démarrage</label>
                    <select name="vehicle[starter_type]" id="vehicle_starter_type" class="select select-bordered w-full">
                      <option value="">Sélectionnez un type</option>
                      <option value="Electrique">Électrique</option>
                      <option value="Kick">Kick</option>
                      <option value="Mixte">Mixte</option>
                    </select>
                  `;
                  break;
                case 'license_type':
                  fieldDiv.innerHTML = `
                    <label for="vehicle_license_type" class="label">Type de permis requis</label>
                    <select name="vehicle[license_type]" id="vehicle_license_type" class="select select-bordered w-full">
                      <option value="">Sélectionnez un type</option>
                      <option value="A">A</option>
                      <option value="A1">A1</option>
                      <option value="A2">A2</option>
                      <option value="B">B (avec formation 125cc)</option>
                      <option value="AM">AM (BSR)</option>
                      <option value="Aucun">Aucun permis requis</option>
                    </select>
                  `;
                  break;
                case 'length':
                case 'width':
                case 'draft':
                  const labels = {
                    'length': 'Longueur (m)',
                    'width': 'Largeur (m)',
                    'draft': 'Tirant d\'eau (m)'
                  };
                  fieldDiv.innerHTML = `
                    <label for="vehicle_${field}" class="label">${labels[field]}</label>
                    <input type="number" name="vehicle[${field}]" id="vehicle_${field}" class="input input-bordered w-full" placeholder="Ex: 10.5" min="0" step="0.01">
                  `;
                  break;
                case 'hull_material':
                  fieldDiv.innerHTML = `
                    <label for="vehicle_hull_material" class="label">Matériau de la coque</label>
                    <select name="vehicle[hull_material]" id="vehicle_hull_material" class="select select-bordered w-full">
                      <option value="">Sélectionnez un matériau</option>
                      <option value="Fibre de verre">Fibre de verre</option>
                      <option value="Polyester">Polyester</option>
                      <option value="Bois">Bois</option>
                      <option value="Aluminium">Aluminium</option>
                      <option value="Acier">Acier</option>
                      <option value="Composite">Composite</option>
                      <option value="Autre">Autre</option>
                    </select>
                  `;
                  break;
                case 'number_of_cabins':
                case 'number_of_berths':
                case 'engine_hours':
                case 'number_of_seats':
                case 'flight_hours':
                case 'number_of_engines':
                case 'ceiling':
                case 'range':
                case 'operating_hours':
                case 'axles':
                  const hourLabels = {
                    'number_of_cabins': 'Nombre de cabines',
                    'number_of_berths': 'Nombre de couchettes',
                    'engine_hours': 'Heures moteur',
                    'number_of_seats': 'Nombre de places',
                    'flight_hours': 'Heures de vol',
                    'number_of_engines': 'Nombre de moteurs',
                    'ceiling': 'Plafond (pieds)',
                    'range': 'Autonomie (km)',
                    'operating_hours': 'Heures de fonctionnement',
                    'axles': 'Nombre d\'essieux'
                  };
                  fieldDiv.innerHTML = `
                    <label for="vehicle_${field}" class="label">${hourLabels[field]}</label>
                    <input type="number" name="vehicle[${field}]" id="vehicle_${field}" class="input input-bordered w-full" min="0">
                  `;
                  break;
                case 'drive_type':
                  fieldDiv.innerHTML = `
                    <label for="vehicle_drive_type" class="label">Type de transmission</label>
                    <select name="vehicle[drive_type]" id="vehicle_drive_type" class="select select-bordered w-full">
                      <option value="">Sélectionnez un type</option>
                      <option value="2x4">2x4</option>
                      <option value="4x4">4x4</option>
                      <option value="6x6">6x6</option>
                      <option value="Autre">Autre</option>
                    </select>
                  `;
                  break;
                case 'transmission_type':
                  fieldDiv.innerHTML = `
                    <label for="vehicle_transmission_type" class="label">Type de boîte</label>
                    <select name="vehicle[transmission_type]" id="vehicle_transmission_type" class="select select-bordered w-full">
                      <option value="">Sélectionnez un type</option>
                      <option value="Automatique">Automatique</option>
                      <option value="Manuelle">Manuelle</option>
                      <option value="CVT">CVT</option>
                      <option value="Semi-automatique">Semi-automatique</option>
                    </select>
                  `;
                  break;
                case 'lifting_capacity':
                case 'maximum_reach':
                case 'bucket_capacity':
                case 'loading_capacity':
                case 'towing_capacity':
                  const capacityLabels = {
                    'lifting_capacity': 'Capacité de levage (tonnes)',
                    'maximum_reach': 'Portée maximale (m)',
                    'bucket_capacity': 'Capacité du godet (m³)',
                    'loading_capacity': 'Capacité de charge (tonnes)',
                    'towing_capacity': 'Capacité de remorquage (tonnes)'
                  };
                  fieldDiv.innerHTML = `
                    <label for="vehicle_${field}" class="label">${capacityLabels[field]}</label>
                    <input type="number" name="vehicle[${field}]" id="vehicle_${field}" class="input input-bordered w-full" min="0" step="0.1">
                  `;
                  break;
                case 'additional_equipment':
                  fieldDiv.innerHTML = `
                    <label for="vehicle_additional_equipment" class="label">Équipements additionnels</label>
                    <textarea name="vehicle[additional_equipment]" id="vehicle_additional_equipment" rows="3" class="textarea textarea-bordered w-full" placeholder="Décrivez les équipements additionnels"></textarea>
                  `;
                  fieldsGrid.appendChild(fieldDiv);
                  return;
                case 'sleeping_cab':
                  fieldDiv.innerHTML = `
                    <label for="vehicle_sleeping_cab" class="label">Cabine couchette</label>
                    <div class="flex items-center space-x-4 pt-2 pl-2">
                      <label class="cursor-pointer flex items-center">
                        <input type="radio" name="vehicle[sleeping_cab]" value="true" class="radio radio-primary">
                        <span class="ml-2">Oui</span>
                      </label>
                      <label class="cursor-pointer flex items-center">
                        <input type="radio" name="vehicle[sleeping_cab]" value="false" class="radio radio-primary">
                        <span class="ml-2">Non</span>
                      </label>
                    </div>
                  `;
                  break;
                case 'emission_standard':
                  fieldDiv.innerHTML = `
                    <label for="vehicle_emission_standard" class="label">Norme d'émission</label>
                    <select name="vehicle[emission_standard]" id="vehicle_emission_standard" class="select select-bordered w-full">
                      <option value="">Sélectionnez une norme</option>
                      <option value="Euro 1">Euro 1</option>
                      <option value="Euro 2">Euro 2</option>
                      <option value="Euro 3">Euro 3</option>
                      <option value="Euro 4">Euro 4</option>
                      <option value="Euro 5">Euro 5</option>
                      <option value="Euro 6">Euro 6</option>
                      <option value="Euro 6d-TEMP">Euro 6d-TEMP</option>
                      <option value="Euro 6d">Euro 6d</option>
                    </select>
                  `;
                  break;
                default:
                  return;
              }
              
              fieldsGrid.appendChild(fieldDiv);
            });
          }
        })
        .catch(error => {
          console.error('Erreur lors du chargement des champs spécifiques:', error);
        });
    }
    
    // Écouteurs d'événements pour les sélecteurs
    if (categorySelect) {
      categorySelect.addEventListener('change', function() {
        const categoryId = this.value;
        const categoryText = this.options[this.selectedIndex].text;
        
        loadSubcategories(categoryId);
        loadSpecificFields(categoryText);
        
        // Réinitialiser le champ de type personnalisé
        if (customTypeContainer) {
          customTypeContainer.classList.add('hidden');
        }
      });
    }
    
    if (subcategorySelect) {
      subcategorySelect.addEventListener('change', function() {
        const subcategoryValue = this.value;
        
        // Afficher le champ de type personnalisé si "Autre" est sélectionné
        if (customTypeContainer) {
          if (subcategoryValue === 'Autre') {
            customTypeContainer.classList.remove('hidden');
          } else {
            customTypeContainer.classList.add('hidden');
          }
        }
      });
    }
  }

