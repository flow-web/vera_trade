<div class="container mx-auto px-4 py-8 max-w-6xl">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Ticket Header -->
      <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
          <div class="flex justify-between items-start mb-4">
            <div>
              <h1 class="text-2xl font-bold text-gray-900"><%= @support_ticket.title %></h1>
              <div class="flex items-center gap-2 mt-2">
                <span class="text-sm text-gray-500">Ticket #<%= @support_ticket.ticket_number %></span>
                <div class="badge <%= @support_ticket.status == 'open' ? 'badge-primary' : 
                                    @support_ticket.status == 'resolved' ? 'badge-success' : 
                                    @support_ticket.status == 'in_progress' ? 'badge-info' : 'badge-secondary' %>">
                  <%= @support_ticket.status_label %>
                </div>
                <div class="badge badge-outline"><%= @support_ticket.category_label %></div>
                <% if @support_ticket.priority == 'urgent' %>
                  <div class="badge badge-error">Urgent</div>
                <% elsif @support_ticket.priority == 'high' %>
                  <div class="badge badge-warning">Priorité élevée</div>
                <% end %>
              </div>
            </div>
            <div class="dropdown dropdown-end">
              <label tabindex="0" class="btn btn-ghost btn-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
                </svg>
              </label>
              <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-52">
                <% if @support_ticket.can_be_edited_by?(current_user) %>
                  <li><%= link_to "Modifier", edit_support_ticket_path(@support_ticket) %></li>
                <% end %>
                <% if @support_ticket.open? && @support_ticket.user == current_user %>
                  <li><%= link_to "Fermer le ticket", close_support_ticket_path(@support_ticket), method: :patch, class: "text-error" %></li>
                <% end %>
                <% if @support_ticket.closed? && @support_ticket.can_be_edited_by?(current_user) %>
                  <li><%= link_to "Rouvrir", reopen_support_ticket_path(@support_ticket), method: :patch %></li>
                <% end %>
              </ul>
            </div>
          </div>
          
          <div class="prose max-w-none">
            <%= simple_format(@support_ticket.description) %>
          </div>

          <% if @support_ticket.attachments.attached? %>
            <div class="mt-4">
              <h4 class="font-semibold mb-2">Pièces jointes :</h4>
              <div class="flex flex-wrap gap-2">
                <% @support_ticket.attachments.each do |attachment| %>
                  <%= link_to attachment.filename, attachment, target: '_blank', 
                      class: "btn btn-sm btn-outline" %>
                <% end %>
              </div>
            </div>
          <% end %>
          
          <div class="flex justify-between text-sm text-gray-500 mt-4 pt-4 border-t">
            <span>Créé le <%= l(@support_ticket.created_at, format: :long) %></span>
            <% if @support_ticket.assigned_to %>
              <span>Assigné à <%= @support_ticket.assigned_to.email %></span>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Messages -->
      <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
          <h2 class="card-title mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            Conversation
          </h2>
          
          <div class="space-y-4 mb-6" id="messages-container">
            <% @ticket_messages.each do |message| %>
              <div class="chat <%= message.from_user? ? 'chat-end' : 'chat-start' %>">
                <div class="chat-image avatar">
                  <div class="w-10 rounded-full bg-primary text-primary-content flex items-center justify-center">
                    <%= message.user.email.first.upcase %>
                  </div>
                </div>
                <div class="chat-header">
                  <%= message.from_user? ? 'Vous' : (message.user.admin? ? 'Support' : message.user.email) %>
                  <time class="text-xs opacity-50"><%= time_ago_in_words(message.created_at) %></time>
                  <% if message.edited? %>
                    <span class="text-xs opacity-50">(modifié)</span>
                  <% end %>
                </div>
                <div class="chat-bubble <%= message.from_user? ? 'chat-bubble-primary' : 'chat-bubble-secondary' %>">
                  <%= simple_format(message.message) %>
                  <% if message.attachments.attached? %>
                    <div class="mt-2 space-x-2">
                      <% message.attachments.each do |attachment| %>
                        <%= link_to attachment.filename, attachment, target: '_blank', 
                            class: "underline text-xs opacity-80" %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Message Form -->
          <% if @support_ticket.open? %>
            <div class="border-t pt-4">
              <%= form_with model: [@support_ticket, @new_message], local: true, multipart: true, class: "space-y-4" do |form| %>
                <div class="form-control">
                  <%= form.text_area :message, 
                      class: "textarea textarea-bordered", 
                      placeholder: "Tapez votre message...",
                      rows: 3,
                      required: true %>
                </div>
                
                <div class="form-control">
                  <%= form.file_field :attachments, 
                      multiple: true,
                      accept: "image/*,application/pdf,.doc,.docx",
                      class: "file-input file-input-bordered file-input-sm" %>
                  <label class="label">
                    <span class="label-text-alt">Joindre des fichiers (optionnel)</span>
                  </label>
                </div>
                
                <div class="flex justify-end">
                  <%= form.submit "Envoyer", class: "btn btn-primary" %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="alert alert-info">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h3 class="font-bold">Ticket fermé</h3>
                <p>Ce ticket est fermé. Vous ne pouvez plus envoyer de messages.</p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Ticket Info -->
      <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
          <h3 class="card-title text-lg mb-4">Informations</h3>
          
          <div class="space-y-3">
            <div>
              <span class="font-medium text-gray-600">Statut :</span>
              <div class="mt-1">
                <div class="badge <%= @support_ticket.status == 'open' ? 'badge-primary' : 
                                    @support_ticket.status == 'resolved' ? 'badge-success' : 
                                    @support_ticket.status == 'in_progress' ? 'badge-info' : 'badge-secondary' %>">
                  <%= @support_ticket.status_label %>
                </div>
              </div>
            </div>
            
            <div>
              <span class="font-medium text-gray-600">Priorité :</span>
              <div class="mt-1">
                <div class="badge <%= @support_ticket.priority == 'urgent' ? 'badge-error' : 
                                    @support_ticket.priority == 'high' ? 'badge-warning' : 'badge-outline' %>">
                  <%= @support_ticket.priority_label %>
                </div>
              </div>
            </div>
            
            <div>
              <span class="font-medium text-gray-600">Catégorie :</span>
              <div class="mt-1 text-sm"><%= @support_ticket.category_label %></div>
            </div>
            
            <% if @support_ticket.assigned_to %>
              <div>
                <span class="font-medium text-gray-600">Agent assigné :</span>
                <div class="mt-1 text-sm"><%= @support_ticket.assigned_to.email %></div>
              </div>
            <% end %>
            
            <div>
              <span class="font-medium text-gray-600">Créé le :</span>
              <div class="mt-1 text-sm"><%= l(@support_ticket.created_at, format: :short) %></div>
            </div>
            
            <% if @support_ticket.resolved_at %>
              <div>
                <span class="font-medium text-gray-600">Résolu le :</span>
                <div class="mt-1 text-sm"><%= l(@support_ticket.resolved_at, format: :short) %></div>
              </div>
            <% end %>
            
            <% if @support_ticket.overdue? %>
              <div class="alert alert-warning p-2">
                <span class="text-xs">🕐 En retard selon SLA</span>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Rating (if resolved) -->
      <% if @support_ticket.status == 'resolved' && !@support_ticket.satisfaction_provided? %>
        <div class="card bg-base-100 shadow-xl">
          <div class="card-body">
            <h3 class="card-title text-lg mb-4">Évaluer le support</h3>
            
            <%= form_with url: rate_support_ticket_path(@support_ticket), method: :post, local: true, class: "space-y-4" do |form| %>
              <div class="form-control">
                <label class="label">Note (1-5 étoiles)</label>
                <div class="rating rating-lg">
                  <input type="radio" name="rating" value="1" class="mask mask-star-2 bg-orange-400" />
                  <input type="radio" name="rating" value="2" class="mask mask-star-2 bg-orange-400" />
                  <input type="radio" name="rating" value="3" class="mask mask-star-2 bg-orange-400" />
                  <input type="radio" name="rating" value="4" class="mask mask-star-2 bg-orange-400" />
                  <input type="radio" name="rating" value="5" class="mask mask-star-2 bg-orange-400" />
                </div>
              </div>
              
              <div class="form-control">
                <%= form.text_area :feedback, 
                    class: "textarea textarea-bordered", 
                    placeholder: "Commentaire (optionnel)",
                    rows: 3 %>
              </div>
              
              <%= form.submit "Évaluer", class: "btn btn-primary btn-sm w-full" %>
            <% end %>
          </div>
        </div>
      <% elsif @support_ticket.satisfaction_provided? %>
        <div class="card bg-base-100 shadow-xl">
          <div class="card-body">
            <h3 class="card-title text-lg mb-4">Votre évaluation</h3>
            
            <div class="space-y-2">
              <div class="rating rating-sm">
                <% (1..5).each do |star| %>
                  <input type="radio" class="mask mask-star-2 bg-orange-400" disabled 
                         <%= 'checked' if @support_ticket.satisfaction_rating.to_i >= star %> />
                <% end %>
              </div>
              
              <div class="text-sm text-gray-600">
                <%= @support_ticket.satisfaction_rating %>/5 étoiles
              </div>
              
              <% if @support_ticket.satisfaction_feedback.present? %>
                <div class="text-sm">
                  <strong>Commentaire :</strong><br>
                  <%= simple_format(@support_ticket.satisfaction_feedback) %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Quick Actions -->
      <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
          <h3 class="card-title text-lg mb-4">Actions rapides</h3>
          
          <div class="space-y-2">
            <%= link_to "Tous mes tickets", support_tickets_path, 
                class: "btn btn-outline btn-sm w-full" %>
            
            <%= link_to "Nouveau ticket", new_support_ticket_path, 
                class: "btn btn-primary btn-sm w-full" %>
            
            <%= link_to "Centre d'aide", help_path, 
                class: "btn btn-ghost btn-sm w-full" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Auto-scroll to bottom of messages
  document.addEventListener('DOMContentLoaded', function() {
    const messagesContainer = document.getElementById('messages-container');
    if (messagesContainer) {
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }
  });
</script>
