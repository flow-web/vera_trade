<div class="min-h-[80vh] flex items-center justify-center py-12 px-4">
  <div class="max-w-md w-full">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold mb-2">Paramètres du compte</h1>
    </div>

    <div class="card-glass p-8">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="grid grid-cols-2 gap-4">
          <div class="form-control">
            <%= f.label :first_name, "Prénom", class: "label text-sm font-medium" %>
            <%= f.text_field :first_name, class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary" %>
          </div>
          <div class="form-control">
            <%= f.label :last_name, "Nom", class: "label text-sm font-medium" %>
            <%= f.text_field :last_name, class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary" %>
          </div>
        </div>

        <div class="form-control">
          <%= f.label :email, "Email", class: "label text-sm font-medium" %>
          <%= f.email_field :email, autocomplete: "email",
              class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary" %>
        </div>

        <div class="form-control">
          <%= f.label :phone, "Téléphone", class: "label text-sm font-medium" %>
          <%= f.telephone_field :phone, class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary" %>
        </div>

        <div class="divider text-base-content/30">Changer le mot de passe</div>

        <div class="form-control">
          <%= f.label :password, "Nouveau mot de passe", class: "label text-sm font-medium" %>
          <span class="text-xs text-base-content/50">Laisser vide pour ne pas modifier</span>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary" %>
        </div>

        <div class="form-control">
          <%= f.label :password_confirmation, "Confirmer", class: "label text-sm font-medium" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary" %>
        </div>

        <div class="form-control">
          <%= f.label :current_password, "Mot de passe actuel", class: "label text-sm font-medium" %>
          <span class="text-xs text-base-content/50">Requis pour confirmer les modifications</span>
          <%= f.password_field :current_password, autocomplete: "current-password",
              class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary" %>
        </div>

        <%= f.submit "Enregistrer", class: "btn btn-primary w-full cursor-pointer" %>
      <% end %>
    </div>

    <div class="card-glass p-6 mt-6">
      <h3 class="text-sm font-medium text-error mb-3">Zone dangereuse</h3>
      <p class="text-sm text-base-content/50 mb-4">La suppression du compte est irréversible.</p>
      <%= button_to "Supprimer mon compte", registration_path(resource_name),
          method: :delete,
          data: { turbo_confirm: "Êtes-vous sûr ? Cette action est irréversible." },
          class: "btn btn-outline btn-error btn-sm cursor-pointer" %>
    </div>
  </div>
</div>
