<%#
  Paramètres du compte — Cinematic Archivist.
  Layout single-colonne éditorial, section Identité / Contact / Sécurité + Zone dangereuse.
%>
<% content_for :title, "Paramètres — Vera Trade" %>

<section class="relative bg-bg-primary">
  <div class="max-w-[900px] mx-auto px-5 lg:px-10 py-16 lg:py-24">

    <!-- En-tête éditorial -->
    <header class="mb-16">
      <p class="eyebrow mb-5">Profil collectionneur</p>
      <h1 class="font-display text-[44px] lg:text-[64px] leading-[1.05] text-text-primary mb-4">
        <span class="playfair-italic">Vos</span> paramètres.
      </h1>
      <p class="font-body italic text-[16px] text-text-secondary max-w-[560px]">
        Votre profil reste la base de confiance du cercle. Toute modification sensible nécessite votre mot de passe actuel.
      </p>
    </header>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-12", novalidate: true }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <!-- Section Identité -->
      <section>
        <div class="flex items-baseline justify-between mb-8 pb-4 border-b border-line">
          <h2 class="font-display text-[24px] playfair-italic text-text-primary">Identité</h2>
          <span class="label-small text-accent-red">Section 01</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <%= f.label :first_name, "Prénom", class: "label-small block mb-3" %>
            <%= f.text_field :first_name, autocomplete: "given-name", class: "input-vera" %>
          </div>
          <div>
            <%= f.label :last_name, "Nom", class: "label-small block mb-3" %>
            <%= f.text_field :last_name, autocomplete: "family-name", class: "input-vera" %>
          </div>
        </div>
      </section>

      <!-- Section Contact -->
      <section>
        <div class="flex items-baseline justify-between mb-8 pb-4 border-b border-line">
          <h2 class="font-display text-[24px] playfair-italic text-text-primary">Contact</h2>
          <span class="label-small text-accent-red">Section 02</span>
        </div>
        <div class="space-y-6">
          <div>
            <%= f.label :email, "Adresse email", class: "label-small block mb-3" %>
            <%= f.email_field :email, autocomplete: "email", class: "input-vera" %>
            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <p class="mt-3 font-ui text-[10px] uppercase tracking-[0.15em] text-accent-red">
                En attente de confirmation pour : <%= resource.unconfirmed_email %>
              </p>
            <% end %>
          </div>
          <div>
            <%= f.label :phone, "Téléphone", class: "label-small block mb-3" %>
            <%= f.telephone_field :phone, autocomplete: "tel", class: "input-vera input-mono" %>
          </div>
        </div>
      </section>

      <!-- Section Sécurité -->
      <section>
        <div class="flex items-baseline justify-between mb-8 pb-4 border-b border-line">
          <h2 class="font-display text-[24px] playfair-italic text-text-primary">Sécurité</h2>
          <span class="label-small text-accent-red">Section 03</span>
        </div>
        <p class="font-body italic text-[14px] text-text-muted mb-6">
          Laissez les champs vides si vous ne souhaitez pas changer de mot de passe.
        </p>
        <div class="space-y-6">
          <div>
            <%= f.label :password, "Nouveau mot de passe", class: "label-small block mb-3" %>
            <%= f.password_field :password, autocomplete: "new-password", class: "input-vera", placeholder: "••••••••" %>
          </div>
          <div>
            <%= f.label :password_confirmation, "Confirmer le nouveau mot de passe", class: "label-small block mb-3" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input-vera", placeholder: "••••••••" %>
          </div>
          <div class="pt-4 border-t border-line">
            <%= f.label :current_password, "Mot de passe actuel", class: "label-small block mb-3" %>
            <p class="font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted mb-3">
              Requis pour confirmer les modifications de cette page.
            </p>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "input-vera", placeholder: "••••••••" %>
          </div>
        </div>
      </section>

      <div class="flex items-center justify-end gap-4 pt-8 border-t border-line">
        <%= link_to "Annuler", :back, class: "btn-vera-secondary cursor-pointer" %>
        <%= f.submit "Enregistrer", class: "btn-vera-primary cursor-pointer" %>
      </div>
    <% end %>

    <!-- Zone dangereuse -->
    <section class="mt-20 pt-10 border-t border-line">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="font-display text-[24px] playfair-italic text-accent-red">Zone rouge</h2>
        <span class="label-small text-accent-red">Irréversible</span>
      </div>
      <div class="card-vera p-8 border-l-2 border-l-accent-red">
        <p class="font-body italic text-[15px] text-text-secondary leading-relaxed mb-6 max-w-[500px]">
          La suppression de votre profil retire définitivement vos annonces, votre historique et vos favoris. Cette action ne peut pas être annulée.
        </p>
        <%= button_to registration_path(resource_name),
            method: :delete,
            form: { data: { turbo_confirm: "Confirmer la suppression définitive du profil ?" } },
            class: "btn-vera-secondary !border-accent-red !text-accent-red hover:!bg-accent-red hover:!text-text-primary cursor-pointer" do %>
          Supprimer mon profil
        <% end %>
      </div>
    </section>

  </div>
</section>
