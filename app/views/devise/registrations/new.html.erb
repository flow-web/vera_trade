<div class="min-h-[80vh] flex items-center justify-center py-12 px-4">
  <div class="max-w-md w-full">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold mb-2">Créer un compte</h1>
      <p class="text-base-content/60">
        Déjà inscrit ?
        <%= link_to "Se connecter", new_session_path(resource_name), class: "text-primary hover:underline" %>
      </p>
    </div>

    <div class="card-glass p-8">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="grid grid-cols-2 gap-4">
          <div class="form-control">
            <%= f.label :first_name, "Prénom", class: "label text-sm font-medium" %>
            <%= f.text_field :first_name, autocomplete: "given-name",
                class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary",
                placeholder: "Prénom" %>
          </div>
          <div class="form-control">
            <%= f.label :last_name, "Nom", class: "label text-sm font-medium" %>
            <%= f.text_field :last_name, autocomplete: "family-name",
                class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary",
                placeholder: "Nom" %>
          </div>
        </div>

        <div class="form-control">
          <%= f.label :email, "Email", class: "label text-sm font-medium" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary",
              placeholder: "votre@email.com" %>
        </div>

        <div class="form-control">
          <%= f.label :phone, "Téléphone", class: "label text-sm font-medium" %>
          <%= f.telephone_field :phone, autocomplete: "tel",
              class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary",
              placeholder: "06 12 34 56 78" %>
        </div>

        <div class="form-control">
          <%= f.label :password, "Mot de passe", class: "label text-sm font-medium" %>
          <% if @minimum_password_length %>
            <span class="text-xs text-base-content/50"><%= @minimum_password_length %> caractères minimum</span>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary",
              placeholder: "Mot de passe" %>
        </div>

        <div class="form-control">
          <%= f.label :password_confirmation, "Confirmer", class: "label text-sm font-medium" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary",
              placeholder: "Confirmer le mot de passe" %>
        </div>

        <%= f.submit "Créer mon compte", class: "btn btn-primary w-full cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>
