<%#
  Renvoyer email de confirmation — Cinematic Archivist.
%>
<% content_for :title, "Renvoyer la confirmation — Vera Trade" %>

<section class="relative bg-bg-primary overflow-hidden">
  <span aria-hidden="true" class="wordmark-deco absolute top-1/3 -left-10 text-[20rem] leading-[0.7] hidden lg:block">✉</span>

  <div class="relative max-w-[520px] mx-auto px-5 lg:px-10 py-20 lg:py-32 min-h-[calc(100vh-80px)] flex flex-col justify-center">

    <p class="eyebrow mb-5">Confirmation</p>
    <h1 class="font-display text-[44px] lg:text-[56px] leading-[1.05] text-text-primary mb-4">
      <span class="playfair-italic">Renvoyer</span>
      <br />l'instruction.
    </h1>
    <p class="font-body text-[15px] text-text-secondary mb-10 max-w-[420px]">
      Vous n'avez pas reçu l'email de confirmation&nbsp;? Nous le renvoyons immédiatement à l'adresse fournie.
    </p>

    <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "space-y-7", novalidate: true }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "Adresse email", class: "label-small block mb-3" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
            class: "input-vera",
            placeholder: "vous@domaine.fr" %>
      </div>

      <%= f.submit "Renvoyer la confirmation", class: "btn-vera-primary w-full cursor-pointer" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</section>
