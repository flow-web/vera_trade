<div class="min-h-[80vh] flex items-center justify-center py-12 px-4">
  <div class="max-w-md w-full">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold mb-2">Connexion</h1>
      <p class="text-base-content/60">
        Pas encore de compte ?
        <%= link_to "Créer un compte", new_registration_path(resource_name), class: "text-primary hover:underline" %>
      </p>
    </div>

    <div class="card-glass p-8">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <div class="form-control">
          <%= f.label :email, "Email", class: "label text-sm font-medium" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary",
              placeholder: "votre@email.com" %>
        </div>

        <div class="form-control">
          <%= f.label :password, "Mot de passe", class: "label text-sm font-medium" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "input input-bordered w-full bg-base-200/50 border-white/10 focus:border-primary",
              placeholder: "Votre mot de passe" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <label class="label cursor-pointer justify-start gap-3">
            <%= f.check_box :remember_me, class: "checkbox checkbox-primary checkbox-sm" %>
            <span class="label-text text-base-content/70">Se souvenir de moi</span>
          </label>
        <% end %>

        <%= f.submit "Se connecter", class: "btn btn-primary w-full cursor-pointer" %>
      <% end %>
    </div>

    <% if devise_mapping.recoverable? %>
      <p class="text-center mt-6">
        <%= link_to "Mot de passe oublié ?", new_password_path(resource_name), class: "text-sm text-base-content/50 hover:text-primary transition-colors" %>
      </p>
    <% end %>
  </div>
</div>
