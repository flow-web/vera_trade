<%#
  Connexion — Cinematic Archivist.
  Layout éditorial 2 colonnes : cover éditorial (wordmark deco + citation) à gauche,
  formulaire à droite. Mobile : formulaire centré, branding minimal.
%>
<% content_for :title, "Connexion — Vera Trade" %>

<section class="relative bg-bg-primary">
  <div class="max-w-[1600px] mx-auto lg:grid lg:grid-cols-12 lg:min-h-[calc(100vh-80px)]">

    <!-- Cover éditorial gauche (desktop only) -->
    <aside class="hidden lg:flex lg:col-span-5 relative border-r border-line px-10 py-20 flex-col justify-between overflow-hidden" aria-hidden="true">
      <span class="wordmark-deco absolute -left-6 top-1/4 text-[22rem] leading-[0.7]">V</span>

      <div class="relative z-10">
        <p class="eyebrow mb-8">Vera Trade — Édition N°001</p>
        <h2 class="font-display text-[56px] leading-[1.05] text-text-primary">
          <span class="playfair-italic">L'adresse</span> des
          <br />amateurs
          <br />de <span class="playfair-italic text-accent-red">vraies</span> voitures.
        </h2>
      </div>

      <div class="relative z-10 border-t border-line pt-8">
        <p class="font-body italic text-[15px] text-text-secondary leading-relaxed max-w-[340px] mb-6">
          «&nbsp;Une voiture qui n'a pas d'histoire n'est qu'un objet. Celles qui en ont une appartiennent à ceux qui savent l'entendre.&nbsp;»
        </p>
        <p class="label-micro">— Le Journal, éditorial d'ouverture</p>
      </div>
    </aside>

    <!-- Formulaire droite -->
    <div class="lg:col-span-7 flex items-start lg:items-center justify-center px-5 lg:px-16 py-16 lg:py-24">
      <div class="w-full max-w-[440px]">

        <p class="eyebrow mb-5">Espace membre</p>
        <h1 class="font-display text-[44px] lg:text-[56px] leading-[1.05] text-text-primary mb-3">
          <span class="playfair-italic">Bon retour</span>
          <br />parmi nous.
        </h1>
        <p class="font-body text-[15px] text-text-secondary mb-10">
          Pas encore de compte ?
          <%= link_to new_registration_path(resource_name), class: "text-text-primary border-b border-accent-red hover:text-accent-red transition-colors duration-300" do %>
            Créer un profil collectionneur
          <% end %>
        </p>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-7", novalidate: true }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div>
            <%= f.label :email, "Adresse email", class: "label-small block mb-3" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "input-vera",
                placeholder: "vous@domaine.fr" %>
          </div>

          <div>
            <div class="flex items-baseline justify-between mb-3">
              <%= f.label :password, "Mot de passe", class: "label-small" %>
              <% if devise_mapping.recoverable? %>
                <%= link_to "Oublié&nbsp;?".html_safe, new_password_path(resource_name),
                    class: "font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted hover:text-accent-red transition-colors" %>
              <% end %>
            </div>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "input-vera",
                placeholder: "••••••••" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <label class="flex items-center gap-3 cursor-pointer group">
              <%= f.check_box :remember_me, class: "peer sr-only" %>
              <span class="w-4 h-4 border border-line-strong flex items-center justify-center peer-checked:bg-accent-red peer-checked:border-accent-red transition-colors">
                <svg class="w-3 h-3 text-text-primary opacity-0 peer-checked:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              <span class="font-ui text-[11px] uppercase tracking-[0.15em] text-text-muted group-hover:text-text-secondary transition-colors">
                Rester connecté sur cet appareil
              </span>
            </label>
          <% end %>

          <%= f.submit "Se connecter", class: "btn-vera-primary w-full cursor-pointer" %>
        <% end %>

        <!-- Liens secondaires -->
        <div class="mt-10 pt-8 border-t border-line space-y-3">
          <% if devise_mapping.confirmable? %>
            <p>
              <%= link_to new_confirmation_path(resource_name),
                  class: "font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted hover:text-text-secondary transition-colors" do %>
                Email de confirmation non reçu&nbsp;?
              <% end %>
            </p>
          <% end %>
          <% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) %>
            <p>
              <%= link_to new_unlock_path(resource_name),
                  class: "font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted hover:text-text-secondary transition-colors" do %>
                Email de déverrouillage non reçu&nbsp;?
              <% end %>
            </p>
          <% end %>
        </div>

      </div>
    </div>
  </div>
</section>
