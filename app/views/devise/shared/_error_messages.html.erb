<%#
  Bloc d'erreurs Devise — Cinematic Archivist.
  Encart sombre, bordure Rosso Corsa, liste formatée éditoriale.
%>
<% if resource.errors.any? %>
  <div class="relative bg-bg-secondary border-l-2 border-l-accent-red border-t border-r border-b border-line p-5 mb-2" role="alert" data-turbo-cache="false">
    <div class="flex items-start gap-4">
      <svg class="w-4 h-4 mt-0.5 shrink-0 text-accent-red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <div class="flex-1">
        <p class="label-small text-accent-red mb-3">
          <%= pluralize(resource.errors.count, "erreur empêche", "erreurs empêchent") %> l'enregistrement
        </p>
        <ul class="space-y-1">
          <% resource.errors.full_messages.each do |msg| %>
            <li class="font-body text-[14px] text-text-secondary leading-relaxed">— <%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
<% end %>
