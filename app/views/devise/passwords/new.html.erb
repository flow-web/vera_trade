<%#
  Mot de passe oublié — Cinematic Archivist.
  Layout éditorial minimal, single colonne centrée avec wordmark deco discret.
%>
<% content_for :title, "Mot de passe oublié — Vera Trade" %>

<section class="relative bg-bg-primary overflow-hidden">
  <span aria-hidden="true" class="wordmark-deco absolute top-1/3 -left-10 text-[20rem] leading-[0.7] hidden lg:block">?</span>

  <div class="relative max-w-[520px] mx-auto px-5 lg:px-10 py-20 lg:py-32 min-h-[calc(100vh-80px)] flex flex-col justify-center">

    <p class="eyebrow mb-5">Réinitialisation</p>
    <h1 class="font-display text-[44px] lg:text-[56px] leading-[1.05] text-text-primary mb-4">
      <span class="playfair-italic">Mot de passe</span>
      <br />oublié.
    </h1>
    <p class="font-body text-[15px] text-text-secondary mb-10 max-w-[420px]">
      Indiquez votre adresse email. Nous vous enverrons un lien pour définir un nouveau mot de passe.
    </p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-7", novalidate: true }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "Adresse email", class: "label-small block mb-3" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "input-vera",
            placeholder: "vous@domaine.fr" %>
      </div>

      <%= f.submit "Envoyer le lien de réinitialisation", class: "btn-vera-primary w-full cursor-pointer" %>
    <% end %>

    <div class="mt-12 pt-8 border-t border-line">
      <%= link_to new_session_path(resource_name),
          class: "font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted hover:text-text-secondary transition-colors inline-flex items-center gap-2" do %>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Retour à la connexion
      <% end %>
    </div>
  </div>
</section>
