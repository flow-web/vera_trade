<%#
  Réinitialisation du mot de passe — Cinematic Archivist.
  Atterrissage depuis l'email de reset. Token caché, 2 champs password + confirmation.
%>
<% content_for :title, "Nouveau mot de passe — Vera Trade" %>

<section class="relative bg-bg-primary overflow-hidden">
  <span aria-hidden="true" class="wordmark-deco absolute top-1/3 -right-10 text-[20rem] leading-[0.7] hidden lg:block">↻</span>

  <div class="relative max-w-[520px] mx-auto px-5 lg:px-10 py-20 lg:py-32 min-h-[calc(100vh-80px)] flex flex-col justify-center">

    <p class="eyebrow mb-5">Nouveau mot de passe</p>
    <h1 class="font-display text-[44px] lg:text-[56px] leading-[1.05] text-text-primary mb-4">
      <span class="playfair-italic">Redéfinissez</span>
      <br />votre accès.
    </h1>
    <p class="font-body text-[15px] text-text-secondary mb-10 max-w-[420px]">
      Choisissez un nouveau mot de passe. Il remplacera immédiatement l'ancien.
    </p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-7", novalidate: true }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div>
        <div class="flex items-baseline justify-between mb-3">
          <%= f.label :password, "Nouveau mot de passe", class: "label-small" %>
          <% if @minimum_password_length %>
            <span class="font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted">
              <%= @minimum_password_length %> car. min.
            </span>
          <% end %>
        </div>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
            class: "input-vera",
            placeholder: "••••••••" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmer le nouveau mot de passe", class: "label-small block mb-3" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "input-vera",
            placeholder: "••••••••" %>
      </div>

      <%= f.submit "Définir le nouveau mot de passe", class: "btn-vera-primary w-full cursor-pointer" %>
    <% end %>

    <div class="mt-12 pt-8 border-t border-line">
      <%= link_to new_session_path(resource_name),
          class: "font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted hover:text-text-secondary transition-colors inline-flex items-center gap-2" do %>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Retour à la connexion
      <% end %>
    </div>
  </div>
</section>
