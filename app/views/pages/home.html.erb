<% content_for(:title) { "Vera Trade — Le magazine des voitures qui ont une âme" } %>
<% content_for(:description) { "Youngtimers, voitures de collection et préparations. Marketplace éditoriale française. Chaque annonce, une histoire. Chaque châssis, un Rust Map." } %>

<%# ========================================================================
    HERO — featured listing ou état vide éditorial
    ======================================================================== %>
<section class="relative">
  <% if @featured_listing %>
    <% fv = @featured_listing.vehicle %>
    <div class="relative w-full aspect-[21/9] min-h-[520px] overflow-hidden bg-bg-secondary">
      <% if @featured_listing.photos.attached? %>
        <%= image_tag @featured_listing.photos.first,
              class: "absolute inset-0 w-full h-full object-cover grayscale-[10%]",
              alt: @featured_listing.title, loading: "eager", fetchpriority: "high" %>
      <% end %>
      <!-- Gradient bas pour lisibilité -->
      <div class="absolute inset-0 bg-gradient-to-t from-bg-primary via-bg-primary/30 to-transparent"></div>
      <!-- Gradient gauche subtil -->
      <div class="absolute inset-0 bg-gradient-to-r from-bg-primary/50 via-transparent to-transparent"></div>

      <!-- Bloc titre hero -->
      <div class="absolute inset-x-0 bottom-0">
        <div class="max-w-[1600px] mx-auto px-5 lg:px-10 pb-12 lg:pb-20">
          <div class="eyebrow text-accent-red mb-4">
            Annonce en vedette · <%= listing_reference(@featured_listing) %>
          </div>
          <h1 class="playfair-italic text-5xl sm:text-6xl md:text-7xl lg:text-[96px] text-text-primary leading-[0.95] tracking-[-0.02em] max-w-5xl mb-6 lg:mb-8">
            <%= @featured_listing.title %>
          </h1>
          <% if @featured_listing.description.present? %>
            <p class="font-body italic text-lg md:text-xl text-text-secondary leading-relaxed max-w-2xl mb-8">
              <%= @featured_listing.description.to_s.truncate(180) %>
            </p>
          <% end %>
          <div class="flex flex-wrap items-end gap-x-8 gap-y-4">
            <div class="font-mono text-3xl md:text-4xl lg:text-[42px] text-accent-red font-medium">
              <%= listing_price_fr(fv) %>
            </div>
            <% if listing_location_tag(@featured_listing) %>
              <div class="font-ui text-[10px] uppercase tracking-[0.2em] text-text-muted pb-2">
                <%= listing_location_tag(@featured_listing) %>
              </div>
            <% end %>
          </div>
          <div class="mt-10 flex flex-wrap items-center gap-4">
            <%= link_to "Voir l'annonce", @featured_listing, class: "btn-vera-primary" %>
            <%= link_to "Tout le catalogue", listings_path, class: "btn-vera-secondary" %>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <!-- État vide éditorial — catalogue vide -->
    <div class="relative w-full min-h-[60vh] flex items-center justify-center border-b border-line">
      <div class="max-w-3xl mx-auto text-center px-5 py-20">
        <div class="eyebrow mb-6">Bientôt en ligne</div>
        <h1 class="playfair-italic text-5xl md:text-7xl text-text-primary leading-[0.95] tracking-[-0.02em] mb-8">
          Le catalogue est en cours d'assemblage.
        </h1>
        <p class="font-body italic text-lg text-text-secondary leading-relaxed mb-10 max-w-xl mx-auto">
          Nos archivistes réunissent en ce moment la première sélection de youngtimers et véhicules de collection. Revenez dans quelques jours, ou publiez vous-même la première annonce.
        </p>
        <% if user_signed_in? %>
          <%= link_to "Publier une annonce", new_listing_wizard_path, class: "btn-vera-primary" %>
        <% else %>
          <%= link_to "Créer un compte vendeur", new_user_registration_path, class: "btn-vera-primary" %>
        <% end %>
      </div>
    </div>
  <% end %>
</section>

<%# ========================================================================
    MANIFESTE — pull quote éditorial
    ======================================================================== %>
<section class="py-24 lg:py-40 bg-bg-secondary border-y border-line">
  <div class="max-w-4xl mx-auto px-5 lg:px-10 text-center">
    <div class="eyebrow mb-8">Manifeste</div>
    <blockquote class="playfair-italic text-3xl md:text-4xl lg:text-[44px] text-text-primary leading-[1.25] tracking-[-0.01em]">
      « Vera Trade n'est pas une marketplace. C'est un magazine automobile qui vend des voitures qui ont une âme. »
    </blockquote>
    <div class="mt-10 flex items-center justify-center gap-6">
      <div class="h-px w-12 bg-accent-red"></div>
      <span class="font-ui text-[10px] uppercase tracking-[0.3em] text-text-muted">L'Équipe Vera</span>
      <div class="h-px w-12 bg-accent-red"></div>
    </div>
  </div>
</section>

<%# ========================================================================
    LA SÉLECTION — curated inventory en grid bento asymétrique
    ======================================================================== %>
<% if @curated_listings.any? %>
  <section class="py-24 lg:py-32">
    <div class="max-w-[1600px] mx-auto px-5 lg:px-10">
      <%= render "components/section_header",
            eyebrow: "La Sélection de la rédaction",
            title: "Le catalogue du moment.",
            link_to_: listings_path,
            link_label: "Tout le catalogue (#{@listings_count})" %>

      <div class="grid grid-cols-12 gap-8 lg:gap-12">
        <% curated = @curated_listings.to_a %>

        <!-- Grand feature : col-span-8 -->
        <% if curated[0] %>
          <div class="col-span-12 lg:col-span-8">
            <%= render "components/listing_card", listing: curated[0], size: :large %>
          </div>
        <% end %>

        <!-- Sidebar vertical : col-span-4 -->
        <% if curated[1] %>
          <div class="col-span-12 lg:col-span-4">
            <%= render "components/listing_card", listing: curated[1], size: :medium %>
          </div>
        <% end %>

        <!-- Bottom row : 2 cards col-span-6 -->
        <% if curated[2] %>
          <div class="col-span-12 md:col-span-6">
            <%= render "components/listing_card", listing: curated[2], size: :medium %>
          </div>
        <% end %>
        <% if curated[3] %>
          <div class="col-span-12 md:col-span-6">
            <%= render "components/listing_card", listing: curated[3], size: :medium %>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# ========================================================================
    LE JOURNAL — preview éditoriale (placeholder disabled)
    ======================================================================== %>
<section class="py-24 lg:py-32 bg-bg-secondary border-y border-line">
  <div class="max-w-[1600px] mx-auto px-5 lg:px-10">
    <div class="grid grid-cols-12 gap-8 lg:gap-16 items-center">
      <div class="col-span-12 lg:col-span-5">
        <div class="relative aspect-[4/5] bg-bg-tertiary border border-line overflow-hidden">
          <!-- Placeholder visuel — motif subtil typographique -->
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="playfair-italic text-[14rem] lg:text-[18rem] text-text-primary/[0.03] leading-none select-none">Journal</span>
          </div>
          <div class="absolute bottom-6 left-6 right-6">
            <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-text-muted">
              Premier numéro · Printemps 2026
            </div>
          </div>
        </div>
      </div>

      <div class="col-span-12 lg:col-span-7">
        <%= render "components/editorial_card",
              eyebrow: "Le Journal",
              title: "Pourquoi une E30 M3 coûte désormais le prix d'une maison en province.",
              excerpt: "Trente ans après sa sortie, l'icône de Munich continue d'affoler les compteurs. Notre analyse sur le marché des youngtimers allemands, entre passion sincère et spéculation assumée.",
              disabled: true %>
      </div>
    </div>
  </div>
</section>

<%# ========================================================================
    CATÉGORIES — 3 tuiles éditoriales
    ======================================================================== %>
<section class="py-24 lg:py-32">
  <div class="max-w-[1600px] mx-auto px-5 lg:px-10">
    <%= render "components/section_header",
          eyebrow: "Les Segments",
          title: "Choisissez votre chapitre." %>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      <%= render "components/category_tile",
            subtitle: "JDM · Années 80–90",
            title: "Youngtimers Japonais",
            query: "Honda" %>

      <%= render "components/category_tile",
            subtitle: "Europe · 1975–2000",
            title: "Icônes Européennes",
            query: "BMW" %>

      <%= render "components/category_tile",
            subtitle: "Rallye & Compétition",
            title: "Préparations Réglées",
            query: "Lancia" %>
    </div>
  </div>
</section>

<%# ========================================================================
    SIGNATURE VERA — 4 trust indicators
    ======================================================================== %>
<section class="py-24 lg:py-32 bg-bg-secondary border-y border-line">
  <div class="max-w-[1600px] mx-auto px-5 lg:px-10">
    <div class="max-w-3xl mb-16 lg:mb-20">
      <div class="eyebrow mb-4">La Signature Vera</div>
      <h2 class="playfair-italic text-4xl md:text-5xl lg:text-6xl text-text-primary leading-[1.05] tracking-[-0.015em]">
        Ce que vous ne trouverez nulle part ailleurs.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16">
      <%= render "components/trust_indicator",
            icon_name: :rust_map,
            title: "Rust Map",
            body: "Cartographie interactive de la corrosion, zone par zone. Inspection rigoureuse des soubassements et historique climatique complet du châssis." %>

      <%= render "components/trust_indicator",
            icon_name: :experts,
            title: "Archivistes Vera",
            body: "Chaque annonce relue par nos spécialistes : originalité mécanique, cohérence historique, authenticité des documents." %>

      <%= render "components/trust_indicator",
            icon_name: :provenance,
            title: "Provenance Ledger",
            body: "Une timeline vérifiée des propriétaires successifs, entretiens, restaurations et événements notables. La mémoire du véhicule." %>

      <%= render "components/trust_indicator",
            icon_name: :escrow,
            title: "Paiement Séquestré",
            body: "Transactions via compte séquestre dédié. Les fonds ne quittent pas votre compte tant que le véhicule n'est pas livré." %>
    </div>
  </div>
</section>

<%# ========================================================================
    CTA FINAL — vendeur
    ======================================================================== %>
<section class="py-28 lg:py-40">
  <div class="max-w-[1600px] mx-auto px-5 lg:px-10">
    <div class="grid grid-cols-12 gap-8 items-center">
      <div class="col-span-12 lg:col-span-7">
        <div class="eyebrow mb-4">Vous vendez</div>
        <h2 class="playfair-italic text-4xl md:text-5xl lg:text-[64px] text-text-primary leading-[1.05] tracking-[-0.015em] mb-8">
          Votre voiture mérite un récit, pas une fiche produit.
        </h2>
        <p class="font-body text-base lg:text-lg text-text-secondary leading-relaxed max-w-2xl mb-10">
          Publiez votre youngtimer, votre collection ou votre préparation sur Vera Trade. Nous fournissons le Rust Map, le Provenance Ledger et l'accompagnement éditorial. Vous gardez la main sur votre prix et vos échanges.
        </p>
        <div class="flex flex-wrap items-center gap-4">
          <%= link_to (user_signed_in? ? "Publier une annonce" : "Créer un compte vendeur"),
                (user_signed_in? ? new_listing_wizard_path : new_user_registration_path),
                class: "btn-vera-primary" %>
          <%= link_to "Parcourir le catalogue", listings_path, class: "btn-vera-secondary" %>
        </div>
      </div>

      <div class="hidden lg:block col-span-5">
        <!-- Bloc décoratif typographique -->
        <div class="relative aspect-square border border-line bg-bg-secondary flex flex-col items-center justify-center">
          <span class="playfair-italic text-[8rem] text-accent-red leading-none">V</span>
          <span class="font-ui text-[10px] uppercase tracking-[0.4em] text-text-muted mt-6">
            Vera Trade
          </span>
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted mt-2">
            Est. 2026
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
