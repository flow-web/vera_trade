<div class="max-w-[1440px] mx-auto px-5 md:px-10 py-16 md:py-24">
  <%# Header — editorial %>
  <div class="mb-16 md:mb-24 max-w-3xl">
    <div class="font-ui text-[11px] font-semibold uppercase tracking-[0.22em] text-accent-red mb-5">
      Services
    </div>
    <h1 class="font-display playfair-italic text-5xl md:text-7xl text-text-primary leading-[0.96] tracking-[-0.015em] mb-5">
      Nos engagements
    </h1>
    <p class="font-body italic text-lg text-text-secondary leading-relaxed max-w-xl">
      Des solutions complètes pour sécuriser, financer et entretenir votre véhicule de collection.
    </p>
  </div>

  <%# Services grid %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-line">
    <%# Service 1 — Inspection %>
    <div class="bg-bg-primary p-8 md:p-10">
      <div class="w-12 h-12 flex items-center justify-center border border-accent-red mb-8">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" class="text-accent-red">
          <path d="M12 3 4 6v6c0 5 3.5 8 8 9 4.5-1 8-4 8-9V6z"/>
        </svg>
      </div>
      <div class="font-ui text-[11px] font-semibold uppercase tracking-[0.22em] text-accent-red mb-3">01</div>
      <h2 class="font-display playfair-italic text-2xl text-text-primary mb-4">Inspection complète</h2>
      <p class="font-body text-sm text-text-secondary leading-relaxed mb-6">
        Un examen approfondi de 148 points pour garantir la qualité et l'authenticité de votre véhicule.
      </p>
      <ul class="space-y-3">
        <% ["Vérification mécanique", "Diagnostic électronique", "Rapport détaillé PDF"].each do |item| %>
          <li class="flex items-center gap-3 font-ui text-xs text-text-secondary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" class="text-patina shrink-0"><path d="m5 12 5 5 10-10"/></svg>
            <%= item %>
          </li>
        <% end %>
      </ul>
    </div>

    <%# Service 2 — Financement %>
    <div class="bg-bg-primary p-8 md:p-10">
      <div class="w-12 h-12 flex items-center justify-center border border-accent-red mb-8">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" class="text-accent-red">
          <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
        </svg>
      </div>
      <div class="font-ui text-[11px] font-semibold uppercase tracking-[0.22em] text-accent-red mb-3">02</div>
      <h2 class="font-display playfair-italic text-2xl text-text-primary mb-4">Paiement sécurisé</h2>
      <p class="font-body text-sm text-text-secondary leading-relaxed mb-6">
        Des solutions de paiement séquestre adaptées aux transactions de véhicules de collection.
      </p>
      <ul class="space-y-3">
        <% ["Escrow sécurisé Stripe", "Paiement en plusieurs fois", "Simulation gratuite"].each do |item| %>
          <li class="flex items-center gap-3 font-ui text-xs text-text-secondary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" class="text-patina shrink-0"><path d="m5 12 5 5 10-10"/></svg>
            <%= item %>
          </li>
        <% end %>
      </ul>
    </div>

    <%# Service 3 — Logistique %>
    <div class="bg-bg-primary p-8 md:p-10">
      <div class="w-12 h-12 flex items-center justify-center border border-accent-red mb-8">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" class="text-accent-red">
          <path d="M3 6l6-2 6 2 6-2v14l-6 2-6-2-6 2z"/><path d="M9 4v16M15 6v16"/>
        </svg>
      </div>
      <div class="font-ui text-[11px] font-semibold uppercase tracking-[0.22em] text-accent-red mb-3">03</div>
      <h2 class="font-display playfair-italic text-2xl text-text-primary mb-4">Logistique</h2>
      <p class="font-body text-sm text-text-secondary leading-relaxed mb-6">
        Transport sur plateau et livraison porte-à-porte dans toute l'Europe.
      </p>
      <ul class="space-y-3">
        <% ["Transport sur plateau fermé", "Assurance tous risques", "Suivi en temps réel"].each do |item| %>
          <li class="flex items-center gap-3 font-ui text-xs text-text-secondary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" class="text-patina shrink-0"><path d="m5 12 5 5 10-10"/></svg>
            <%= item %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <%# CTA %>
  <div class="mt-20 border border-line bg-bg-secondary p-10 md:p-16 text-center">
    <div class="font-ui text-[11px] font-semibold uppercase tracking-[0.22em] text-accent-red mb-4">
      Accompagnement
    </div>
    <h2 class="font-display playfair-italic text-3xl md:text-4xl text-text-primary mb-4">
      Besoin de conseils ?
    </h2>
    <p class="font-body text-text-secondary max-w-md mx-auto mb-8">
      Notre équipe d'experts est à votre disposition pour vous accompagner dans chaque étape de votre projet.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="mailto:contact@veratrade.fr" class="btn-vera-primary text-[11px] px-6 py-3">
        Nous contacter
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</div>
