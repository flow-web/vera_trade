<div class="container mx-auto px-4 py-8 max-w-4xl">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Ouvrir un Litige</h1>
    <p class="text-gray-600 mt-2">Décrivez votre problème de manière détaillée pour une résolution rapide</p>
  </div>

  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <%= form_with model: @dispute, local: true, multipart: true, class: "space-y-6" do |form| %>
        <% if @dispute.errors.any? %>
          <div class="alert alert-error">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <h3 class="font-bold">Erreurs dans le formulaire :</h3>
              <ul class="list-disc list-inside">
                <% @dispute.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>

        <!-- Hidden fields for disputed item -->
        <%= hidden_field_tag :disputed_item_type, params[:disputed_item_type] %>
        <%= hidden_field_tag :disputed_item_id, params[:disputed_item_id] %>

        <!-- Disputed Item Info -->
        <% if @disputed_item %>
          <div class="alert alert-info">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <h3 class="font-bold">Objet du litige :</h3>
              <p>
                <% if @disputed_item.is_a?(Listing) %>
                  Annonce : <%= @disputed_item.title %>
                <% elsif @disputed_item.is_a?(ServiceBooking) %>
                  Réservation de service : <%= @disputed_item.service_offer&.title %>
                <% end %>
              </p>
            </div>
          </div>
        <% end %>

        <!-- Basic Information -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="form-control">
            <%= form.label :dispute_type, "Type de litige", class: "label" %>
            <%= form.select :dispute_type, 
                options_for_select([
                  ['Sélectionnez un type', ''],
                  *Dispute::DISPUTE_TYPES.map { |k, v| [v, k] }
                ], @dispute.dispute_type), 
                {}, 
                { class: "select select-bordered", required: true } %>
            <label class="label">
              <span class="label-text-alt">Choisissez le type qui correspond le mieux à votre problème</span>
            </label>
          </div>

          <div class="form-control">
            <%= form.label :priority, "Priorité", class: "label" %>
            <%= form.select :priority, 
                options_for_select([
                  *Dispute::PRIORITIES.map { |k, v| [v, k] }
                ], @dispute.priority || 'normal'), 
                {}, 
                { class: "select select-bordered" } %>
            <label class="label">
              <span class="label-text-alt">Urgent pour les problèmes nécessitant une attention immédiate</span>
            </label>
          </div>
        </div>

        <!-- Title -->
        <div class="form-control">
          <%= form.label :title, "Titre du litige", class: "label" %>
          <%= form.text_field :title, 
              class: "input input-bordered", 
              placeholder: "Résumez votre problème en quelques mots",
              required: true %>
          <label class="label">
            <span class="label-text-alt">Minimum 10 caractères, maximum 200</span>
          </label>
        </div>

        <!-- Description -->
        <div class="form-control">
          <%= form.label :description, "Description détaillée", class: "label" %>
          <%= form.text_area :description, 
              class: "textarea textarea-bordered h-32", 
              placeholder: "Décrivez votre problème en détail : que s'est-il passé ? Quand ? Quelles sont vos attentes ?",
              required: true %>
          <label class="label">
            <span class="label-text-alt">Minimum 20 caractères. Plus vous êtes précis, plus la résolution sera rapide.</span>
          </label>
        </div>

        <!-- Amount -->
        <div class="form-control">
          <%= form.label :amount, "Montant en jeu (optionnel)", class: "label" %>
          <div class="input-group">
            <%= form.number_field :amount, 
                class: "input input-bordered flex-1", 
                placeholder: "0.00",
                step: 0.01,
                min: 0 %>
            <span class="bg-base-200 px-3 flex items-center">€</span>
          </div>
          <label class="label">
            <span class="label-text-alt">Montant financier concerné par le litige</span>
          </label>
        </div>

        <!-- Attachments -->
        <div class="form-control">
          <%= form.label :attachments, "Pièces jointes (optionnel)", class: "label" %>
          <%= form.file_field :attachments, 
              multiple: true,
              accept: "image/*,application/pdf,.doc,.docx",
              class: "file-input file-input-bordered" %>
          <label class="label">
            <span class="label-text-alt">Images, PDF, documents Word acceptés. Maximum 5 fichiers de 10MB chacun.</span>
          </label>
        </div>

        <!-- Guidelines -->
        <div class="alert alert-warning">
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
          <div>
            <h3 class="font-bold">Conseils pour une résolution rapide :</h3>
            <ul class="list-disc list-inside text-sm mt-2">
              <li>Soyez factuel et objectif dans votre description</li>
              <li>Joignez toutes les preuves pertinentes (captures d'écran, photos, emails)</li>
              <li>Mentionnez les tentatives de résolution déjà effectuées</li>
              <li>Restez respectueux dans vos échanges</li>
            </ul>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex justify-between items-center pt-6">
          <%= link_to "Annuler", disputes_path, class: "btn btn-ghost" %>
          <div class="flex gap-3">
            <%= form.submit "Créer le litige", class: "btn btn-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  // Auto-resize textarea
  document.addEventListener('DOMContentLoaded', function() {
    const textarea = document.querySelector('textarea[name="dispute[description]"]');
    if (textarea) {
      textarea.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = this.scrollHeight + 'px';
      });
    }
  });
</script>
