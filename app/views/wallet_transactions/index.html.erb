<div class="container mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold">Historique des transactions</h1>
    <div class="text-right">
      <p class="text-sm opacity-80">Solde actuel</p>
      <p class="text-2xl font-bold"><%= number_to_currency(current_user.wallet.balance) %></p>
    </div>
  </div>

  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <div class="overflow-x-auto">
        <table class="table w-full">
          <thead>
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>Description</th>
              <th class="text-right">Montant</th>
            </tr>
          </thead>
          <tbody>
            <% @transactions.each do |transaction| %>
              <div class="hover:bg-base-200">
                <tr class="cursor-pointer" data-controller="turbo-frame" data-action="click->turbo-frame#visit" data-turbo-frame-target="<%= wallet_transaction_path(transaction) %>">
                  <td><%= l transaction.created_at, format: :short %></td>
                  <td>
                    <span class="badge <%= transaction_type_badge_class(transaction) %>">
                      <%= transaction.transaction_type %>
                    </span>
                  </td>
                  <td><%= transaction.description %></td>
                  <td class="text-right font-medium <%= transaction.amount.positive? ? 'text-success' : 'text-error' %>">
                    <%= transaction.amount.positive? ? '+' : '' %><%= number_to_currency(transaction.amount) %>
                  </td>
                </tr>
              </div>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="mt-4">
        <%= paginate @transactions %>
      </div>
    </div>
  </div>
</div>
