<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nouveau message — Vera Trade</title>
    <style>
      body { margin: 0; padding: 0; background: #0d0d0d; font-family: Georgia, 'Times New Roman', serif; }
      .wrapper { max-width: 600px; margin: 0 auto; background: #141414; }
      .header { padding: 32px 40px 24px; border-bottom: 1px solid #2a2a2a; }
      .logo { font-family: Georgia, serif; font-size: 22px; font-weight: normal; color: #f5f0e8; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; }
      .logo span { color: #dc2626; }
      .body { padding: 40px; }
      .greeting { font-size: 14px; color: #8a8a8a; margin: 0 0 24px; font-family: Arial, sans-serif; }
      .headline { font-size: 24px; color: #f5f0e8; line-height: 1.3; margin: 0 0 8px; font-weight: normal; }
      .meta { font-size: 13px; color: #8a8a8a; font-family: Arial, sans-serif; margin: 0 0 32px; }
      .meta strong { color: #b0a898; }
      .preview-box { background: #1e1e1e; border-left: 3px solid #dc2626; padding: 20px 24px; margin: 0 0 36px; border-radius: 0 4px 4px 0; }
      .preview-text { font-size: 15px; color: #c8c0b4; line-height: 1.6; margin: 0; font-style: italic; }
      .cta-wrap { text-align: center; margin: 0 0 40px; }
      .cta { display: inline-block; background: #dc2626; color: #ffffff; text-decoration: none; font-family: Arial, sans-serif; font-size: 14px; font-weight: bold; letter-spacing: 0.06em; text-transform: uppercase; padding: 14px 36px; border-radius: 2px; }
      .footer { padding: 24px 40px; border-top: 1px solid #1e1e1e; }
      .footer p { font-size: 11px; color: #4a4a4a; font-family: Arial, sans-serif; margin: 0; line-height: 1.6; }
      .footer a { color: #6a6a6a; }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="header">
        <a href="<%= root_url %>" class="logo">Vera<span>Trade</span></a>
      </div>

      <div class="body">
        <p class="greeting">Bonjour <%= @recipient.display_name %>,</p>

        <h1 class="headline">Vous avez un nouveau message</h1>

        <p class="meta">
          De <strong><%= @sender.display_name %></strong>
          <% if @listing %>
            &nbsp;·&nbsp; Annonce : <strong><%= @listing.title %></strong>
          <% end %>
        </p>

        <div class="preview-box">
          <p class="preview-text">"<%= truncate(@message.content, length: 280) %>"</p>
        </div>

        <% if @message.offer? %>
          <p style="font-family: Arial, sans-serif; font-size: 14px; color: #b0a898; text-align: center; margin: -16px 0 32px;">
            💶 Offre jointe : <strong style="color: #f5f0e8;"><%= number_to_currency(@message.offer_euros, unit: "€", format: "%n %u") %></strong>
          </p>
        <% end %>

        <div class="cta-wrap">
          <a href="<%= @conversation_url %>" class="cta">Répondre</a>
        </div>
      </div>

      <div class="footer">
        <p>
          Vous recevez cet e-mail car vous êtes membre de Vera Trade.<br>
          <a href="<%= root_url %>">veratrade.fr</a> &nbsp;·&nbsp; Ce message est envoyé automatiquement, ne pas répondre directement.
        </p>
      </div>
    </div>
  </body>
</html>
