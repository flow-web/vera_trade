<% content_for(:title) { "Admin — Vérification KYC — Vera Trade" } %>

<div class="max-w-5xl mx-auto px-5 lg:px-10 py-20">

  <div class="eyebrow mb-3 text-accent-red">Administration</div>
  <h1 class="playfair-italic text-4xl text-text-primary leading-tight mb-12">
    Vérification KYC.
  </h1>

  <%# PENDING DOCUMENTS %>
  <section class="mb-16">
    <h2 class="label-small text-accent-red mb-6">En attente (<%= @pending.count %>)</h2>

    <% if @pending.any? %>
      <div class="space-y-4">
        <% @pending.each do |doc| %>
          <div class="border border-line bg-bg-secondary p-6">
            <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
              <div>
                <div class="font-ui text-[11px] uppercase tracking-[0.15em] text-text-primary mb-1">
                  <%= doc.user.display_name %> · <%= doc.user.email %>
                </div>
                <div class="font-mono text-[10px] text-text-muted">
                  <%= { "identity_card" => "Pièce d'identité", "passport" => "Passeport", "driver_license" => "Permis", "proof_of_address" => "Justificatif de domicile" }[doc.document_type] %>
                  · Envoyé <%= time_ago_in_words(doc.created_at) %>
                </div>
              </div>
              <% if doc.file.attached? %>
                <%= link_to "Voir le document", url_for(doc.file), target: "_blank", class: "btn-vera-secondary text-[10px] px-4 py-2" %>
              <% end %>
            </div>

            <div class="flex flex-wrap gap-3">
              <%= button_to "Approuver", approve_admin_kyc_path(doc), method: :patch, class: "btn-vera-primary text-[10px] px-5 py-2" %>

              <%= form_with url: reject_admin_kyc_path(doc), method: :patch, class: "flex items-center gap-2" do %>
                <input type="text" name="rejection_reason" placeholder="Motif de refus…" class="input-vera text-[13px] py-2 px-3 w-48" required>
                <button type="submit" class="btn-vera-secondary text-[10px] px-5 py-2 border-accent-red text-accent-red hover:bg-accent-red hover:text-text-primary">
                  Refuser
                </button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="border border-line bg-bg-secondary p-8 text-center">
        <p class="font-body italic text-sm text-text-muted">Aucun document en attente de vérification.</p>
      </div>
    <% end %>
  </section>

  <%# RECENT DECISIONS %>
  <section>
    <h2 class="label-small text-text-muted mb-6">Décisions récentes</h2>
    <% if @recent.any? %>
      <div class="space-y-3">
        <% @recent.each do |doc| %>
          <div class="border-t border-line py-4 flex flex-wrap items-center justify-between gap-4">
            <div>
              <span class="font-ui text-[11px] uppercase tracking-[0.15em] text-text-primary">
                <%= doc.user.display_name %>
              </span>
              <span class="font-mono text-[10px] text-text-muted ml-2">
                <%= { "identity_card" => "ID", "passport" => "PP", "driver_license" => "PC", "proof_of_address" => "AD" }[doc.document_type] %>
              </span>
            </div>
            <div class="flex items-center gap-3">
              <% if doc.approved? %>
                <span class="badge-vera badge-vera-matching">Approuvé</span>
              <% else %>
                <span class="badge-vera badge-vera-red" title="<%= doc.rejection_reason %>">Refusé</span>
              <% end %>
              <span class="font-mono text-[10px] text-text-muted">
                <%= doc.reviewed_at ? time_ago_in_words(doc.reviewed_at) : "—" %>
                <% if doc.reviewer %> · <%= doc.reviewer.display_name %><% end %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="font-body italic text-sm text-text-muted">Aucune décision récente.</p>
    <% end %>
  </section>
</div>
