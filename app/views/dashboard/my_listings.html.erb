<div class="mb-6">
  <h1 class="font-poppins text-2xl font-semibold text-[#0C1E3B]">Mes Annonces</h1>
  <p class="text-[#1A1A1A]">Gérez vos annonces automobiles</p>
</div>

<!-- Actions -->
<div class="flex justify-between items-center mb-6">
  <div>
    <h3 class="font-poppins text-lg font-medium"><span class="text-[#B18B43]"><%= @listings.count %></span> annonces</h3>
  </div>
  
  <div>
    <a href="<%= new_listing_path %>" class="btn bg-[#B18B43] hover:bg-[#A0782D] text-white border-none">
      <i class="bi bi-plus-lg mr-2"></i> Publier une annonce
    </a>
  </div>
</div>

<!-- Listings -->
<% if @listings.any? %>
  <div class="grid grid-cols-1 gap-4">
    <% @listings.each do |listing| %>
      <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="flex flex-col md:flex-row">
          <!-- Image -->
          <div class="w-full md:w-1/4 h-48 md:h-auto">
            <% if listing.main_photo&.file.present? %>
              <%= image_tag listing.main_photo.file, class: "w-full h-full object-cover" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center bg-[#D9D9D9]">
                <i class="bi bi-image text-[#0C1E3B] text-4xl"></i>
              </div>
            <% end %>
          </div>
          
          <!-- Content -->
          <div class="flex-1 p-4 flex flex-col">
            <div class="flex flex-col md:flex-row justify-between">
              <div>
                <h3 class="font-poppins font-medium text-[#0C1E3B] text-lg mb-1"><%= listing.title %></h3>
                <p class="text-sm text-[#1A1A1A] opacity-75 mb-3"><%= listing.vehicle.make %> <%= listing.vehicle.model %> - <%= listing.vehicle.year %></p>
                
                <!-- Status -->
                <div class="flex items-center mb-4">
                  <span class="px-3 py-1 rounded-full text-xs font-medium 
                        <%= listing_status_color(listing.status) %>">
                    <%= listing.status.humanize %>
                  </span>
                  
                  <% if listing.certified? %>
                    <span class="ml-2 px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800 flex items-center">
                      <i class="bi bi-patch-check-fill mr-1"></i> Certifié
                    </span>
                  <% end %>
                </div>
              </div>
              
              <div class="md:text-right">
                <p class="text-xl font-semibold text-[#B18B43]">
                  <%= number_to_currency(listing.vehicle.price, precision: 0, unit: "€", delimiter: " ") %>
                </p>
                <p class="text-xs text-[#1A1A1A] opacity-75 mb-4">
                  Publié le <%= l listing.created_at.to_date, format: :long %>
                </p>
              </div>
            </div>
            
            <!-- Specs -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-4">
              <div class="flex items-center text-sm text-[#1A1A1A]">
                <i class="bi bi-speedometer2 text-[#B18B43] mr-1"></i>
                <%= number_with_delimiter(listing.vehicle.mileage) %> km
              </div>
              <div class="flex items-center text-sm text-[#1A1A1A]">
                <i class="bi bi-fuel-pump text-[#B18B43] mr-1"></i>
                <%= listing.vehicle.fuel_type %>
              </div>
              <div class="flex items-center text-sm text-[#1A1A1A]">
                <i class="bi bi-gear-wide-connected text-[#B18B43] mr-1"></i>
                <%= listing.vehicle.transmission %>
              </div>
              <div class="flex items-center text-sm text-[#1A1A1A]">
                <i class="bi bi-eye text-[#B18B43] mr-1"></i>
                <%= rand(10..500) %> vues
              </div>
            </div>
            
            <!-- Actions -->
            <div class="flex flex-wrap gap-2 mt-auto">
              <%= link_to listing_path(listing), class: "btn btn-sm bg-[#F2E8D8] hover:bg-[#D9D9D9] border-none text-[#0C1E3B]" do %>
                <i class="bi bi-eye mr-1"></i> Voir
              <% end %>
              
              <%= link_to edit_listing_path(listing), class: "btn btn-sm bg-[#F2E8D8] hover:bg-[#D9D9D9] border-none text-[#0C1E3B]" do %>
                <i class="bi bi-pencil mr-1"></i> Modifier
              <% end %>
              
              <% if listing.status == 'active' %>
                <%= button_to listing_path(listing, listing: { status: 'archived' }), 
                            method: :patch, 
                            form: { data: { turbo_confirm: "Êtes-vous sûr de vouloir archiver cette annonce ?" } },
                            class: "btn btn-sm bg-[#F2E8D8] hover:bg-[#D9D9D9] border-none text-[#0C1E3B]" do %>
                  <i class="bi bi-archive mr-1"></i> Archiver
                <% end %>
              <% elsif listing.status == 'archived' %>
                <%= button_to listing_path(listing, listing: { status: 'active' }), 
                            method: :patch,
                            class: "btn btn-sm bg-[#F2E8D8] hover:bg-[#D9D9D9] border-none text-[#0C1E3B]" do %>
                  <i class="bi bi-arrow-up-circle mr-1"></i> Republier
                <% end %>
              <% end %>
              
              <%= button_to listing_path(listing), 
                          method: :delete, 
                          form: { data: { turbo_confirm: "Êtes-vous sûr de vouloir supprimer définitivement cette annonce ?" } },
                          class: "btn btn-sm bg-red-100 hover:bg-red-200 border-none text-red-800" do %>
                <i class="bi bi-trash mr-1"></i> Supprimer
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-xl shadow-md p-8 text-center">
    <div class="flex flex-col items-center gap-4">
      <div class="p-4 bg-[#F2E8D8] rounded-full">
        <i class="bi bi-car-front text-[#B18B43] text-4xl"></i>
      </div>
      <h3 class="font-poppins text-lg font-medium text-[#0C1E3B]">Vous n'avez pas encore d'annonce</h3>
      <p class="text-[#1A1A1A] opacity-75 mb-4">Commencez par publier votre première annonce pour vendre ou louer votre véhicule.</p>
      <a href="<%= new_listing_path %>" class="btn bg-[#B18B43] hover:bg-[#A0782D] text-white border-none">
        <i class="bi bi-plus-lg mr-2"></i> Publier une annonce
      </a>
    </div>
  </div>
<% end %> 