<!-- Hero Section -->
<div class="relative bg-gradient-to-r from-primary to-primary-focus text-primary-content py-16 mb-12">
  <div class="absolute inset-0 bg-[url('/images/car-pattern.svg')] opacity-10"></div>
  <div class="container mx-auto px-4 relative">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Tableau de Bord</h1>
        <p class="text-lg opacity-90">Bienvenue, <%= current_user.name %></p>
      </div>
      <div class="flex items-center space-x-4">
        <div class="text-right">
          <p class="text-sm opacity-80">Solde actuel</p>
          <p class="text-2xl font-bold"><%= number_to_currency(@wallet&.balance || 0) %></p>
        </div>
        <button class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
          Recharger
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Main Content -->
<div class="container mx-auto px-4 pb-16">
  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
    <!-- Active Listings -->
    <div class="stat bg-base-100 shadow-xl rounded-lg">
      <div class="stat-figure text-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
      </div>
      <div class="stat-title">Annonces actives</div>
      <div class="stat-value text-primary"><%= @stats[:active_listings] %></div>
    </div>

    <!-- Total Sales -->
    <div class="stat bg-base-100 shadow-xl rounded-lg">
      <div class="stat-figure text-success">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="stat-title">Ventes totales</div>
      <div class="stat-value text-success"><%= @stats[:total_sales] %></div>
    </div>

    <!-- Total Purchases -->
    <div class="stat bg-base-100 shadow-xl rounded-lg">
      <div class="stat-figure text-info">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
      </div>
      <div class="stat-title">Achats totaux</div>
      <div class="stat-value text-info"><%= @stats[:total_purchases] %></div>
    </div>

    <!-- Unread Messages -->
    <div class="stat bg-base-100 shadow-xl rounded-lg">
      <div class="stat-figure text-warning">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      <div class="stat-title">Messages non lus</div>
      <div class="stat-value text-warning"><%= @stats[:unread_messages] %></div>
    </div>
  </div>

  <!-- Main Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- My Listings -->
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <div class="flex items-center justify-between mb-4">
          <h2 class="card-title">Mes Annonces</h2>
          <%= link_to "Voir tout", my_listings_path, class: "btn btn-primary btn-sm" %>
        </div>
        <div class="space-y-4">
          <% @my_listings.limit(3).each do |listing| %>
            <div class="flex items-center space-x-4 p-4 rounded-lg hover:bg-base-200 transition-colors duration-200">
              <% if listing.vehicle.images.attached? %>
                <%= image_tag listing.vehicle.images.first, class: "w-16 h-16 object-cover rounded-lg" %>
              <% end %>
              <div class="flex-1">
                <h3 class="font-medium"><%= listing.vehicle.title %></h3>
                <p class="text-sm text-base-content opacity-70"><%= listing.status %></p>
              </div>
              <div class="text-right">
                <p class="font-bold"><%= number_to_currency(listing.price) %></p>
                <p class="text-xs text-base-content opacity-50"><%= time_ago_in_words(listing.created_at) %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Recent Messages -->
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <div class="flex items-center justify-between mb-4">
          <h2 class="card-title">Messages récents</h2>
          <%= link_to "Voir tout", messages_path, class: "btn btn-primary btn-sm" %>
        </div>
        <div class="space-y-4">
          <% @conversations.each do |conversation| %>
            <div class="flex items-center space-x-4 p-4 rounded-lg hover:bg-base-200 transition-colors duration-200">
              <div class="avatar">
                <div class="w-12 h-12 rounded-full">
                  <img src="<%= conversation.other_user.avatar_url || 'https://ui-avatars.com/api/?name=' + conversation.other_user.name %>" alt="<%= conversation.other_user.name %>">
                </div>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-medium"><%= conversation.other_user.name %></p>
                <p class="text-sm text-base-content opacity-70 truncate"><%= conversation.last_message&.content %></p>
              </div>
              <div class="text-right">
                <p class="text-xs text-base-content opacity-50"><%= time_ago_in_words(conversation.last_message&.created_at) %></p>
                <% if conversation.unread_count > 0 %>
                  <span class="badge badge-primary badge-sm"><%= conversation.unread_count %></span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Recent Transactions -->
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <div class="flex items-center justify-between mb-4">
          <h2 class="card-title">Transactions récentes</h2>
          <%= link_to "Voir tout", wallet_transactions_path, class: "btn btn-primary btn-sm" %>
        </div>
        <div class="space-y-4">
          <% @transactions.each do |transaction| %>
            <div class="flex items-center justify-between p-4 rounded-lg hover:bg-base-200 transition-colors duration-200">
              <div class="flex items-center space-x-4">
                <div class="<%= transaction.amount.positive? ? 'text-success' : 'text-error' %>">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium"><%= transaction.description %></p>
                  <p class="text-sm text-base-content opacity-70"><%= transaction.transaction_type %></p>
                </div>
              </div>
              <div class="text-right">
                <p class="font-bold <%= transaction.amount.positive? ? 'text-success' : 'text-error' %>">
                  <%= transaction.amount.positive? ? '+' : '' %><%= number_to_currency(transaction.amount) %>
                </p>
                <p class="text-xs text-base-content opacity-50"><%= time_ago_in_words(transaction.created_at) %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div> 