<%
  # Helper to get display name for a user
  def display_name(user)
    return "Utilisateur" unless user
    [user.first_name, user.last_name].compact.join(" ").presence || user.name.presence || user.email.split("@").first
  end

  # Helper to get the counterpart in a conversation
  def conversation_partner(conversation, me)
    conversation.user_id == me.id ? conversation.other_user : conversation.user
  end
%>

<!-- Hero Section -->
<div class="relative bg-gradient-to-r from-primary to-primary-focus text-primary-content py-16 mb-12">
  <div class="container mx-auto px-4 relative">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Tableau de Bord</h1>
        <p class="text-lg opacity-90">Bienvenue, <%= display_name(current_user) %></p>
      </div>
      <div class="text-right">
        <p class="text-sm opacity-80">Solde</p>
        <p class="text-2xl font-bold"><%= number_to_currency(@wallet&.balance || 0) %></p>
      </div>
    </div>
  </div>
</div>

<!-- Main Content -->
<div class="container mx-auto px-4 pb-16">
  <!-- Stats Grid -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
    <div class="stat bg-base-100 shadow-xl rounded-lg">
      <div class="stat-title">Annonces actives</div>
      <div class="stat-value text-primary"><%= @stats[:active_listings] %></div>
    </div>
    <div class="stat bg-base-100 shadow-xl rounded-lg">
      <div class="stat-title">Ventes</div>
      <div class="stat-value text-success"><%= @stats[:total_sales] %></div>
    </div>
    <div class="stat bg-base-100 shadow-xl rounded-lg">
      <div class="stat-title">Achats</div>
      <div class="stat-value text-info"><%= @stats[:total_purchases] %></div>
    </div>
    <div class="stat bg-base-100 shadow-xl rounded-lg">
      <div class="stat-title">Messages non lus</div>
      <div class="stat-value text-warning"><%= @stats[:unread_messages] %></div>
    </div>
  </div>

  <!-- Main Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- My Listings -->
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <div class="flex items-center justify-between mb-4">
          <h2 class="card-title">Mes Annonces</h2>
          <%= link_to "Voir tout", my_listings_path, class: "btn btn-primary btn-sm" %>
        </div>
        <div class="space-y-4">
          <% @my_listings.limit(5).each do |listing| %>
            <%= link_to listing, class: "flex items-center space-x-4 p-4 rounded-lg hover:bg-base-200 transition-colors" do %>
              <div class="flex-1">
                <h3 class="font-medium"><%= listing.title %></h3>
                <p class="text-sm opacity-70"><%= listing.status %> &middot; <%= time_ago_in_words(listing.created_at) %></p>
              </div>
              <div class="text-right">
                <p class="font-bold"><%= number_to_currency(listing.vehicle&.price) %></p>
              </div>
            <% end %>
          <% end %>
          <% if @my_listings.empty? %>
            <p class="text-center text-base-content opacity-50 py-4">Aucune annonce</p>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Recent Messages -->
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <div class="flex items-center justify-between mb-4">
          <h2 class="card-title">Messages récents</h2>
          <%= link_to "Voir tout", messages_path, class: "btn btn-primary btn-sm" %>
        </div>
        <div class="space-y-4">
          <% @conversations.each do |conversation| %>
            <% partner = conversation_partner(conversation, current_user) %>
            <% partner_name = display_name(partner) %>
            <div class="flex items-center space-x-4 p-4 rounded-lg hover:bg-base-200 transition-colors">
              <div class="avatar placeholder">
                <div class="bg-neutral text-neutral-content rounded-full w-12">
                  <span class="text-lg"><%= partner_name[0]&.upcase %></span>
                </div>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-medium"><%= partner_name %></p>
                <% last_msg = Message.between(conversation.user_id, conversation.other_user_id).last %>
                <p class="text-sm opacity-70 truncate"><%= last_msg&.content || "Pas encore de message" %></p>
              </div>
            </div>
          <% end %>
          <% if @conversations.empty? %>
            <p class="text-center text-base-content opacity-50 py-4">Aucune conversation</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
