<% content_for(:title) { "Votre Garage — Vera Trade" } %>

<%
  hour = Time.current.hour
  greeting = case hour
             when 5..11  then "Bonjour"
             when 12..17 then "Bon après-midi"
             when 18..22 then "Bonsoir"
             else             "Bonne nuit"
             end
  first_name = current_user.respond_to?(:first_name) ? current_user.first_name : nil
  display = first_name.presence || current_user.display_name
%>

<%# ========================================================================
    HERO — "Bonsoir, Prénom." ton personnel collectionneur
    ======================================================================== %>
<header class="border-b border-line">
  <div class="max-w-[1600px] mx-auto px-5 lg:px-10 pt-16 lg:pt-24 pb-12 lg:pb-20">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-10">
      <div class="flex-1">
        <div class="eyebrow mb-4">Votre Garage · <%= l(Date.current, format: "%e %B %Y") rescue Date.current.strftime("%d/%m/%Y") %></div>
        <h1 class="playfair-italic text-6xl md:text-7xl lg:text-[96px] text-text-primary leading-[0.9] tracking-[-0.02em]">
          <%= greeting %>, <%= display %>.
        </h1>
      </div>

      <div class="flex items-end gap-10 pb-4">
        <div>
          <div class="label-micro mb-2">Portefeuille</div>
          <div class="font-mono text-2xl md:text-3xl text-text-primary">
            <%= number_with_delimiter((@wallet&.balance || 0).to_i, delimiter: " ") %> €
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<%# ========================================================================
    KPIs — 4 métriques éditoriales
    ======================================================================== %>
<section class="max-w-[1600px] mx-auto px-5 lg:px-10 py-12 lg:py-16">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-0 border-y border-line">
    <%
      kpis = [
        {
          label: "Annonces actives",
          value: @active_listings_count.to_s.rjust(2, "0"),
          sublabel: @total_sales_count > 0 ? "#{@total_sales_count} vendue#{'s' if @total_sales_count > 1}" : "Publiées"
        },
        {
          label: "Vues totales",
          value: number_with_delimiter(@total_views, delimiter: " "),
          sublabel: "Depuis la publication"
        },
        {
          label: "Favoris reçus",
          value: @total_favorites_received.to_s.rjust(2, "0"),
          sublabel: "Sur vos annonces"
        },
        {
          label: "Valeur catalogue",
          value: @collection_value && @collection_value > 0 ? "#{number_with_delimiter(@collection_value.to_i, delimiter: ' ')} €" : "—",
          sublabel: "Total des annonces actives"
        }
      ]
    %>
    <% kpis.each_with_index do |kpi, i| %>
      <div class="py-8 lg:py-10 px-6 lg:px-8 <%= i < kpis.size - 1 ? 'lg:border-r border-line' : '' %> <%= i.odd? ? 'border-l border-line lg:border-l-0' : '' %> <%= i >= 2 ? 'border-t border-line lg:border-t-0' : '' %>">
        <div class="label-micro mb-4"><%= kpi[:label] %></div>
        <div class="playfair-italic text-5xl lg:text-6xl text-text-primary leading-none tracking-[-0.01em] mb-3">
          <%= kpi[:value] %>
        </div>
        <div class="font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted">
          <%= kpi[:sublabel] %>
        </div>
      </div>
    <% end %>
  </div>
</section>

<div class="max-w-[1600px] mx-auto px-5 lg:px-10 pb-20 lg:pb-32">
  <div class="grid grid-cols-12 gap-12 lg:gap-16">

    <%# ========================================================================
        COLONNE PRINCIPALE (8/12)
        ======================================================================== %>
    <div class="col-span-12 lg:col-span-8 space-y-20 lg:space-y-28">

      <%# -------------------- MES ANNONCES -------------------- %>
      <section>
        <%= render "components/section_header",
              eyebrow: "Votre Publication",
              title: "Mes annonces.",
              link_to_: my_listings_path,
              link_label: "Gérer tout" %>

        <% if @my_listings.any? %>
          <div class="space-y-0">
            <% @my_listings.limit(5).each do |listing| %>
              <%= link_to listing, class: "group block border-t border-line last:border-b hover:bg-bg-secondary transition-colors duration-200" do %>
                <div class="grid grid-cols-12 gap-4 lg:gap-6 items-center py-6 px-4">
                  <!-- Thumbnail -->
                  <div class="col-span-3 md:col-span-2">
                    <div class="aspect-square bg-bg-tertiary overflow-hidden">
                      <% if listing.photos.attached? %>
                        <%= image_tag listing.photos.first, class: "w-full h-full object-cover", alt: listing.title, loading: "lazy" %>
                      <% else %>
                        <div class="w-full h-full flex items-center justify-center">
                          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.8" class="text-text-muted/30">
                            <rect width="18" height="18" x="3" y="3"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                          </svg>
                        </div>
                      <% end %>
                    </div>
                  </div>

                  <!-- Titre + status -->
                  <div class="col-span-9 md:col-span-6 min-w-0">
                    <div class="label-micro mb-1">Annonce <%= listing_reference(listing) %></div>
                    <h3 class="playfair-italic text-lg md:text-xl text-text-primary leading-tight line-clamp-1 group-hover:text-accent-red transition-colors">
                      <%= listing.title %>
                    </h3>
                    <div class="mt-2 flex items-center gap-4">
                      <%
                        status_color = case listing.status
                                       when "active"  then "text-rust-ok border-rust-ok"
                                       when "pending" then "text-gold border-gold"
                                       when "sold"    then "text-accent-red border-accent-red"
                                       else                "text-text-muted border-line"
                                       end
                        status_label = case listing.status
                                       when "active"  then "En ligne"
                                       when "pending" then "En attente"
                                       when "sold"    then "Vendu"
                                       else                listing.status.to_s.capitalize
                                       end
                      %>
                      <span class="font-ui text-[9px] uppercase tracking-[0.2em] border <%= status_color %> px-2 py-0.5">
                        <%= status_label %>
                      </span>
                      <span class="font-mono text-[10px] text-text-muted">
                        <%= listing.views_count %> vue<%= listing.views_count > 1 ? "s" : "" %>
                      </span>
                      <span class="font-mono text-[10px] text-text-muted">
                        Publié <%= time_ago_in_words(listing.created_at) %>
                      </span>
                    </div>
                  </div>

                  <!-- Prix -->
                  <div class="hidden md:block md:col-span-3 text-right">
                    <div class="font-mono text-lg text-accent-red">
                      <%= listing_price_fr(listing.vehicle) %>
                    </div>
                  </div>

                  <!-- Arrow cue -->
                  <div class="hidden md:flex md:col-span-1 justify-end text-text-muted group-hover:text-accent-red transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                    </svg>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="border border-line bg-bg-secondary py-20 px-8 text-center">
            <div class="eyebrow mb-4">Rien publié</div>
            <h3 class="playfair-italic text-3xl md:text-4xl text-text-primary leading-tight mb-6">
              Votre garage est encore vide.
            </h3>
            <p class="font-body italic text-base text-text-secondary mb-8 max-w-md mx-auto">
              Publiez votre première annonce : une voiture, son histoire, ses détails. Nous prenons soin du reste.
            </p>
            <%= link_to "Publier une annonce", new_listing_path, class: "btn-vera-primary" %>
          </div>
        <% end %>
      </section>

      <%# -------------------- MA WISHLIST (favoris) -------------------- %>
      <% if @my_favorites.any? %>
        <section>
          <%= render "components/section_header",
                eyebrow: "Votre Wishlist",
                title: "Les voitures que vous suivez.",
                link_to_: favorites_path,
                link_label: "Tous les favoris" %>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
            <% @my_favorites.limit(4).each do |listing| %>
              <%= render "components/listing_card", listing: listing, size: :medium %>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>

    <%# ========================================================================
        SIDEBAR (4/12)
        ======================================================================== %>
    <aside class="col-span-12 lg:col-span-4 space-y-10">

      <!-- Conversations récentes -->
      <div class="bg-bg-secondary border border-line">
        <div class="p-6 border-b border-line flex items-center justify-between">
          <div>
            <div class="eyebrow mb-1">Messagerie</div>
            <h3 class="playfair-italic text-2xl text-text-primary leading-tight">Derniers échanges.</h3>
          </div>
          <% if @unread_messages_count > 0 %>
            <span class="badge-vera-red"><%= @unread_messages_count %></span>
          <% end %>
        </div>

        <% if @conversations.any? %>
          <ul>
            <% @conversations.each do |conversation| %>
              <%
                partner = conversation.user_id == current_user.id ? conversation.other_user : conversation.user
                partner_name = partner&.display_name || "Utilisateur"
                partner_initial = partner_name[0]&.upcase || "?"
                last_msg_content = begin
                  Message.between(conversation.user_id, conversation.other_user_id).last&.content
                rescue
                  nil
                end
              %>
              <li>
                <%= link_to conversation_path(partner), class: "flex items-start gap-4 p-5 border-t border-line first:border-t-0 hover:bg-bg-tertiary transition-colors" do %>
                  <div class="w-10 h-10 bg-bg-tertiary border border-line flex items-center justify-center shrink-0">
                    <span class="font-ui text-xs font-bold text-text-primary uppercase"><%= partner_initial %></span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2 mb-1">
                      <span class="playfair-italic text-sm text-text-primary truncate"><%= partner_name %></span>
                      <span class="font-mono text-[9px] text-text-muted shrink-0">
                        <%= time_ago_in_words(conversation.updated_at).sub(/\babout\b/, "").strip %>
                      </span>
                    </div>
                    <p class="font-body italic text-xs text-text-secondary truncate">
                      <%= last_msg_content.presence || "Pas encore de message" %>
                    </p>
                  </div>
                <% end %>
              </li>
            <% end %>
          </ul>
          <div class="p-4 border-t border-line">
            <%= link_to messages_path, class: "block text-center font-ui text-[10px] uppercase tracking-[0.2em] text-text-muted hover:text-accent-red transition-colors" do %>
              Voir toute la messagerie
            <% end %>
          </div>
        <% else %>
          <div class="p-8 text-center">
            <p class="font-body italic text-sm text-text-muted">Aucune conversation pour l'instant.</p>
          </div>
        <% end %>
      </div>

      <!-- Compte & sécurité -->
      <div class="bg-bg-secondary border border-line p-6">
        <div class="eyebrow mb-4">Votre Compte</div>
        <ul class="divide-y divide-line">
          <li class="py-3 flex items-center justify-between">
            <span class="font-ui text-[11px] uppercase tracking-[0.15em] text-text-secondary">Adresse e-mail</span>
            <span class="font-mono text-[10px] text-text-muted truncate max-w-[60%]" title="<%= current_user.email %>"><%= current_user.email %></span>
          </li>
          <li class="py-3 flex items-center justify-between">
            <span class="font-ui text-[11px] uppercase tracking-[0.15em] text-text-secondary">Membre depuis</span>
            <span class="font-mono text-[10px] text-text-muted"><%= current_user.created_at.strftime("%m/%Y") %></span>
          </li>
          <li class="py-3 flex items-center justify-between">
            <span class="font-ui text-[11px] uppercase tracking-[0.15em] text-text-secondary">Vérification</span>
            <span class="font-mono text-[10px] text-text-muted">À venir</span>
          </li>
        </ul>
        <div class="mt-6 pt-6 border-t border-line">
          <%= link_to edit_user_registration_path, class: "block text-center font-ui text-[10px] uppercase tracking-[0.2em] text-text-muted hover:text-accent-red transition-colors" do %>
            Paramètres du compte
          <% end %>
        </div>
      </div>

      <!-- CTA Publier -->
      <div class="bg-bg-secondary border border-accent-red p-8 text-center">
        <div class="eyebrow mb-4">Une voiture à vendre ?</div>
        <h4 class="playfair-italic text-2xl text-text-primary leading-tight mb-5">
          Publiez votre prochaine annonce.
        </h4>
        <p class="font-body italic text-sm text-text-secondary mb-6">
          Rust Map, provenance et accompagnement éditorial inclus.
        </p>
        <%= link_to "Publier une annonce", new_listing_path, class: "btn-vera-primary w-full justify-center" %>
      </div>
    </aside>
  </div>
</div>
