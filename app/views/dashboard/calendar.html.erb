<div class="max-w-7xl mx-auto p-6">
  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold">Calendrier</h1>
      <p class="text-base-content opacity-70">Gérez vos événements et rendez-vous</p>
    </div>
    <div class="flex items-center space-x-2">
      <button class="btn btn-primary" onclick="new_event_modal.showModal()">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        Nouvel événement
      </button>
      <%= link_to "Retour au dashboard", dashboard_path, class: "btn btn-ghost" %>
    </div>
  </div>

  <!-- Calendar Container -->
  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <!-- Calendar Header with Filters -->
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center space-x-4">
          <h2 class="text-lg font-semibold">Mes événements</h2>
          <div class="divider divider-horizontal"></div>
          
          <!-- Type Filter -->
          <div class="form-control">
            <label class="label cursor-pointer">
              <input type="checkbox" checked="checked" class="checkbox checkbox-primary checkbox-sm mr-2" data-filter="all">
              <span class="label-text text-sm">Tous</span>
            </label>
          </div>
          
          <% CalendarEvent.event_types.each do |type, _| %>
            <div class="form-control">
              <label class="label cursor-pointer">
                <input type="checkbox" checked="checked" class="checkbox checkbox-sm mr-2" data-filter="<%= type %>">
                <span class="label-text text-sm"><%= type.humanize %></span>
              </label>
            </div>
          <% end %>
        </div>
        
        <!-- View Toggle -->
        <div class="btn-group">
          <button class="btn btn-sm" data-view="dayGridMonth">Mois</button>
          <button class="btn btn-sm" data-view="timeGridWeek">Semaine</button>
          <button class="btn btn-sm" data-view="timeGridDay">Jour</button>
          <button class="btn btn-sm" data-view="listWeek">Liste</button>
        </div>
      </div>
      
      <!-- Calendar -->
      <div id="calendar" class="min-h-[600px]"></div>
    </div>
  </div>

  <!-- Événements d'aujourd'hui -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mt-8">
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h3 class="card-title">Événements d'aujourd'hui</h3>
        
        <% today_events = @calendar_events.select { |e| e.start_time.to_date == Date.current } %>
        <% if today_events.any? %>
          <div class="space-y-3">
            <% today_events.each do |event| %>
              <div class="flex items-center space-x-3 p-3 bg-base-200 rounded-lg">
                <div class="w-3 h-3 rounded-full" style="background-color: <%= event.color %>"></div>
                <div class="flex-1">
                  <h4 class="font-medium"><%= event.title %></h4>
                  <p class="text-sm opacity-70">
                    <%= event.start_time.strftime('%H:%M') %>
                    <% if event.end_time && !event.all_day? %>
                      - <%= event.end_time.strftime('%H:%M') %>
                    <% end %>
                  </p>
                  <% if event.description.present? %>
                    <p class="text-xs opacity-60"><%= truncate(event.description, length: 50) %></p>
                  <% end %>
                </div>
                <div class="flex space-x-1">
                  <button class="btn btn-ghost btn-xs" onclick="editEvent(<%= event.id %>)">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                  </button>
                  <button class="btn btn-ghost btn-xs text-error" onclick="deleteEvent(<%= event.id %>)">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                  </button>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <svg class="w-16 h-16 mx-auto text-base-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <p class="text-base-content opacity-70">Aucun événement aujourd'hui</p>
          </div>
        <% end %>
      </div>
    </div>
    
    <!-- Prochains événements -->
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h3 class="card-title">Prochains événements</h3>
        
        <% upcoming = @calendar_events.select { |e| e.start_time > Time.current }.sort_by(&:start_time).first(5) %>
        <% if upcoming.any? %>
          <div class="space-y-3">
            <% upcoming.each do |event| %>
              <div class="flex items-center space-x-3 p-3 bg-base-200 rounded-lg">
                <div class="w-3 h-3 rounded-full" style="background-color: <%= event.color %>"></div>
                <div class="flex-1">
                  <h4 class="font-medium"><%= event.title %></h4>
                  <p class="text-sm opacity-70">
                    <%= l(event.start_time, format: :short) %>
                  </p>
                </div>
                <div class="badge badge-outline"><%= event.event_type.humanize %></div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <svg class="w-16 h-16 mx-auto text-base-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-base-content opacity-70">Aucun événement planifié</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Modal Nouvel Événement -->
<dialog id="new_event_modal" class="modal">
  <div class="modal-box w-11/12 max-w-2xl">
    <h3 class="font-bold text-lg mb-4">Créer un nouvel événement</h3>
    
    <%= form_with model: CalendarEvent.new, url: calendar_events_path, local: false, 
        html: { id: "new-event-form", class: "space-y-4" } do |form| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-control">
          <%= form.label :title, "Titre", class: "label" %>
          <%= form.text_field :title, class: "input input-bordered w-full", placeholder: "Nom de l'événement" %>
        </div>
        
        <div class="form-control">
          <%= form.label :event_type, "Type", class: "label" %>
          <%= form.select :event_type, 
              CalendarEvent.event_types.keys.map { |k| [k.humanize, k] }, 
              { prompt: "Sélectionnez un type" }, 
              { class: "select select-bordered w-full" } %>
        </div>
      </div>
      
      <div class="form-control">
        <%= form.label :description, "Description", class: "label" %>
        <%= form.text_area :description, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Description de l'événement (optionnel)" %>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-control">
          <%= form.label :start_time, "Date et heure de début", class: "label" %>
          <%= form.datetime_local_field :start_time, class: "input input-bordered w-full" %>
        </div>
        
        <div class="form-control">
          <%= form.label :end_time, "Date et heure de fin", class: "label" %>
          <%= form.datetime_local_field :end_time, class: "input input-bordered w-full" %>
        </div>
      </div>
      
      <div class="flex items-center space-x-4">
        <div class="form-control">
          <label class="label cursor-pointer">
            <%= form.check_box :all_day, class: "checkbox checkbox-primary" %>
            <span class="label-text ml-2">Journée entière</span>
          </label>
        </div>
        
        <div class="form-control">
          <%= form.label :color, "Couleur", class: "label" %>
          <%= form.color_field :color, class: "input input-bordered w-20 h-12", value: "#3B82F6" %>
        </div>
      </div>
      
      <div class="modal-action">
        <button type="button" class="btn" onclick="new_event_modal.close()">Annuler</button>
        <%= form.submit "Créer l'événement", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</dialog>

<!-- Modal Édition Événement -->
<dialog id="edit_event_modal" class="modal">
  <div class="modal-box w-11/12 max-w-2xl">
    <h3 class="font-bold text-lg mb-4">Modifier l'événement</h3>
    <div id="edit-event-form-container">
      <!-- Le formulaire sera chargé ici via AJAX -->
    </div>
  </div>
</dialog>

<!-- Inclure FullCalendar -->
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.10/locales/fr.global.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var calendarEl = document.getElementById('calendar');
  var calendar = new FullCalendar.Calendar(calendarEl, {
    initialView: 'dayGridMonth',
    locale: 'fr',
    headerToolbar: {
      left: 'prev,next today',
      center: 'title',
      right: 'dayGridMonth,timeGridWeek,timeGridDay,listWeek'
    },
    buttonText: {
      today: 'Aujourd\'hui',
      month: 'Mois',
      week: 'Semaine',
      day: 'Jour',
      list: 'Liste'
    },
    height: 'auto',
    events: '/calendar_events/events_data',
    selectable: true,
    editable: true,
    
    // Création d'événement en sélectionnant une plage
    select: function(info) {
      document.getElementById('calendar_event_start_time').value = 
        new Date(info.start.getTime() - info.start.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
      document.getElementById('calendar_event_end_time').value = 
        new Date(info.end.getTime() - info.end.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
      document.getElementById('calendar_event_all_day').checked = info.allDay;
      new_event_modal.showModal();
    },
    
    // Clic sur un événement
    eventClick: function(info) {
      editEvent(info.event.id);
    },
    
    // Drag & drop d'événement
    eventDrop: function(info) {
      updateEventTime(info.event.id, info.event.start, info.event.end);
    },
    
    // Redimensionnement d'événement
    eventResize: function(info) {
      updateEventTime(info.event.id, info.event.start, info.event.end);
    }
  });
  
  calendar.render();
  
  // Gestion des filtres de type
  document.querySelectorAll('[data-filter]').forEach(checkbox => {
    checkbox.addEventListener('change', function() {
      if (this.dataset.filter === 'all') {
        if (this.checked) {
          document.querySelectorAll('[data-filter]:not([data-filter="all"])').forEach(cb => cb.checked = true);
        } else {
          document.querySelectorAll('[data-filter]:not([data-filter="all"])').forEach(cb => cb.checked = false);
        }
      }
      // Recharger les événements avec filtres
      calendar.refetchEvents();
    });
  });
  
  // Gestion des vues
  document.querySelectorAll('[data-view]').forEach(button => {
    button.addEventListener('click', function() {
      calendar.changeView(this.dataset.view);
      // Mise à jour de l'apparence des boutons
      document.querySelectorAll('[data-view]').forEach(btn => btn.classList.remove('btn-primary'));
      this.classList.add('btn-primary');
    });
  });
  
  // Gestion de la case "Journée entière"
  document.getElementById('calendar_event_all_day').addEventListener('change', function() {
    const endTimeField = document.getElementById('calendar_event_end_time');
    if (this.checked) {
      endTimeField.disabled = true;
      endTimeField.style.opacity = '0.5';
    } else {
      endTimeField.disabled = false;
      endTimeField.style.opacity = '1';
    }
  });
});

// Fonctions globales
function editEvent(eventId) {
  fetch(`/calendar_events/${eventId}/edit`)
    .then(response => response.text())
    .then(html => {
      document.getElementById('edit-event-form-container').innerHTML = html;
      edit_event_modal.showModal();
    });
}

function deleteEvent(eventId) {
  if (confirm('Êtes-vous sûr de vouloir supprimer cet événement ?')) {
    fetch(`/calendar_events/${eventId}`, {
      method: 'DELETE',
      headers: {
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      }
    }).then(() => {
      location.reload();
    });
  }
}

function updateEventTime(eventId, start, end) {
  fetch(`/calendar_events/${eventId}`, {
    method: 'PATCH',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
    },
    body: JSON.stringify({
      calendar_event: {
        start_time: start.toISOString(),
        end_time: end ? end.toISOString() : null
      }
    })
  });
}

// Gestion des formulaires AJAX
document.addEventListener('turbo:load', function() {
  const newEventForm = document.getElementById('new-event-form');
  if (newEventForm) {
    newEventForm.addEventListener('ajax:success', function() {
      new_event_modal.close();
      location.reload();
    });
  }
});
</script>

<style>
/* Styles personnalisés pour FullCalendar */
.fc {
  font-family: inherit;
}

.fc-toolbar {
  margin-bottom: 1rem !important;
}

.fc-button {
  background-color: hsl(var(--p)) !important;
  border-color: hsl(var(--p)) !important;
  color: hsl(var(--pc)) !important;
}

.fc-button:hover {
  background-color: hsl(var(--pf)) !important;
  border-color: hsl(var(--pf)) !important;
}

.fc-button-active {
  background-color: hsl(var(--pf)) !important;
  border-color: hsl(var(--pf)) !important;
}

.fc-today {
  background-color: hsl(var(--b2)) !important;
}

.fc-event {
  border-radius: 0.375rem !important;
  border: none !important;
  font-size: 0.875rem !important;
}

.fc-daygrid-event {
  margin: 1px 2px !important;
}
</style> 