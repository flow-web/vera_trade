<%# Editorial listing card — sizes: feature, large, medium, small %>

<%
  size       ||= :medium
  lazy         = local_assigns.fetch(:lazy, true)
  show_desc    = local_assigns.fetch(:show_desc, false)
  vehicle      = listing.vehicle

  aspect, title_size, gutter_y = case size
  when :feature then ["aspect-[21/9]", "text-4xl md:text-6xl", "py-8"]
  when :large   then ["aspect-[16/10]", "text-2xl md:text-3xl", "py-6"]
  when :small   then ["aspect-square",  "text-lg md:text-xl",  "py-4"]
  else               ["aspect-[4/3]",    "text-xl md:text-2xl", "py-5"]
  end
%>

<article class="group relative">
  <%= link_to listing, class: "block" do %>
    <!-- Image 21:9 / 16:10 / square selon taille -->
    <div class="relative overflow-hidden bg-bg-tertiary <%= aspect %>">
      <% if listing.photos.attached? %>
        <%= image_tag listing.photos.first,
              class: "w-full h-full object-cover grayscale-[15%] group-hover:grayscale-0 scale-[1.02] group-hover:scale-100 transition-all duration-700 ease-out",
              loading: (lazy ? "lazy" : "eager"),
              alt: listing.title %>
      <% else %>
        <div class="w-full h-full flex items-center justify-center bg-bg-tertiary">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.8" class="text-text-muted/40">
            <rect width="18" height="18" x="3" y="3"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
        </div>
      <% end %>

      <!-- Gradient bas pour lisibilité titre sur feature -->
      <% if size == :feature %>
        <div class="absolute inset-0 bg-gradient-to-t from-bg-primary/70 via-transparent to-transparent pointer-events-none"></div>
      <% end %>

      <!-- Status VENDU -->
      <% if listing.status == "sold" %>
        <div class="absolute inset-0 bg-bg-primary/75 flex items-center justify-center">
          <span class="font-ui text-sm font-bold uppercase tracking-[0.3em] text-accent-red border border-accent-red px-6 py-2">
            Vendu
          </span>
        </div>
      <% end %>

      <!-- Bloc titre sur feature (superposé) -->
      <% if size == :feature %>
        <div class="absolute bottom-0 left-0 right-0 px-6 md:px-8 pb-6 md:pb-8">
          <div class="eyebrow text-accent-red mb-2">
            Annonce <%= listing_reference(listing) %>
          </div>
          <h3 class="playfair-italic <%= title_size %> text-text-primary leading-[0.95] tracking-[-0.015em]">
            <%= listing.title %>
          </h3>
        </div>
      <% end %>
    </div>

    <!-- Bloc métadonnées (hors feature) -->
    <% if size != :feature %>
      <div class="<%= gutter_y %> border-t border-line mt-0">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <div class="eyebrow text-accent-red mb-2">
              Annonce <%= listing_reference(listing) %>
            </div>
            <h3 class="playfair-italic <%= title_size %> text-text-primary leading-tight tracking-[-0.01em] mb-2 line-clamp-2">
              <%= listing.title %>
            </h3>
            <% if show_desc && listing.description.present? %>
              <p class="font-body italic text-sm text-text-secondary leading-relaxed line-clamp-2 mb-3">
                <%= listing.description.to_s.truncate(140) %>
              </p>
            <% end %>
          </div>
          <div class="text-right shrink-0">
            <div class="font-mono text-base md:text-lg text-accent-red whitespace-nowrap">
              <%= listing_price_fr(vehicle) %>
            </div>
          </div>
        </div>

        <!-- Metadata line -->
        <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2">
          <% if vehicle&.year %>
            <span class="font-mono text-[11px] text-text-secondary"><%= vehicle.year %></span>
          <% end %>
          <% if vehicle&.kilometers %>
            <span class="font-mono text-[11px] text-text-secondary"><%= listing_kilometers_fr(vehicle.kilometers) %></span>
          <% end %>
          <% if vehicle&.transmission.present? %>
            <span class="font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted"><%= vehicle.transmission %></span>
          <% end %>
          <% if listing_location_tag(listing) %>
            <span class="font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted ml-auto">
              <%= listing_location_tag(listing) %>
            </span>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <!-- Métadonnées SOUS le bloc image pour variante feature -->
  <% if size == :feature %>
    <div class="mt-6 flex items-center justify-between border-t border-line pt-4">
      <div class="flex items-center gap-x-6 gap-y-2 flex-wrap">
        <% if vehicle&.year %>
          <span class="font-mono text-xs text-text-secondary"><%= vehicle.year %></span>
        <% end %>
        <% if vehicle&.kilometers %>
          <span class="font-mono text-xs text-text-secondary"><%= listing_kilometers_fr(vehicle.kilometers) %></span>
        <% end %>
        <% if listing_location_tag(listing) %>
          <span class="font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted">
            <%= listing_location_tag(listing) %>
          </span>
        <% end %>
      </div>
      <div class="font-mono text-xl md:text-2xl text-accent-red">
        <%= listing_price_fr(vehicle) %>
      </div>
    </div>
  <% end %>
</article>
