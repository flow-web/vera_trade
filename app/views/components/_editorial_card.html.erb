<%#
  Editorial card — carte "Le Journal" pour homepage et list article.
  Locals :
    eyebrow   — string (ex: "Le Journal · Guide d'achat")
    title     — string (titre éditorial)
    excerpt   — string (résumé court)
    image_url — string (optional — affiche visuel si présent)
    image_alt — string
    link_to_  — string ou path (défaut "#" disabled)
    disabled  — true/false (défaut false) — affiche "Bientôt"
%>

<%
  eyebrow   ||= "Le Journal"
  title     ||= "Titre de l'article"
  excerpt   ||= ""
  image_url = local_assigns[:image_url]
  image_alt ||= title
  link_target = local_assigns[:link_to_] || "#"
  disabled  = local_assigns.fetch(:disabled, false)
%>

<article class="group">
  <%= link_to link_target, class: "block #{disabled ? 'cursor-not-allowed pointer-events-none opacity-75' : ''}" do %>
    <% if image_url %>
      <div class="relative overflow-hidden aspect-[4/5] bg-bg-tertiary mb-6">
        <%= image_tag image_url,
              class: "w-full h-full object-cover grayscale group-hover:grayscale-0 scale-[1.02] group-hover:scale-100 transition-all duration-700",
              alt: image_alt, loading: "lazy",
              width: 600, height: 750 %>
      </div>
    <% end %>

    <div class="eyebrow mb-4"><%= eyebrow %></div>

    <h3 class="playfair-italic text-3xl md:text-4xl lg:text-5xl text-text-primary leading-[1.05] tracking-[-0.015em] mb-6">
      <%= title %>
    </h3>

    <% if excerpt.present? %>
      <p class="font-body text-base lg:text-lg text-text-secondary leading-relaxed mb-8 max-w-[56ch]">
        <%= excerpt %>
      </p>
    <% end %>

    <span class="inline-flex items-center gap-3 font-ui text-[10px] font-medium uppercase tracking-[0.2em] text-text-primary border-b border-text-primary pb-1 <%= disabled ? 'opacity-60' : 'group-hover:text-accent-red group-hover:border-accent-red transition-colors duration-300' %>">
      <%= disabled ? "Bientôt" : "Lire l'article" %>
      <% unless disabled %>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      <% end %>
    </span>
  <% end %>
</article>
