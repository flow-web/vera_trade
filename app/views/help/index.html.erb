<div class="container mx-auto px-4 py-8 max-w-6xl">
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Centre d'Aide VeraTrade</h1>
    <p class="text-xl text-gray-600">Trouvez rapidement les réponses à vos questions</p>
  </div>

  <!-- Quick Actions -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
    <%= link_to help_dispute_guidelines_path, 
        class: "card bg-gradient-to-br from-blue-500 to-blue-600 text-white hover:shadow-lg transition-all duration-300" do %>
      <div class="card-body text-center">
        <div class="text-4xl mb-3">⚖️</div>
        <h3 class="text-lg font-semibold">Guide des Litiges</h3>
        <p class="text-sm opacity-90">Procédures et bonnes pratiques</p>
      </div>
    <% end %>

    <%= link_to help_support_faq_path, 
        class: "card bg-gradient-to-br from-green-500 to-green-600 text-white hover:shadow-lg transition-all duration-300" do %>
      <div class="card-body text-center">
        <div class="text-4xl mb-3">❓</div>
        <h3 class="text-lg font-semibold">FAQ</h3>
        <p class="text-sm opacity-90">Questions fréquemment posées</p>
      </div>
    <% end %>

    <%= link_to new_support_ticket_path, 
        class: "card bg-gradient-to-br from-purple-500 to-purple-600 text-white hover:shadow-lg transition-all duration-300" do %>
      <div class="card-body text-center">
        <div class="text-4xl mb-3">🎧</div>
        <h3 class="text-lg font-semibold">Contacter le Support</h3>
        <p class="text-sm opacity-90">Créer un ticket de support</p>
      </div>
    <% end %>

    <%= link_to new_dispute_path, 
        class: "card bg-gradient-to-br from-red-500 to-red-600 text-white hover:shadow-lg transition-all duration-300" do %>
      <div class="card-body text-center">
        <div class="text-4xl mb-3">🚨</div>
        <h3 class="text-lg font-semibold">Ouvrir un Litige</h3>
        <p class="text-sm opacity-90">Signaler un problème</p>
      </div>
    <% end %>
  </div>

  <!-- Recent Activity -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Recent Disputes -->
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h2 class="card-title text-xl mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Mes Litiges Récents
        </h2>
        
        <% if @recent_disputes.any? %>
          <div class="space-y-3">
            <% @recent_disputes.each do |dispute| %>
              <div class="flex items-center justify-between p-3 bg-base-200 rounded-lg">
                <div class="flex-1">
                  <h4 class="font-medium"><%= link_to dispute.title, dispute, class: "link link-hover" %></h4>
                  <p class="text-sm text-gray-500"><%= dispute.reference_number %></p>
                </div>
                <div class="badge <%= dispute.status == 'open' ? 'badge-primary' : 
                                    dispute.status == 'resolved' ? 'badge-success' : 'badge-secondary' %>">
                  <%= dispute.status_label %>
                </div>
              </div>
            <% end %>
          </div>
          <div class="card-actions justify-end mt-4">
            <%= link_to "Voir tous les litiges", disputes_path, class: "btn btn-sm btn-outline" %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <div class="text-4xl mb-2">📋</div>
            <p class="text-gray-600">Aucun litige récent</p>
            <%= link_to "Ouvrir un litige", new_dispute_path, class: "btn btn-sm btn-primary mt-3" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Support Tickets -->
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h2 class="card-title text-xl mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Mes Tickets Récents
        </h2>
        
        <% if @recent_tickets.any? %>
          <div class="space-y-3">
            <% @recent_tickets.each do |ticket| %>
              <div class="flex items-center justify-between p-3 bg-base-200 rounded-lg">
                <div class="flex-1">
                  <h4 class="font-medium"><%= link_to ticket.title, ticket, class: "link link-hover" %></h4>
                  <p class="text-sm text-gray-500"><%= ticket.ticket_number %></p>
                </div>
                <div class="badge <%= ticket.status == 'open' ? 'badge-primary' : 
                                    ticket.status == 'resolved' ? 'badge-success' : 'badge-info' %>">
                  <%= ticket.status_label %>
                </div>
              </div>
            <% end %>
          </div>
          <div class="card-actions justify-end mt-4">
            <%= link_to "Voir tous les tickets", support_tickets_path, class: "btn btn-sm btn-outline" %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <div class="text-4xl mb-2">🎧</div>
            <p class="text-gray-600">Aucun ticket récent</p>
            <%= link_to "Créer un ticket", new_support_ticket_path, class: "btn btn-sm btn-secondary mt-3" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Help Categories -->
  <div class="mt-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Catégories d'aide</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
          <h3 class="card-title text-primary">🚗 Véhicules et Annonces</h3>
          <ul class="space-y-2 text-sm">
            <li>• Comment créer une annonce</li>
            <li>• Conseils pour vendre</li>
            <li>• Évaluation de véhicules</li>
            <li>• Photos et descriptions</li>
          </ul>
        </div>
      </div>

      <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
          <h3 class="card-title text-secondary">💬 Communication</h3>
          <ul class="space-y-2 text-sm">
            <li>• Messagerie instantanée</li>
            <li>• Modèles de messages</li>
            <li>• Négociation en ligne</li>
            <li>• Bonnes pratiques</li>
          </ul>
        </div>
      </div>

      <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
          <h3 class="card-title text-accent">🔒 Sécurité</h3>
          <ul class="space-y-2 text-sm">
            <li>• Éviter les arnaques</li>
            <li>• Paiements sécurisés</li>
            <li>• Vérification d'identité</li>
            <li>• Signalement de fraude</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Contact Section -->
  <div class="mt-12 text-center">
    <div class="card bg-gradient-to-r from-primary to-secondary text-white">
      <div class="card-body">
        <h2 class="card-title justify-center text-2xl mb-4">Besoin d'aide personnalisée ?</h2>
        <p class="mb-6">Notre équipe de support est disponible pour vous aider avec tous vos besoins.</p>
        <div class="flex justify-center gap-4">
          <%= link_to "Contacter le Support", new_support_ticket_path, 
              class: "btn btn-accent" %>
          <%= link_to "Guide des Litiges", help_dispute_guidelines_path, 
              class: "btn btn-outline btn-accent" %>
        </div>
      </div>
    </div>
  </div>
</div>
