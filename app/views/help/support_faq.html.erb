<div class="container mx-auto px-4 py-8 max-w-4xl">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">FAQ - Questions Fréquemment Posées</h1>
    <p class="text-xl text-gray-600">Trouvez rapidement les réponses aux questions les plus courantes</p>
  </div>

  <!-- Search -->
  <div class="card bg-base-100 shadow-xl mb-8">
    <div class="card-body">
      <div class="form-control">
        <div class="input-group">
          <input type="text" id="faq-search" placeholder="Rechercher dans la FAQ..." class="input input-bordered flex-1" />
          <button class="btn btn-square">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <%= link_to new_support_ticket_path, 
        class: "card bg-gradient-to-r from-primary to-primary-focus text-white hover:shadow-lg transition-shadow" do %>
      <div class="card-body text-center py-6">
        <div class="text-3xl mb-2">🎧</div>
        <h3 class="font-semibold">Contacter le Support</h3>
        <p class="text-sm opacity-90">Créer un ticket</p>
      </div>
    <% end %>

    <%= link_to new_dispute_path, 
        class: "card bg-gradient-to-r from-error to-error-focus text-white hover:shadow-lg transition-shadow" do %>
      <div class="card-body text-center py-6">
        <div class="text-3xl mb-2">⚖️</div>
        <h3 class="font-semibold">Ouvrir un Litige</h3>
        <p class="text-sm opacity-90">Signaler un problème</p>
      </div>
    <% end %>

    <%= link_to help_dispute_guidelines_path, 
        class: "card bg-gradient-to-r from-info to-info-focus text-white hover:shadow-lg transition-shadow" do %>
      <div class="card-body text-center py-6">
        <div class="text-3xl mb-2">📋</div>
        <h3 class="font-semibold">Guide des Litiges</h3>
        <p class="text-sm opacity-90">Procédures détaillées</p>
      </div>
    <% end %>
  </div>

  <!-- FAQ Categories -->
  <div class="space-y-8">
    <% @faqs.each_with_index do |category_data, index| %>
      <div class="card bg-base-100 shadow-xl faq-category" data-category="<%= category_data[:category].downcase %>">
        <div class="card-body">
          <h2 class="card-title text-2xl mb-6 text-primary">
            <span class="badge badge-primary badge-lg mr-3"><%= index + 1 %></span>
            <%= category_data[:category] %>
          </h2>
          
          <div class="space-y-4">
            <% category_data[:questions].each_with_index do |qa, qa_index| %>
              <div class="collapse collapse-arrow bg-base-200 faq-item" 
                   data-question="<%= qa[:question].downcase %>" 
                   data-answer="<%= qa[:answer].downcase %>">
                <input type="checkbox" class="peer" id="faq-<%= index %>-<%= qa_index %>" />
                <div class="collapse-title text-lg font-medium peer-checked:bg-primary peer-checked:text-primary-content">
                  <label for="faq-<%= index %>-<%= qa_index %>" class="cursor-pointer w-full block">
                    <%= qa[:question] %>
                  </label>
                </div>
                <div class="collapse-content peer-checked:bg-primary peer-checked:text-primary-content">
                  <p class="pt-4"><%= qa[:answer] %></p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Contact Section -->
  <div class="mt-12">
    <div class="card bg-gradient-to-r from-secondary to-secondary-focus text-white">
      <div class="card-body text-center">
        <h2 class="card-title justify-center text-2xl mb-4">Vous ne trouvez pas votre réponse ?</h2>
        <p class="mb-6">Notre équipe de support est là pour vous aider avec toutes vos questions spécifiques.</p>
        <div class="flex justify-center gap-4">
          <%= link_to "Créer un Ticket de Support", new_support_ticket_path, 
              class: "btn btn-accent" %>
          <%= link_to "Retour à l'Aide", help_path, 
              class: "btn btn-outline btn-accent" %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('faq-search');
    const faqCategories = document.querySelectorAll('.faq-category');
    const faqItems = document.querySelectorAll('.faq-item');

    searchInput.addEventListener('input', function() {
      const searchTerm = this.value.toLowerCase();
      
      if (searchTerm === '') {
        // Show all categories and items
        faqCategories.forEach(category => category.style.display = 'block');
        faqItems.forEach(item => item.style.display = 'block');
      } else {
        // Hide all first
        faqCategories.forEach(category => category.style.display = 'none');
        faqItems.forEach(item => item.style.display = 'none');

        // Show matching items and their categories
        faqItems.forEach(item => {
          const question = item.dataset.question;
          const answer = item.dataset.answer;
          
          if (question.includes(searchTerm) || answer.includes(searchTerm)) {
            item.style.display = 'block';
            item.closest('.faq-category').style.display = 'block';
          }
        });
      }
    });
  });
</script>
