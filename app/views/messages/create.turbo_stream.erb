<%= turbo_stream.append "message-list", id: "message_#{@message.id}" do %>
  <%= render "messages/message", message: @message, current_user_id: current_user.id %>
<% end %>

<%= turbo_stream.update "new_message" do %>
  <%= form_with model: Message.new, url: messages_path(user_id: @recipient.id), data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |f| %>
    <div class="flex gap-3">
      <%= f.text_field :content,
        class: "flex-1 bg-bg-primary border border-line-strong text-text-primary px-4 py-3 font-body text-sm focus:border-accent-red focus:outline-none transition-[border-color] duration-300",
        placeholder: "Votre message…", autofocus: true, required: true %>
      <%= f.submit "Envoyer", class: "btn-vera-primary text-[11px] px-6 py-3 cursor-pointer" %>
    </div>
  <% end %>
<% end %>
