<%= turbo_stream_from ["user", current_user.id, "messages"] %>

<div class="container mx-auto max-w-screen-lg py-8">
  <div class="flex items-center mb-6">
    <div class="flex-1">
      <h1 class="text-2xl font-bold">Conversation avec <%= @recipient.email %></h1>
    </div>
    <div>
      <%= link_to "Retour", messages_path, class: "px-4 py-2 bg-gray-200 rounded hover:bg-gray-300 transition duration-150" %>
    </div>
  </div>
  
  <div class="bg-white rounded-lg shadow-md mb-6 h-96 overflow-y-auto p-4" id="messages" data-controller="chat-scroll">
    <%= render partial: "messages/messages", locals: { messages: @messages, current_user_id: current_user.id } %>
  </div>
  
  <%= turbo_frame_tag "new_message" do %>
    <%= form_with model: @message, url: messages_path(user_id: @recipient.id), data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |f| %>
      <div class="flex">
        <%= f.text_field :content, placeholder: "Votre message...", class: "flex-1 border border-gray-300 rounded-l-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", autofocus: true, required: true %>
        <%= f.submit "Envoyer", class: "bg-blue-500 text-white px-4 py-2 rounded-r-lg hover:bg-blue-600 transition duration-150" %>
      </div>
    <% end %>
  <% end %>
</div>
