<!-- Hero Section -->
<div class="relative bg-gradient-to-r from-primary to-primary-focus text-primary-content py-16 mb-12">
  <div class="absolute inset-0 bg-[url('/images/car-pattern.svg')] opacity-10"></div>
  <div class="container mx-auto px-4 relative">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Messages</h1>
    <p class="text-lg opacity-90">Communiquez avec les vendeurs et acheteurs</p>
  </div>
</div>

<!-- Main Content -->
<div class="max-w-7xl mx-auto p-6">
  <div class="bg-base-100 shadow-xl rounded-xl overflow-hidden">
    <!-- Header -->
    <div class="bg-gradient-to-r from-primary to-primary-focus text-primary-content p-6">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold">Messagerie</h1>
          <p class="opacity-90">Gérez vos conversations avec les acheteurs et vendeurs</p>
        </div>
        <div class="flex items-center space-x-4">
          <div class="badge badge-primary-content text-primary">
            <%= pluralize(@conversations.count, 'conversation') %> active<%= 's' if @conversations.count > 1 %>
          </div>
          <% if current_user.unread_messages_count > 0 %>
            <div class="badge badge-error" id="notification-badge">
              <%= current_user.unread_messages_count %> non lu<%= 's' if current_user.unread_messages_count > 1 %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="flex h-[600px]">
      <!-- Conversations Sidebar -->
      <div class="w-1/3 border-r border-base-300 bg-base-50">
        <!-- Tabs for Active/Archived -->
        <div class="tabs tabs-boxed p-4">
          <a class="tab tab-active" data-tab="active">Actives</a>
          <a class="tab" data-tab="archived">Archivées</a>
        </div>

        <!-- Active Conversations -->
        <div id="active-conversations" class="tab-content">
          <% if @conversations.any? %>
            <% @conversations.each do |conversation| %>
              <div class="conversation-item p-4 border-b border-base-200 hover:bg-base-100 cursor-pointer" 
                   id="conversation-<%= conversation.id %>"
                   data-conversation-id="<%= conversation.id %>">
                <%= link_to conversation_path(conversation), class: "block" do %>
                  <div class="flex items-center space-x-3">
                    <div class="avatar">
                      <div class="w-12 h-12 rounded-full bg-primary text-primary-content flex items-center justify-center">
                        <%= conversation.other_participant(current_user).email.first.upcase %>
                      </div>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center justify-between">
                        <h3 class="font-semibold truncate">
                          <%= conversation.other_participant(current_user).email %>
                        </h3>
                        <% if conversation.last_message %>
                          <span class="text-xs text-base-content opacity-60">
                            il y a <%= time_ago_in_words(conversation.last_message.created_at) %>
                          </span>
                        <% end %>
                      </div>
                      <% if conversation.listing %>
                        <p class="text-sm text-primary">
                          🚗 <%= conversation.listing.title %>
                        </p>
                      <% end %>
                      <% if conversation.last_message %>
                        <p class="text-sm text-base-content opacity-70 truncate">
                          <%= conversation.last_message.content %>
                        </p>
                      <% end %>
                      <% if conversation.unread_count_for(current_user) > 0 %>
                        <div class="badge badge-primary badge-sm mt-1">
                          <%= conversation.unread_count_for(current_user) %>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>
                
                <!-- Archive button -->
                <div class="mt-2 flex justify-end">
                  <%= button_to "Archiver", archive_conversation_messages_path, 
                      params: { conversation_id: conversation.id },
                      method: :post,
                      class: "btn btn-ghost btn-xs",
                      data: { turbo_method: :post } %>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="p-8 text-center">
              <div class="text-6xl mb-4">💬</div>
              <h3 class="text-lg font-semibold mb-2">Aucune conversation</h3>
              <p class="text-base-content opacity-70">Vos conversations apparaîtront ici</p>
            </div>
          <% end %>
        </div>

        <!-- Archived Conversations -->
        <div id="archived-conversations" class="tab-content hidden">
          <% if @archived_conversations.any? %>
            <% @archived_conversations.each do |conversation| %>
              <div class="conversation-item p-4 border-b border-base-200 hover:bg-base-100 cursor-pointer opacity-60" 
                   id="archived-conversation-<%= conversation.id %>">
                <%= link_to conversation_path(conversation), class: "block" do %>
                  <div class="flex items-center space-x-3">
                    <div class="avatar">
                      <div class="w-12 h-12 rounded-full bg-base-300 text-base-content flex items-center justify-center">
                        <%= conversation.other_participant(current_user).email.first.upcase %>
                      </div>
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3 class="font-semibold truncate">
                        <%= conversation.other_participant(current_user).email %>
                      </h3>
                      <% if conversation.listing %>
                        <p class="text-sm text-base-content opacity-50">
                          🚗 <%= conversation.listing.title %>
                        </p>
                      <% end %>
                    </div>
                  </div>
                <% end %>
                
                <!-- Unarchive button -->
                <div class="mt-2 flex justify-end">
                  <%= button_to "Restaurer", unarchive_conversation_messages_path, 
                      params: { conversation_id: conversation.id },
                      method: :post,
                      class: "btn btn-ghost btn-xs",
                      data: { turbo_method: :post } %>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="p-8 text-center">
              <div class="text-6xl mb-4">📦</div>
              <h3 class="text-lg font-semibold mb-2">Aucune conversation archivée</h3>
              <p class="text-base-content opacity-70">Les conversations archivées apparaîtront ici</p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Message Templates Sidebar -->
      <div class="w-1/3 bg-base-50 p-4">
        <h3 class="text-lg font-semibold mb-4">Modèles de messages</h3>
        
        <!-- Template Categories -->
        <div class="tabs tabs-boxed tabs-xs mb-4">
          <% MessageTemplate.categories.keys.each do |category| %>
            <a class="tab <%= 'tab-active' if category == 'greeting' %>" 
               data-category="<%= category %>">
              <%= MessageTemplate.category_in_french(category) %>
            </a>
          <% end %>
        </div>

        <!-- Template List -->
        <div id="template-list" class="space-y-2">
          <% @message_templates.each do |template| %>
            <div class="card bg-base-100 shadow-sm">
              <div class="card-body p-3">
                <h4 class="card-title text-sm"><%= template.title %></h4>
                <p class="text-xs text-base-content opacity-70 line-clamp-2">
                  <%= template.content %>
                </p>
                <div class="card-actions justify-end">
                  <button class="btn btn-primary btn-xs" 
                          data-template-id="<%= template.id %>"
                          data-template-content="<%= template.content %>">
                    Utiliser
                  </button>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Add New Template -->
        <div class="mt-4">
          <button class="btn btn-outline btn-sm w-full" onclick="new_template_modal.showModal()">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            Nouveau modèle
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- New Template Modal -->
<dialog id="new_template_modal" class="modal">
  <div class="modal-box">
    <h3 class="font-bold text-lg">Nouveau modèle de message</h3>
    <%= form_with model: MessageTemplate.new, url: message_templates_path, local: true, class: "space-y-4 mt-4" do |form| %>
      <div class="form-control">
        <%= form.label :title, "Titre", class: "label" %>
        <%= form.text_field :title, class: "input input-bordered w-full", placeholder: "Titre du modèle" %>
      </div>
      
      <div class="form-control">
        <%= form.label :category, "Catégorie", class: "label" %>
        <%= form.select :category, MessageTemplate.categories.keys.map { |k| [MessageTemplate.category_in_french(k), k] }, 
            { include_blank: "Sélectionnez une catégorie" }, 
            { class: "select select-bordered w-full" } %>
      </div>
      
      <div class="form-control">
        <%= form.label :content, "Contenu", class: "label" %>
        <%= form.text_area :content, rows: 4, class: "textarea textarea-bordered w-full", placeholder: "Contenu du message..." %>
      </div>
      
      <div class="modal-action">
        <button type="button" class="btn" onclick="new_template_modal.close()">Annuler</button>
        <%= form.submit "Créer", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</dialog>

<script>
document.addEventListener('turbo:load', function() {
  // Tab switching
  document.querySelectorAll('[data-tab]').forEach(tab => {
    tab.addEventListener('click', function() {
      const tabName = this.dataset.tab;
      
      // Update tab appearance
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('tab-active'));
      this.classList.add('tab-active');
      
      // Show/hide content
      document.querySelectorAll('.tab-content').forEach(content => {
        content.classList.add('hidden');
      });
      document.getElementById(`${tabName}-conversations`).classList.remove('hidden');
    });
  });
  
  // Template category switching
  document.querySelectorAll('[data-category]').forEach(tab => {
    tab.addEventListener('click', function() {
      const category = this.dataset.category;
      
      // Update tab appearance
      document.querySelectorAll('[data-category]').forEach(t => t.classList.remove('tab-active'));
      this.classList.add('tab-active');
      
      // Load templates for this category
      fetch(`/messages/templates?category=${category}`, {
        headers: {
          'Accept': 'application/vnd.turbo-stream.html'
        }
      });
    });
  });
});
</script>
