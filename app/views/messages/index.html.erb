<div class="max-w-[1440px] mx-auto px-5 md:px-10 py-12 md:py-20">
  <%# Header %>
  <div class="mb-10 border-b border-line pb-8">
    <div class="font-ui text-[11px] font-semibold uppercase tracking-[0.22em] text-accent-red mb-4">
      Messagerie
    </div>
    <h1 class="font-display playfair-italic text-4xl md:text-6xl text-text-primary leading-[0.96] tracking-[-0.015em]">
      Conversations
    </h1>
    <p class="font-body italic text-text-secondary mt-3">
      Échangez avec les vendeurs et acheteurs de la communauté.
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[360px_1fr] gap-0 border border-line min-h-[600px]">
    <%# Sidebar — conversation list %>
    <div class="border-r border-line bg-bg-secondary overflow-y-auto">
      <div class="p-4 border-b border-line">
        <div class="font-ui text-[11px] font-semibold uppercase tracking-[0.14em] text-text-muted">
          <%= @conversations.count %> conversation<%= @conversations.count > 1 ? "s" : "" %>
        </div>
      </div>

      <% @conversations.each do |conversation| %>
        <%= link_to conversation_path(conversation.other_user), class: "block px-5 py-4 border-b border-line hover:bg-bg-tertiary transition-colors duration-150 #{'bg-bg-tertiary' if @current_conversation == conversation}" do %>
          <div class="flex items-start gap-3">
            <%# Avatar %>
            <div class="w-10 h-10 rounded-full bg-accent-red/20 flex items-center justify-center shrink-0">
              <span class="font-ui text-[11px] font-bold text-accent-red uppercase">
                <%= conversation.other_user.public_display_name&.first(2)&.upcase || "??" %>
              </span>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline justify-between gap-2">
                <span class="font-ui text-sm font-medium text-text-primary truncate">
                  <%= conversation.other_user.public_display_name || conversation.other_user.email %>
                </span>
                <span class="font-mono text-[10px] text-text-muted tracking-wider shrink-0">
                  <%= conversation.last_message&.created_at&.strftime("%d/%m") %>
                </span>
              </div>
              <p class="font-body text-xs text-text-muted truncate mt-0.5">
                <%= conversation.last_message&.content&.truncate(60) %>
              </p>
            </div>
            <% if conversation.unread_count_for(current_user) > 0 %>
              <span class="w-5 h-5 flex items-center justify-center bg-accent-red text-text-primary font-mono text-[9px] font-bold shrink-0">
                <%= conversation.unread_count_for(current_user) %>
              </span>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <% if @conversations.empty? %>
        <div class="px-5 py-12 text-center">
          <p class="font-body text-sm text-text-muted italic">Aucune conversation.</p>
        </div>
      <% end %>
    </div>

    <%# Main — active conversation or empty state %>
    <div class="bg-bg-primary flex flex-col">
      <% if @current_conversation %>
        <%# Conversation header %>
        <div class="px-6 py-4 border-b border-line flex items-center gap-4">
          <div class="w-10 h-10 rounded-full bg-accent-red/20 flex items-center justify-center shrink-0">
            <span class="font-ui text-[11px] font-bold text-accent-red uppercase">
              <%= @current_conversation.other_user.public_display_name&.first(2)&.upcase || "??" %>
            </span>
          </div>
          <div>
            <div class="font-display text-lg text-text-primary font-medium">
              <%= @current_conversation.other_user.public_display_name %>
            </div>
            <div class="font-ui text-[11px] text-text-muted uppercase tracking-[0.14em]">
              Membre Vera Trade
            </div>
          </div>
        </div>

        <%# Messages %>
        <div class="flex-1 overflow-y-auto p-6 space-y-4" id="messages" data-controller="chat-scroll">
          <% @current_conversation.messages.each do |message| %>
            <div class="flex <%= message.sender == current_user ? 'justify-end' : 'justify-start' %>">
              <div class="max-w-[70%] px-4 py-3 <%= message.sender == current_user ? 'bg-accent-red/15 border border-accent-red/20' : 'bg-bg-secondary border border-line' %>">
                <p class="font-body text-sm text-text-primary"><%= message.content %></p>
                <p class="font-mono text-[10px] text-text-muted mt-1.5 tracking-wider">
                  <%= message.created_at.strftime("%H:%M") %>
                </p>
              </div>
            </div>
          <% end %>
        </div>

        <%# Input %>
        <div class="p-4 border-t border-line">
          <%= form_with model: Message.new, url: messages_path(user_id: @current_conversation.other_user.id), data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |f| %>
            <div class="flex gap-3">
              <%= f.text_field :content,
                class: "flex-1 bg-bg-secondary border border-line text-text-primary px-4 py-3 font-body text-sm focus:border-accent-red focus:outline-none transition-[border-color] duration-300",
                placeholder: "Votre message…", autofocus: true, required: true %>
              <%= f.submit "Envoyer", class: "btn-vera-primary text-[11px] px-5 py-3 cursor-pointer" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <%# Empty state %>
        <div class="flex-1 flex items-center justify-center">
          <div class="text-center max-w-xs">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="square" class="mx-auto mb-5 text-text-faint">
              <path d="M4 9v6h4l5 4V5L8 9zM17 9a4 4 0 0 1 0 6"/>
            </svg>
            <h3 class="font-display playfair-italic text-xl text-text-primary mb-2">Sélectionnez une conversation</h3>
            <p class="font-body text-sm text-text-muted italic leading-relaxed">
              Choisissez un échange dans la liste à gauche pour afficher les messages.
            </p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
