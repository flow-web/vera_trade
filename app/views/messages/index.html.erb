<!-- Hero Section -->
<div class="relative bg-gradient-to-r from-primary to-primary-focus text-primary-content py-16 mb-12">
  <div class="absolute inset-0 bg-[url('/images/car-pattern.svg')] opacity-10"></div>
  <div class="container mx-auto px-4 relative">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Messages</h1>
    <p class="text-lg opacity-90">Communiquez avec les vendeurs et acheteurs</p>
  </div>
</div>

<!-- Main Content -->
<div class="container mx-auto px-4 pb-16">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Conversations List -->
    <div class="lg:col-span-1">
      <div class="bg-base-100 rounded-lg shadow-xl p-6">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold">Conversations</h2>
          <button class="btn btn-primary btn-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Nouveau message
          </button>
        </div>
        
        <!-- Search Bar -->
        <div class="relative mb-6">
          <input type="text" placeholder="Rechercher une conversation..." class="input input-bordered w-full pl-10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 absolute left-3 top-3 text-base-content opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>

        <!-- Conversations -->
        <div class="space-y-4">
          <% @conversations.each do |conversation| %>
            <div class="flex items-center space-x-4 p-4 rounded-lg hover:bg-base-200 cursor-pointer transition-colors duration-200">
              <div class="avatar">
                <div class="w-12 h-12 rounded-full">
                  <img src="<%= conversation.other_user.avatar_url || (conversation.other_user.name ? 'https://ui-avatars.com/api/?name=' + conversation.other_user.name : 'https://ui-avatars.com/api/') %>" alt="<%= conversation.other_user.name %>">
                </div>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium truncate"><%= conversation.other_user.name %></p>
                <p class="text-sm text-base-content opacity-70 truncate"><%= conversation.last_message&.content %></p>
              </div>
              <div class="text-right">
                <p class="text-xs text-base-content opacity-50"><%= conversation.last_message&.created_at %></p>
                <% if conversation.unread_count_for(current_user) > 0 %>
                  <span class="badge badge-primary badge-sm"><%= conversation.unread_count_for(current_user) %></span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Messages -->
    <div class="lg:col-span-2">
      <div class="bg-base-100 rounded-lg shadow-xl p-6">
        <% if @current_conversation %>
          <!-- Conversation Header -->
          <div class="flex items-center space-x-4 mb-6 pb-4 border-b border-base-300">
            <div class="avatar">
              <div class="w-12 h-12 rounded-full">
                <img src="<%= @current_conversation.other_user.avatar_url || 'https://ui-avatars.com/api/?name=' + @current_conversation.other_user.name %>" alt="<%= @current_conversation.other_user.name %>">
              </div>
            </div>
            <div>
              <h3 class="text-lg font-bold"><%= @current_conversation.other_user.name %></h3>
              <p class="text-sm text-base-content opacity-70">En ligne</p>
            </div>
          </div>

          <!-- Messages List -->
          <div class="space-y-4 mb-6 max-h-[500px] overflow-y-auto">
            <% @current_conversation.messages.each do |message| %>
              <div class="flex <%= message.sender == current_user ? 'justify-end' : 'justify-start' %>">
                <div class="<%= message.sender == current_user ? 'bg-primary text-primary-content' : 'bg-base-200' %> rounded-lg px-4 py-2 max-w-[70%]">
                  <p class="text-sm"><%= message.content %></p>
                  <p class="text-xs opacity-70 mt-1"><%= message.created_at.strftime('%H:%M') %></p>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Message Input -->
          <div class="flex space-x-4">
            <input type="text" placeholder="Écrivez votre message..." class="input input-bordered flex-1">
            <button class="btn btn-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
            </button>
          </div>
        <% else %>
          <!-- Empty State -->
          <div class="text-center py-12">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto text-base-content opacity-20 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            <h3 class="text-xl font-bold mb-2">Aucune conversation sélectionnée</h3>
            <p class="text-base-content opacity-70">Sélectionnez une conversation ou créez-en une nouvelle</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
