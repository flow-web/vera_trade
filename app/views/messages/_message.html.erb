<div id="message_<%= message.id %>" class="flex <%= message.sender_id == current_user_id ? 'justify-end' : 'justify-start' %>">
  <div class="max-w-[70%] px-4 py-3 <%= message.sender_id == current_user_id ? 'bg-accent-red/15 border border-accent-red/20' : 'bg-bg-tertiary border border-line' %>">
    <p class="font-body text-sm text-text-primary"><%= message.content %></p>
    <p class="font-mono text-[10px] text-text-muted mt-1.5 tracking-wider">
      <%= message.created_at.strftime("%H:%M") %>
    </p>
  </div>
</div>
