<div class="min-h-screen flex items-center justify-center px-5">
  <div class="w-full max-w-sm">
    <%# Header — centered editorial %>
    <div class="text-center mb-10">
      <div class="font-ui text-[11px] font-semibold uppercase tracking-[0.22em] text-rosso-bright mb-4">
        Vera Trade · Vérification
      </div>
      <h1 class="font-display text-[clamp(26px,4vw,36px)] font-medium text-text-primary leading-[0.96] tracking-[-0.015em] mb-3">
        Code <span class="italic font-normal">d'authentification</span>
      </h1>
      <p class="font-body text-sm text-text-secondary leading-relaxed">
        Entrez le code à 6 chiffres depuis votre application d'authentification.
      </p>
    </div>

    <div class="border border-line-strong bg-bg-secondary">
      <%# Visual lock icon header %>
      <div class="px-6 py-5 border-b border-line flex items-center justify-center gap-3">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" class="text-accent-red">
          <path d="M12 3 4 6v6c0 5 3.5 8 8 9 4.5-1 8-4 8-9V6z"/>
        </svg>
        <span class="font-ui text-[11px] font-semibold uppercase tracking-[0.18em] text-text-muted">
          Connexion sécurisée
        </span>
      </div>

      <div class="px-6 py-8">
        <%= form_with url: two_factor_verify_path, method: :post, class: "space-y-6" do |f| %>
          <div>
            <label class="block font-ui text-[11px] font-semibold uppercase tracking-[0.14em] text-text-muted mb-3 text-center">
              Code à 6 chiffres
            </label>
            <%= f.text_field :otp_code,
              class: "w-full bg-bg-primary border border-line-strong text-text-primary px-4 py-4 font-mono text-2xl tracking-[0.5em] text-center focus:border-accent-red focus:outline-none transition-[border-color] duration-300",
              maxlength: 6, autocomplete: "one-time-code", inputmode: "numeric",
              pattern: "[0-9]{6}", required: true, autofocus: true %>
          </div>

          <%= f.submit "Vérifier", class: "w-full btn-vera-primary text-[11px] py-3.5 cursor-pointer" %>
        <% end %>

        <div class="mt-6 pt-5 border-t border-line text-center">
          <p class="font-ui text-[11px] text-text-muted leading-relaxed">
            Vous n'avez pas accès à votre application ?
            <br>
            <%= link_to "Retour à la connexion", new_user_session_path, class: "text-rosso-bright hover:text-accent-red transition-colors" %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
