<%#
  Footer éditorial — Cinematic Archivist v2 (racing green).
  4 colonnes + newsletter "Le Hangar", wordmark deco géant en arrière-plan.
%>
<footer class="relative overflow-hidden bg-bg-primary border-t border-line pt-20 lg:pt-28 <%= user_signed_in? ? 'pb-32 lg:pb-12' : 'pb-12' %> mt-20 lg:mt-32">

  <%# Wordmark décoratif géant %>
  <div aria-hidden="true" class="wordmark-deco absolute -bottom-6 lg:-bottom-12 left-0 right-0 text-[8rem] sm:text-[12rem] lg:text-[16rem] xl:text-[18rem] leading-[0.8] text-center whitespace-nowrap">
    Vera &amp; Trade
  </div>

  <div class="relative max-w-[1680px] mx-auto px-5 lg:px-10 grid grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr_1.2fr] gap-10 lg:gap-12 z-10">

    <%# ─────────── Col 1 — Manifeste %>
    <div class="col-span-2 lg:col-span-1">
      <div class="playfair-italic text-[2rem] font-semibold tracking-[-0.02em] text-text-primary leading-none">
        Vera<span class="text-racing-bright">&amp;</span>Trade
      </div>
      <p class="font-body italic text-sm text-text-secondary leading-relaxed max-w-[300px] mt-5">
        Marketplace française dédiée aux youngtimers, voitures de collection abordables, JDM, préparations rallye et race cars. Le magazine des voitures qui ont une âme.
      </p>
    </div>

    <%# ─────────── Col 2 — Acheter %>
    <div>
      <h4 class="font-ui text-[10px] font-semibold uppercase tracking-[0.25em] text-text-primary mb-5">Acheter</h4>
      <ul class="space-y-3">
        <li><%= link_to "Catalogue", listings_path, class: "font-ui text-[12px] text-text-muted hover:text-text-primary transition-colors" %></li>
        <li><span class="font-ui text-[12px] text-text-faint cursor-not-allowed">Enchères live</span></li>
        <li><span class="font-ui text-[12px] text-text-faint cursor-not-allowed">Échange véhicule</span></li>
        <li><span class="font-ui text-[12px] text-text-faint cursor-not-allowed">Inspection experte</span></li>
        <li><span class="font-ui text-[12px] text-text-faint cursor-not-allowed">Convoyage</span></li>
      </ul>
    </div>

    <%# ─────────── Col 3 — Vendre %>
    <div>
      <h4 class="font-ui text-[10px] font-semibold uppercase tracking-[0.25em] text-text-primary mb-5">Vendre</h4>
      <ul class="space-y-3">
        <li><%= link_to (user_signed_in? ? "Publier une annonce" : "Estimation gratuite"),
                       (user_signed_in? ? new_listing_wizard_path : new_user_registration_path),
                       class: "font-ui text-[12px] text-text-muted hover:text-text-primary transition-colors" %></li>
        <li><span class="font-ui text-[12px] text-text-faint cursor-not-allowed">Programme Pro</span></li>
        <li><span class="font-ui text-[12px] text-text-faint cursor-not-allowed">Tarifs &amp; commissions</span></li>
        <li><span class="font-ui text-[12px] text-text-faint cursor-not-allowed">FAQ vendeur</span></li>
      </ul>
    </div>

    <%# ─────────── Col 4 — Magazine %>
    <div>
      <h4 class="font-ui text-[10px] font-semibold uppercase tracking-[0.25em] text-text-primary mb-5">Magazine</h4>
      <ul class="space-y-3">
        <li><span class="font-ui text-[12px] text-text-faint cursor-not-allowed">Essais &amp; tests</span></li>
        <li><span class="font-ui text-[12px] text-text-faint cursor-not-allowed">Guides d'achat</span></li>
        <li><span class="font-ui text-[12px] text-text-faint cursor-not-allowed">Reportages</span></li>
        <li><span class="font-ui text-[12px] text-text-faint cursor-not-allowed">Évènements</span></li>
      </ul>
    </div>

    <%# ─────────── Col 5 — Newsletter "Le Hangar" %>
    <div class="col-span-2 lg:col-span-1">
      <h4 class="font-ui text-[10px] font-semibold uppercase tracking-[0.25em] text-text-primary mb-5">Newsletter — Le Hangar</h4>
      <p class="font-body text-[13px] text-text-muted leading-relaxed mb-5 max-w-[280px]">
        Un dimanche sur deux, dans votre boîte. Une voiture, une histoire, une analyse marché. Pas de spam, jamais.
      </p>
      <form action="#" method="post" class="flex border border-line max-w-[320px]" onsubmit="event.preventDefault(); this.querySelector('button').textContent='Bientôt'; this.querySelector('button').disabled=true;">
        <input type="email"
               placeholder="votre@email.fr"
               aria-label="Votre adresse email"
               class="flex-1 bg-transparent border-0 text-text-primary font-body text-[13px] outline-none px-3 py-2.5 placeholder:italic placeholder:text-text-muted">
        <button type="submit" class="px-4 bg-racing-mid text-text-primary font-ui text-[11px] font-bold uppercase tracking-[0.15em] hover:bg-racing-deep transition-colors">
          →
        </button>
      </form>
      <p class="font-mono text-[10px] text-text-faint mt-3">Disponible bientôt</p>
    </div>
  </div>

  <%# ─────────── Bandeau inférieur (copyright + légal) %>
  <div class="relative z-10 max-w-[1680px] mx-auto px-5 lg:px-10 mt-16 lg:mt-20 pt-6 border-t border-line flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted">
      © 2026 Vera Trade · Lyon · Le magazine des voitures qui ont une âme
    </p>
    <ul class="flex flex-wrap items-center gap-6">
      <li><%= link_to "CGU", cgu_path, class: "font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted hover:text-text-primary transition-colors" %></li>
      <li><%= link_to "Confidentialité", confidentialite_path, class: "font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted hover:text-text-primary transition-colors" %></li>
      <li><%= link_to "Mentions légales", mentions_legales_path, class: "font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted hover:text-text-primary transition-colors" %></li>
      <li><span class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-faint">Fait en France, avec précision</span></li>
    </ul>
  </div>
</footer>
