<%#
  Footer éditorial — Organic Brutalism, wordmark décoratif géant en arrière-plan.
  4 colonnes desktop, FR strict, copyright 2026.
%>
<footer class="relative overflow-hidden bg-bg-primary border-t border-line pt-20 lg:pt-28 pb-16 lg:pb-12 mt-20 lg:mt-32 <%= user_signed_in? ? 'pb-32 lg:pb-12' : 'pb-16' %>">

  <!-- Wordmark décoratif -->
  <div aria-hidden="true" class="wordmark-deco absolute -bottom-6 lg:-bottom-10 -right-4 lg:-right-8 text-[8rem] sm:text-[12rem] lg:text-[18rem] leading-none">
    Vera
  </div>

  <div class="relative max-w-[1600px] mx-auto px-5 lg:px-10 grid grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-16 z-10">

    <!-- Col 1 — Manifeste -->
    <div class="col-span-2 lg:col-span-1">
      <div class="font-ui text-[14px] font-black tracking-[0.18em] uppercase text-text-primary mb-8">
        Vera Trade
      </div>
      <p class="font-body italic text-sm text-text-secondary leading-relaxed max-w-[280px]">
        Le magazine des voitures qui ont une âme. Youngtimers, collection et compétition, pour celles et ceux qui préfèrent une vraie histoire à un taux d'intérêt.
      </p>
    </div>

    <!-- Col 2 — Explorer -->
    <div>
      <h4 class="label-small text-accent-red mb-6">Explorer</h4>
      <ul class="space-y-4">
        <li><%= link_to "Catalogue", listings_path, class: "font-ui text-[11px] uppercase tracking-[0.15em] text-text-muted hover:text-text-primary transition-colors" %></li>
        <li><span class="font-ui text-[11px] uppercase tracking-[0.15em] text-text-muted/60 cursor-not-allowed">Le Journal</span></li>
        <li><span class="font-ui text-[11px] uppercase tracking-[0.15em] text-text-muted/60 cursor-not-allowed">Enchères</span></li>
        <li><span class="font-ui text-[11px] uppercase tracking-[0.15em] text-text-muted/60 cursor-not-allowed">Expertises</span></li>
      </ul>
    </div>

    <!-- Col 3 — Services -->
    <div>
      <h4 class="label-small text-accent-red mb-6">Services</h4>
      <ul class="space-y-4">
        <li><%= link_to "Publier une annonce", (user_signed_in? ? new_listing_path : new_user_registration_path), class: "font-ui text-[11px] uppercase tracking-[0.15em] text-text-muted hover:text-text-primary transition-colors" %></li>
        <li><span class="font-ui text-[11px] uppercase tracking-[0.15em] text-text-muted/60 cursor-not-allowed">Rust Map</span></li>
        <li><span class="font-ui text-[11px] uppercase tracking-[0.15em] text-text-muted/60 cursor-not-allowed">Estimation gratuite</span></li>
        <li><span class="font-ui text-[11px] uppercase tracking-[0.15em] text-text-muted/60 cursor-not-allowed">Paiement sécurisé</span></li>
      </ul>
    </div>

    <!-- Col 4 — Contact + légal -->
    <div>
      <h4 class="label-small text-accent-red mb-6">Contact</h4>
      <p class="font-mono text-[11px] uppercase tracking-[0.1em] text-text-muted mb-2">
        bonjour@veratrade.fr
      </p>
      <p class="font-mono text-[11px] uppercase tracking-[0.1em] text-text-muted mb-6">
        Lyon · Paris · Bordeaux · Marseille
      </p>
      <ul class="space-y-3 pt-6 border-t border-line">
        <li><span class="font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted/60 cursor-not-allowed">Conditions Générales</span></li>
        <li><span class="font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted/60 cursor-not-allowed">Politique de Confidentialité</span></li>
        <li><span class="font-ui text-[10px] uppercase tracking-[0.15em] text-text-muted/60 cursor-not-allowed">Mentions légales</span></li>
      </ul>
    </div>
  </div>

  <!-- Bande inférieure -->
  <div class="relative z-10 max-w-[1600px] mx-auto px-5 lg:px-10 mt-20 lg:mt-24 pt-8 border-t border-line flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted">
      © 2026 Vera Trade · Le magazine des voitures qui ont une âme
    </p>
    <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted">
      Fait en France, avec précision
    </p>
  </div>
</footer>
