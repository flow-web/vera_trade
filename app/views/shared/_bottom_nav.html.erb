<%#
  Bottom navigation mobile — visible lg:hidden. Fond solide bg-bg-primary,
  border-top 1px #2A2A2A, SVG custom line icons, labels FR.
%>
<nav class="bottom-nav-vera lg:hidden fixed bottom-0 inset-x-0 z-[100] bg-bg-primary border-t border-line"
     style="padding-bottom: env(safe-area-inset-bottom, 0px);"
     aria-label="Navigation mobile">
  <div class="grid grid-cols-5 h-[62px]">

    <!-- Catalogue -->
    <% catalogue_active = request.path.start_with?("/listings") && request.path == "/listings" %>
    <%= link_to listings_path, class: "flex flex-col items-center justify-center gap-1 #{catalogue_active ? 'text-accent-red' : 'text-text-muted'} transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <span class="font-ui text-[9px] uppercase tracking-[0.15em]">Catalogue</span>
    <% end %>

    <!-- Favoris -->
    <% favorites_active = request.path == "/favorites" %>
    <%= link_to favorites_path, class: "flex flex-col items-center justify-center gap-1 #{favorites_active ? 'text-accent-red' : 'text-text-muted'} transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span class="font-ui text-[9px] uppercase tracking-[0.15em]">Favoris</span>
    <% end %>

    <!-- Publier (CTA central, accent rouge) -->
    <%= link_to new_listing_path, class: "flex flex-col items-center justify-center gap-1 text-accent-red" do %>
      <div class="flex items-center justify-center w-9 h-9 bg-accent-red text-text-primary border border-accent-red -mt-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14M5 12h14"/>
        </svg>
      </div>
      <span class="font-ui text-[9px] uppercase tracking-[0.15em]">Publier</span>
    <% end %>

    <!-- Messagerie -->
    <% messages_active = request.path.start_with?("/messages") || request.path.start_with?("/conversations") %>
    <%= link_to messages_path, class: "flex flex-col items-center justify-center gap-1 #{messages_active ? 'text-accent-red' : 'text-text-muted'} transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <span class="font-ui text-[9px] uppercase tracking-[0.15em]">Messages</span>
    <% end %>

    <!-- Garage -->
    <% dashboard_active = request.path == "/dashboard" %>
    <%= link_to dashboard_path, class: "flex flex-col items-center justify-center gap-1 #{dashboard_active ? 'text-accent-red' : 'text-text-muted'} transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      <span class="font-ui text-[9px] uppercase tracking-[0.15em]">Garage</span>
    <% end %>
  </div>
</nav>
