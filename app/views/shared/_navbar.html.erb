<div class="navbar shadow-md" style="background-color: #011f3b; color: white;">
  <div class="navbar-start">
    <div class="dropdown">
      <div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" /></svg>
      </div>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
        <li><a href="/">Home</a></li>
        <li><a href="<%= listings_path %>">Annonces</a></li>
        <% if user_signed_in? %>
          <li><a href="<%= my_listings_path %>">Mes annonces</a></li>
          <li><a href="<%= new_listing_path %>">Publier une annonce</a></li>
          <li><a href="<%= messages_path %>">Messages</a></li>
        <% end %>
        <li><a>Services</a></li>
        <li><a>About Us</a></li>
        <li><a>Contact</a></li>
      </ul>
    </div>
    <ul class="menu menu-horizontal px-1 hidden lg:flex">
      <li><a href="/">Home</a></li>
      <li><a href="<%= listings_path %>">Annonces</a></li>
      <% if user_signed_in? %>
        <li><a href="<%= my_listings_path %>">Mes annonces</a></li>
      <% end %>
    </ul>
  </div>
  
  <div class="navbar-center">
    <a href="/" class="btn btn-ghost">
      <img src="/vta_logo.png" alt="VTA Logo" class="h-12" />
    </a>
  </div>
  
  <div class="navbar-end">
    <ul class="menu menu-horizontal px-1 hidden lg:flex">
      <% if user_signed_in? %>
        <li><a href="<%= new_listing_path %>">Publier une annonce</a></li>
        <li><a href="<%= messages_path %>">Messages</a></li>
      <% end %>
      <li><a>Services</a></li>
    </ul>
    <% if user_signed_in? %>
      <div class="dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar">
          <div class="w-10 rounded-full">
            <img alt="User Avatar" src="https://ui-avatars.com/api/?name=<%= current_user.email.split('@').first %>&background=random" />
          </div>
        </div>
        <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
          <li><a>Profile</a></li>
          <li><a href="<%= edit_user_registration_path %>">Settings</a></li>
          <li><%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete } %></li>
        </ul>
      </div>
    <% else %>
      <%= link_to "Sign in", new_user_session_path, class: "btn btn-ghost mr-2" %>
      <%= link_to "Register", new_user_registration_path, class: "btn btn-primary" %>
    <% end %>
  </div>
</div> 