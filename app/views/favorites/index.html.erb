<div class="max-w-[1440px] mx-auto px-5 md:px-10 py-12 md:py-20">
  <%# Header — editorial %>
  <div class="mb-12 md:mb-16 border-b border-line pb-8">
    <div class="font-ui text-[11px] font-semibold uppercase tracking-[0.22em] text-accent-red mb-4">
      Collection personnelle
    </div>
    <div class="flex items-end justify-between flex-wrap gap-6">
      <div>
        <h1 class="font-display playfair-italic text-4xl md:text-6xl text-text-primary leading-[0.96] tracking-[-0.015em]">
          Mes favoris
        </h1>
        <p class="font-body italic text-text-secondary mt-3">
          <%= pluralize(@listings.count, "véhicule suivi", "véhicules suivis") %>
        </p>
      </div>
      <%= link_to listings_path, class: "btn-vera-secondary text-[11px] px-5 py-2.5" do %>
        Parcourir le catalogue
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
      <% end %>
    </div>
  </div>

  <% if @listings.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <% @listings.each do |listing| %>
        <%= render "components/listing_card", listing: listing, size: "medium" %>
      <% end %>
    </div>
  <% else %>
    <%# Empty state — editorial %>
    <div class="text-center py-24 max-w-md mx-auto">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="square" class="mx-auto mb-6 text-text-faint">
        <path d="M7 3h10v18l-5-3.5L7 21z"/>
      </svg>
      <h2 class="font-display playfair-italic text-2xl text-text-primary mb-3">Aucun favori</h2>
      <p class="font-body text-sm text-text-secondary mb-8 leading-relaxed">
        Sauvegardez des véhicules pour les retrouver ici. Cliquez sur l'icône signet depuis n'importe quelle annonce.
      </p>
      <%= link_to listings_path, class: "btn-vera-primary text-[11px] px-6 py-3" do %>
        Parcourir les annonces
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
      <% end %>
    </div>
  <% end %>
</div>
