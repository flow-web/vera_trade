<div class="min-h-[80vh] flex items-center justify-center px-5 py-16">
  <div class="w-full max-w-lg">
    <%# Header — editorial chapter style %>
    <div class="mb-10">
      <div class="font-ui text-[11px] font-semibold uppercase tracking-[0.22em] text-rosso-bright mb-4">
        Configuration · Étape 2/2
      </div>
      <h1 class="font-display text-[clamp(28px,4vw,44px)] font-medium text-text-primary leading-[0.96] tracking-[-0.015em] mb-3">
        Scanner le <span class="italic font-normal">QR code</span>
      </h1>
      <p class="font-body text-[17px] leading-relaxed text-text-secondary">
        Ouvrez votre application d'authentification et scannez le code ci-dessous.
      </p>
    </div>

    <div class="border border-line-strong bg-bg-secondary">
      <%# Step indicators %>
      <div class="px-6 py-4 border-b border-line flex items-center gap-6">
        <div class="flex items-center gap-3">
          <span class="w-6 h-6 flex items-center justify-center font-mono text-[10px] font-semibold tracking-[0.14em] bg-patina/20 text-patina border border-patina/30">✓</span>
          <span class="font-ui text-[11px] uppercase tracking-[0.14em] text-patina font-semibold">Application</span>
        </div>
        <div class="w-8 h-px bg-line-strong"></div>
        <div class="flex items-center gap-3">
          <span class="w-6 h-6 flex items-center justify-center font-mono text-[10px] font-semibold tracking-[0.14em] bg-accent-red text-text-primary">2</span>
          <span class="font-ui text-[11px] uppercase tracking-[0.14em] text-text-primary font-semibold">Vérification</span>
        </div>
      </div>

      <%# QR Code %>
      <div class="px-6 pt-8 pb-6 flex justify-center">
        <div class="bg-white p-5 inline-block border border-line-strong">
          <%= @qr_svg.html_safe %>
        </div>
      </div>

      <%# Manual key %>
      <div class="px-6 pb-6">
        <div class="font-ui text-[11px] font-semibold uppercase tracking-[0.14em] text-text-muted mb-2">
          Clé secrète · saisie manuelle
        </div>
        <div class="bg-bg-primary border border-line px-4 py-3 text-center">
          <code class="font-mono text-sm tracking-[0.15em] text-text-primary select-all"><%= @secret %></code>
        </div>
        <p class="font-ui text-[11px] text-text-muted mt-2 leading-relaxed">
          Si vous ne pouvez pas scanner le QR code, entrez cette clé manuellement dans votre application.
        </p>
      </div>

      <div class="border-t border-line"></div>

      <%# Verification form %>
      <div class="px-6 py-6">
        <%= form_with url: enable_two_factor_path, method: :post, class: "space-y-5" do |f| %>
          <div>
            <label class="block font-ui text-[11px] font-semibold uppercase tracking-[0.14em] text-text-muted mb-2">
              Code de vérification à 6 chiffres
            </label>
            <%= f.text_field :otp_code,
              class: "w-full bg-bg-primary border border-line-strong text-text-primary px-4 py-3.5 font-mono text-xl tracking-[0.4em] text-center focus:border-accent-red focus:outline-none transition-[border-color] duration-300",
              maxlength: 6, autocomplete: "one-time-code", inputmode: "numeric",
              pattern: "[0-9]{6}", required: true, placeholder: "000000", autofocus: true %>
            <p class="font-ui text-[11px] text-text-muted mt-2">
              Entrez le code affiché dans votre application pour finaliser l'activation.
            </p>
          </div>
          <div class="flex items-center gap-4">
            <%= f.submit "Activer la 2FA", class: "btn-vera-primary text-[11px] px-6 py-3 cursor-pointer" %>
            <%= link_to "Annuler", two_factor_path, class: "font-ui text-xs text-text-muted hover:text-text-primary transition-colors" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
