<% content_for :title, "Carte Interactive - Véhicules" %>

<div class="min-h-screen bg-base-100">
  <!-- Header de la carte -->
  <div class="navbar bg-base-200 shadow-sm">
    <div class="flex-1">
      <h1 class="text-xl font-bold">🗺️ Carte Interactive</h1>
      <div class="text-sm text-base-content/70 ml-4">
        <%= @listings.count %> véhicule<%= 's' if @listings.count > 1 %> disponible<%= 's' if @listings.count > 1 %>
      </div>
    </div>
    <div class="flex-none">
      <%= link_to "Liste", listings_path, class: "btn btn-ghost btn-sm" %>
      <%= link_to "Ajouter une annonce", new_listing_path, class: "btn btn-primary btn-sm" %>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row h-[calc(100vh-4rem)]">
    <!-- Panneau de filtres (mobile/desktop) -->
    <div class="lg:w-80 bg-base-200 border-r border-base-300 overflow-y-auto">
      <div class="p-4">
        <h2 class="text-lg font-semibold mb-4">🔍 Filtres de recherche</h2>
        
        <%= form_with url: map_search_path, method: :get, 
                      data: { 
                        controller: "search",
                        action: "submit->search#filter",
                        search_target: "form"
                      }, 
                      local: false, 
                      class: "space-y-4" do |form| %>
          
          <!-- Filtre par marque et modèle -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="form-control">
              <%= form.label :make, "Marque", class: "label label-text font-medium" %>
              <%= form.text_field :make, 
                    value: params.dig(:search, :make),
                    placeholder: "Toyota, BMW...", 
                    class: "input input-bordered input-sm" %>
            </div>
            
            <div class="form-control">
              <%= form.label :model, "Modèle", class: "label label-text font-medium" %>
              <%= form.text_field :model, 
                    value: params.dig(:search, :model),
                    placeholder: "Corolla, X5...", 
                    class: "input input-bordered input-sm" %>
            </div>
          </div>

          <!-- Filtre par prix -->
          <div class="form-control">
            <label class="label label-text font-medium">💰 Prix</label>
            <div class="grid grid-cols-2 gap-2">
              <%= form.number_field :min_price, 
                    value: params.dig(:search, :min_price),
                    placeholder: "Min (€)", 
                    class: "input input-bordered input-sm", 
                    min: 0 %>
              <%= form.number_field :max_price, 
                    value: params.dig(:search, :max_price),
                    placeholder: "Max (€)", 
                    class: "input input-bordered input-sm", 
                    min: 0 %>
            </div>
          </div>

          <!-- Filtre par année -->
          <div class="form-control">
            <label class="label label-text font-medium">📅 Année</label>
            <div class="grid grid-cols-2 gap-2">
              <%= form.number_field :min_year, 
                    value: params.dig(:search, :min_year),
                    placeholder: "De", 
                    class: "input input-bordered input-sm", 
                    min: 1950, max: Date.current.year %>
              <%= form.number_field :max_year, 
                    value: params.dig(:search, :max_year),
                    placeholder: "À", 
                    class: "input input-bordered input-sm", 
                    min: 1950, max: Date.current.year %>
            </div>
          </div>

          <!-- Filtre par carburant -->
          <div class="form-control">
            <%= form.label :fuel_type, "⛽ Carburant", class: "label label-text font-medium" %>
            <%= form.select :fuel_type, 
                  options_for_select([
                    ['Tous', ''],
                    ['Essence', 'essence'],
                    ['Diesel', 'diesel'],
                    ['Électrique', 'electric'],
                    ['Hybride', 'hybrid'],
                    ['GPL', 'gpl']
                  ], params.dig(:search, :fuel_type)),
                  {}, 
                  { class: "select select-bordered select-sm" } %>
          </div>

          <!-- Filtre par transmission -->
          <div class="form-control">
            <%= form.label :transmission, "⚙️ Transmission", class: "label label-text font-medium" %>
            <%= form.select :transmission, 
                  options_for_select([
                    ['Toutes', ''],
                    ['Manuelle', 'manual'],
                    ['Automatique', 'automatic']
                  ], params.dig(:search, :transmission)),
                  {}, 
                  { class: "select select-bordered select-sm" } %>
          </div>

          <!-- Filtre par kilométrage -->
          <div class="form-control">
            <%= form.label :max_kilometers, "🚗 Kilométrage max", class: "label label-text font-medium" %>
            <%= form.number_field :max_kilometers, 
                  value: params.dig(:search, :max_kilometers),
                  placeholder: "ex: 100000", 
                  class: "input input-bordered input-sm", 
                  min: 0 %>
          </div>

          <!-- Filtre par distance -->
          <div class="form-control">
            <%= form.label :radius, "📍 Rayon de recherche", class: "label label-text font-medium" %>
            <%= form.select :radius, 
                  options_for_select([
                    ['Partout', ''],
                    ['10 km', '10'],
                    ['25 km', '25'],
                    ['50 km', '50'],
                    ['100 km', '100'],
                    ['200 km', '200']
                  ], params.dig(:search, :radius)),
                  {}, 
                  { class: "select select-bordered select-sm" } %>
          </div>

          <!-- Boutons d'action -->
          <div class="flex gap-2 pt-4">
            <%= form.submit "🔍 Filtrer", class: "btn btn-primary btn-sm flex-1" %>
            <%= link_to "🗑️ Effacer", map_index_path, class: "btn btn-ghost btn-sm" %>
          </div>
        <% end %>

        <!-- Options de la carte -->
        <div class="divider">Options</div>
        
        <div class="space-y-3">
          <div class="form-control">
            <label class="label cursor-pointer">
              <span class="label-text">🎯 Centrer automatiquement</span>
              <input type="checkbox" 
                     checked="<%= @map_options[:auto_center] %>" 
                     class="checkbox checkbox-primary checkbox-sm"
                     data-action="change->map#toggleAutoCenter">
            </label>
          </div>
          
          <div class="form-control">
            <label class="label cursor-pointer">
              <span class="label-text">🛣️ Afficher les itinéraires</span>
              <input type="checkbox" 
                     checked="<%= @map_options[:show_route] %>" 
                     class="checkbox checkbox-primary checkbox-sm"
                     data-action="change->map#toggleRoutes">
            </label>
          </div>
          
          <div class="form-control">
            <label class="label cursor-pointer">
              <span class="label-text">✏️ Dessiner des zones</span>
              <input type="checkbox" 
                     checked="<%= @map_options[:enable_drawing] %>" 
                     class="checkbox checkbox-primary checkbox-sm"
                     data-action="change->map#toggleDrawing">
            </label>
          </div>
        </div>

        <!-- Zones sauvegardées -->
        <div class="divider">Zones sauvegardées</div>
        <div id="saved-areas" class="space-y-2">
          <!-- Sera rempli par JavaScript -->
        </div>
      </div>
    </div>

    <!-- Conteneur de la carte -->
    <div class="flex-1 relative">
      <div 
        data-controller="map" 
        data-map-api-key-value="<%= @mapbox_token %>"
        data-map-listings-value="<%= @listings_data.to_json %>"
        data-map-auto-center-value="<%= @map_options[:auto_center] %>"
        data-map-show-route-value="<%= @map_options[:show_route] %>"
        data-map-enable-drawing-value="<%= @map_options[:enable_drawing] %>"
        data-action="map:showRoute->map#showRoute"
        class="w-full h-full map-container">
        
        <!-- La carte sera rendue ici -->
        <div data-map-target="map" class="w-full h-full"></div>
        
        <!-- Panneau d'informations de distance -->
        <div data-map-target="distanceInfo" class="map-info-panel lg:block hidden">
          <div class="text-sm text-base-content/70">
            <p class="font-medium mb-1">📍 Informations de position</p>
            <p>Activez la géolocalisation pour voir les distances</p>
          </div>
        </div>
        
        <!-- Panneau d'informations d'itinéraire -->
        <div data-map-target="routeInfo" class="hidden fixed bottom-4 right-4 z-10 bg-white rounded-lg shadow-lg p-4 max-w-sm">
          <!-- Les informations d'itinéraire apparaîtront ici -->
        </div>

        <!-- Loader -->
        <div class="map-loading">
          <div class="loading loading-spinner loading-lg text-primary"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Statistiques en bas (mobile) -->
  <div class="lg:hidden bg-base-200 p-4 border-t border-base-300">
    <div class="flex justify-between items-center text-sm">
      <span class="badge badge-primary">
        <%= @listings.count %> résultat<%= 's' if @listings.count > 1 %>
      </span>
      
      <div class="flex gap-2">
        <button class="btn btn-xs btn-ghost" onclick="document.querySelector('[data-controller=map]').querySelector('[data-map-target=map]').scrollIntoView()">
          🗺️ Voir la carte
        </button>
        <button class="btn btn-xs btn-ghost" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
          🔍 Filtres
        </button>
      </div>
    </div>
  </div>

  <!-- Modal d'aide -->
  <dialog id="help_modal" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg mb-4">🗺️ Guide d'utilisation de la carte</h3>
      
      <div class="space-y-4 text-sm">
        <div>
          <h4 class="font-semibold">Navigation</h4>
          <ul class="list-disc list-inside ml-4 space-y-1">
            <li>Utilisez la molette pour zoomer</li>
            <li>Cliquez et glissez pour vous déplacer</li>
            <li>Utilisez les contrôles en haut à droite</li>
          </ul>
        </div>
        
        <div>
          <h4 class="font-semibold">Marqueurs</h4>
          <ul class="list-disc list-inside ml-4 space-y-1">
            <li><span class="inline-block w-3 h-3 bg-blue-500 rounded-full mr-1"></span> Véhicules</li>
            <li><span class="inline-block w-3 h-3 bg-green-500 rounded-full mr-1"></span> Pièces détachées</li>
            <li><span class="inline-block w-3 h-3 bg-yellow-500 rounded-full mr-1"></span> Services</li>
          </ul>
        </div>
        
        <div>
          <h4 class="font-semibold">Fonctionnalités</h4>
          <ul class="list-disc list-inside ml-4 space-y-1">
            <li>Cliquez sur un cluster pour zoomer</li>
            <li>Cliquez sur un marqueur pour voir les détails</li>
            <li>Activez la géolocalisation pour voir les distances</li>
            <li>Dessinez des zones de recherche personnalisées</li>
          </ul>
        </div>
      </div>
      
      <div class="modal-action">
        <form method="dialog">
          <button class="btn">Fermer</button>
        </form>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>Fermer</button>
    </form>
  </dialog>

  <!-- Bouton d'aide flottant -->
  <button class="btn btn-circle btn-primary fixed bottom-4 right-4 lg:bottom-6 lg:right-6 z-50 shadow-lg" 
          onclick="help_modal.showModal()">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
  </button>
</div>

<script>
  // Initialisation des zones sauvegardées au chargement de la page
  document.addEventListener('DOMContentLoaded', function() {
    const savedAreas = JSON.parse(localStorage.getItem('savedSearchAreas') || '[]');
    const container = document.getElementById('saved-areas');
    
    if (savedAreas.length === 0) {
      container.innerHTML = '<p class="text-sm text-base-content/50">Aucune zone sauvegardée</p>';
    } else {
      container.innerHTML = savedAreas.map(area => `
        <div class="flex items-center justify-between p-2 bg-base-100 rounded border">
          <span class="text-sm font-medium">${area.name}</span>
          <div class="flex gap-1">
            <button class="btn btn-xs btn-ghost" onclick="loadSavedArea(${area.id})">
              Charger
            </button>
            <button class="btn btn-xs btn-error btn-ghost" onclick="deleteSavedArea(${area.id})">
              ×
            </button>
          </div>
        </div>
      `).join('');
    }
  });
  
  function loadSavedArea(id) {
    const savedAreas = JSON.parse(localStorage.getItem('savedSearchAreas') || '[]');
    const area = savedAreas.find(a => a.id === id);
    if (area) {
      // Envoyer l'événement au contrôleur Stimulus
      const mapController = document.querySelector('[data-controller="map"]');
      mapController.dispatchEvent(new CustomEvent('map:loadArea', {
        detail: { coordinates: area.coordinates }
      }));
    }
  }
  
  function deleteSavedArea(id) {
    const savedAreas = JSON.parse(localStorage.getItem('savedSearchAreas') || '[]');
    const filteredAreas = savedAreas.filter(a => a.id !== id);
    localStorage.setItem('savedSearchAreas', JSON.stringify(filteredAreas));
    location.reload(); // Recharger pour mettre à jour l'affichage
  }
</script>
