# Vera Trade — environment variables template
#
# Copy this file to `.env` locally (or to your VPS host) and fill in real
# values. `.env` is gitignored — never commit secrets.
#
# On the VPS, `.env` is loaded by docker-compose.yml via the `env_file`
# directive and the keys are exposed as ENV vars to the Rails container.
# In GitHub Actions, these should be configured as repository secrets and
# injected into the workflow env block when needed.

# ──────────────────────────────────────────────────────────────────────
# Rails
# ──────────────────────────────────────────────────────────────────────
RAILS_MASTER_KEY=
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=1
RAILS_SERVE_STATIC_FILES=1

# ──────────────────────────────────────────────────────────────────────
# Database (Postgres, connected via docker-compose network)
# ──────────────────────────────────────────────────────────────────────
DATABASE_HOST=db
VERA_TRADE_REAL_DATABASE_PASSWORD=

# ──────────────────────────────────────────────────────────────────────
# Cloudinary (media storage)
# ──────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ──────────────────────────────────────────────────────────────────────
# Mailer
# ──────────────────────────────────────────────────────────────────────
MAIL_FROM=

# ──────────────────────────────────────────────────────────────────────
# Sentry — error monitoring and performance tracing
# ──────────────────────────────────────────────────────────────────────
# Get the DSN from your Sentry project settings:
#   https://sentry.io → project "vera-trade" → Settings → Client Keys (DSN)
# Leave empty in local dev to skip Sentry entirely — the initializer
# gracefully no-ops when SENTRY_DSN is blank.
SENTRY_DSN=

# Optional: deployed commit SHA used as the Sentry release tag so stack
# traces deep-link to the exact source version. Set by CI/CD on deploy.
# GIT_SHA=

# ──────────────────────────────────────────────────────────────────────
# External APIs (populate when integrating)
# ──────────────────────────────────────────────────────────────────────
# SIV_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
